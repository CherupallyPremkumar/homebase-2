<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Schema creation — MUST be first                                    -->
    <!-- ================================================================== -->
    <changeSet id="promo-000-create-schema" author="homebase">
        <sql>CREATE SCHEMA IF NOT EXISTS hm_promo</sql>
    </changeSet>

    <!-- coupon (CouponEntity extends AbstractJpaStateEntity — no standard entity file, kept from existing schema) -->
    <changeSet id="promo-001-create-coupon" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="coupon" schemaName="hm_promo"/></not>
        </preConditions>
        <createTable tableName="coupon" schemaName="hm_promo">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="code" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="discount_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="discount_value" type="DOUBLE"><constraints nullable="false"/></column>
            <column name="min_order_value" type="DOUBLE"/>
            <column name="max_discount_amount" type="DOUBLE"/>
            <column name="start_date" type="TIMESTAMP"/>
            <column name="end_date" type="TIMESTAMP"/>
            <column name="usage_limit" type="INT" defaultValueNumeric="0"/>
            <column name="usage_count" type="INT" defaultValueNumeric="0"/>
            <column name="usage_per_customer" type="INT" defaultValueNumeric="1"/>
            <column name="applicable_categories" type="TEXT"/>
            <column name="applicable_products" type="TEXT"/>
        </createTable>
        <addUniqueConstraint tableName="coupon" columnNames="code" constraintName="uk_coupon_code" schemaName="hm_promo"/>
        <createIndex indexName="idx_coupon_code" tableName="coupon" schemaName="hm_promo">
            <column name="code"/>
        </createIndex>
        <createIndex indexName="idx_coupon_state" tableName="coupon" schemaName="hm_promo">
            <column name="state_id"/>
        </createIndex>
    </changeSet>

    <!-- coupon_usage_log -->
    <changeSet id="promo-002-create-coupon-usage-log" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="coupon_usage_log" schemaName="hm_promo"/></not>
        </preConditions>
        <createTable tableName="coupon_usage_log" schemaName="hm_promo">
            <column name="usage_id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="coupon_code" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="user_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="used_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="refunded_at" type="TIMESTAMP"/>
            <column name="ip_address" type="VARCHAR(50)"/>
        </createTable>
        <createIndex indexName="idx_usage_coupon_user" tableName="coupon_usage_log" schemaName="hm_promo">
            <column name="coupon_code"/>
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <!-- promo_code_activity_log -->
    <changeSet id="promo-003-create-promo-activity-log" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="promo_code_activity_log" schemaName="hm_promo"/></not>
        </preConditions>
        <createTable tableName="promo_code_activity_log" schemaName="hm_promo">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="promo_code" type="VARCHAR(100)"/>
            <column name="activity_name" type="VARCHAR(100)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>
    </changeSet>

    <!-- Add Amazon-standard columns to coupon -->
    <changeSet id="promo-004-add-coupon-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="coupon" schemaName="hm_promo"/>
            <not><columnExists tableName="coupon" columnName="stacking_allowed" schemaName="hm_promo"/></not>
        </preConditions>
        <addColumn tableName="coupon" schemaName="hm_promo">
            <column name="stacking_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="auto_apply" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="target_audience" type="VARCHAR(50)" defaultValue="ALL"/>
            <column name="target_user_ids" type="TEXT"/>
            <column name="minimum_items" type="INT" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>

    <!-- Add indexes to coupon -->
    <changeSet id="promo-005-add-coupon-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="coupon" schemaName="hm_promo"/>
            <not><indexExists indexName="idx_coupon_dates" schemaName="hm_promo"/></not>
        </preConditions>
        <createIndex indexName="idx_coupon_dates" tableName="coupon" schemaName="hm_promo">
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>
        <createIndex indexName="idx_coupon_active" tableName="coupon" schemaName="hm_promo">
            <column name="state_id"/>
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>
    </changeSet>

    <!-- campaign -->
    <changeSet id="promo-006-create-campaign" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="campaign" schemaName="hm_promo"/></not>
        </preConditions>
        <createTable tableName="campaign" schemaName="hm_promo">
            <!-- BaseJpaEntity columns -->
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <!-- StateEntity columns -->
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <!-- Campaign-specific columns -->
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="campaign_type" type="VARCHAR(50)"/>
            <column name="description" type="TEXT"/>
            <column name="discount_type" type="VARCHAR(20)"/>
            <column name="discount_value" type="DECIMAL(12,2)"/>
            <column name="start_date" type="TIMESTAMP"/>
            <column name="end_date" type="TIMESTAMP"/>
            <column name="budget" type="DECIMAL(15,2)"/>
            <column name="spent" type="DECIMAL(15,2)" defaultValueNumeric="0"/>
            <column name="revenue" type="DECIMAL(15,2)" defaultValueNumeric="0"/>
            <column name="usage_count" type="INT" defaultValueNumeric="0"/>
            <column name="applicable_categories" type="TEXT"/>
            <column name="applicable_products" type="TEXT"/>
            <column name="min_order_amount" type="DECIMAL(12,2)"/>
            <column name="max_discount_amount" type="DECIMAL(12,2)"/>
        </createTable>
        <createIndex indexName="idx_campaign_state" tableName="campaign" schemaName="hm_promo">
            <column name="state_id"/>
        </createIndex>
        <createIndex indexName="idx_campaign_type" tableName="campaign" schemaName="hm_promo">
            <column name="campaign_type"/>
        </createIndex>
        <createIndex indexName="idx_campaign_dates" tableName="campaign" schemaName="hm_promo">
            <column name="start_date"/>
            <column name="end_date"/>
        </createIndex>
    </changeSet>

    <!-- campaign_activity -->
    <changeSet id="promo-007-create-campaign-activity" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="campaign_activity" schemaName="hm_promo"/></not>
        </preConditions>
        <createTable tableName="campaign_activity" schemaName="hm_promo">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="campaign_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="TEXT"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="campaign_activity" baseTableSchemaName="hm_promo"
            baseColumnNames="campaign_id"
            referencedTableName="campaign" referencedTableSchemaName="hm_promo"
            referencedColumnNames="id"
            constraintName="fk_campaign_activity_campaign"/>
    </changeSet>

</databaseChangeLog>
