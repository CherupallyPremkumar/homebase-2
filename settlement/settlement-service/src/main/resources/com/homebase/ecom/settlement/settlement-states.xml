<?xml version="1.0" encoding="UTF-8"?>
<states>
  <flow id='settlement-flow' default='true'>
    <entry-action componentName="settlementEntryAction" />

    <manual-state id='PENDING' initialState='true' meta-mainPath="true" description="Settlement pending, awaiting month-end trigger">
      <on eventId='monthEnd'
          componentName='settlementMonthEndAction'
          newStateId='PROCESSING'
          meta-mainPath="true"
          meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='PROCESSING' meta-mainPath="true" description="Settlement being calculated and processed">
      <on eventId='calculateSettlement'
          componentName='settlementCalculateSettlementAction'
          newStateId='READY_FOR_PAYMENT'
          meta-mainPath="true"
          meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='READY_FOR_PAYMENT' meta-mainPath="true" description="Settlement calculated, ready for admin payout confirmation">
      <on eventId='confirmPayout'
          componentName='settlementConfirmPayoutAction'
          newStateId='SETTLED'
          meta-mainPath="true"
          meta-acls="ADMIN"/>
      <on eventId='rejectSettlement'
          componentName='settlementRejectSettlementAction'
          newStateId='FAILED'
          meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='SETTLED' meta-mainPath="true" description="Settlement completed and paid out">
    </manual-state>

    <manual-state id='FAILED' description="Settlement processing failed">
      <on eventId='retrySettlement'
          componentName='settlementRetrySettlementAction'
          newStateId='PROCESSING'
          meta-acls="ADMIN"/>
    </manual-state>
  </flow>
</states>
