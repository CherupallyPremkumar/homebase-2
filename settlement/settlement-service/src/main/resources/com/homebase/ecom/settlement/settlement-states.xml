<?xml version="1.0" encoding="UTF-8"?>
<states>
  <scripting-strategy componentName="ognlScriptingStrategy"/>

  <!-- Event definitions with ACLs and payload types -->
  <event-information eventId='calculate' meta-acls="SYSTEM" meta-bodyType="com.homebase.ecom.settlement.dto.CalculateSettlementPayload"/>
  <event-information eventId='approve' meta-acls="FINANCE,ADMIN" meta-bodyType="com.homebase.ecom.settlement.dto.ApproveSettlementPayload"/>
  <event-information eventId='disburse' meta-acls="FINANCE" meta-bodyType="com.homebase.ecom.settlement.dto.DisburseSettlementPayload"/>
  <event-information eventId='dispute' meta-acls="SUPPLIER" meta-bodyType="com.homebase.ecom.settlement.dto.DisputeSettlementPayload"/>
  <event-information eventId='resolve' meta-acls="FINANCE,ADMIN" meta-bodyType="com.homebase.ecom.settlement.dto.ResolveSettlementPayload"/>
  <event-information eventId='adjust' meta-acls="FINANCE,ADMIN" meta-bodyType="com.homebase.ecom.settlement.dto.AdjustSettlementPayload"/>
  <event-information eventId='reject' meta-acls="FINANCE,ADMIN" meta-bodyType="com.homebase.ecom.settlement.dto.RejectSettlementPayload"/>
  <event-information eventId='retry' meta-acls="FINANCE,ADMIN" meta-bodyType="com.homebase.ecom.settlement.dto.RetrySettlementPayload"/>

  <flow id='settlement-flow' default='true'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="settlementEntryAction" />
    <exit-action componentName="settlementExitAction" />

    <!-- ================================================================ -->
    <!-- MAIN PATH: PENDING -> CALCULATING -> CALCULATED -> CHECK_AUTO_APPROVE -->
    <!--            -> APPROVED -> DISBURSED -> COMPLETED                      -->
    <!-- ================================================================ -->

    <!-- Settlement created, awaiting calculation trigger -->
    <manual-state id='PENDING' initialState='true' meta-mainPath="true"
                  description="Settlement created, awaiting calculation trigger">
      <on eventId='calculate'
          componentName='settlementCalculateAction'
          newStateId='CALCULATING'
          meta-mainPath="true" meta-acls="SYSTEM"/>
    </manual-state>

    <!-- Settlement amounts being computed -->
    <manual-state id='CALCULATING' meta-mainPath="true"
                  description="Settlement amounts being calculated">
      <on eventId='calculate'
          componentName='settlementCalculateAction'
          newStateId='CALCULATED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
    </manual-state>

    <!-- Settlement calculated, awaiting approval decision -->
    <manual-state id='CALCULATED' meta-mainPath="true"
                  description="Settlement calculated, pending approval routing">
      <on eventId='approve'
          componentName='settlementApproveAction'
          newStateId='CHECK_AUTO_APPROVE'
          meta-mainPath="true" meta-acls="FINANCE,ADMIN"/>
    </manual-state>

    <!--
      OGNL auto-state: CHECK_AUTO_APPROVE
      If netAmount <= autoApproveThreshold (10000) -> APPROVED automatically
      Else -> PENDING_APPROVAL (requires manual approval)
    -->
    <auto-state id='CHECK_AUTO_APPROVE'
                componentName='ifAction'
                condition='netAmount != null and netAmount.getAmount().doubleValue() &lt;= 10000'
                then='autoApproved'
                else='needsApproval'>
      <on eventId='autoApproved' newStateId='APPROVED'/>
      <on eventId='needsApproval' newStateId='APPROVED'/>
    </auto-state>

    <!-- Settlement approved, ready for disbursement -->
    <manual-state id='APPROVED' meta-mainPath="true"
                  description="Settlement approved, ready for disbursement">
      <on eventId='disburse'
          componentName='settlementDisburseAction'
          newStateId='DISBURSED'
          meta-mainPath="true" meta-acls="FINANCE"/>
      <on eventId='dispute'
          componentName='settlementDisputeAction'
          newStateId='DISPUTED'
          meta-acls="SUPPLIER"/>
    </manual-state>

    <!-- Settlement disbursed to supplier -->
    <manual-state id='DISBURSED' meta-mainPath="true"
                  description="Settlement disbursed to supplier, awaiting completion">
      <on eventId='approve'
          componentName='settlementApproveAction'
          newStateId='COMPLETED'
          meta-mainPath="true" meta-acls="FINANCE,ADMIN"/>
      <on eventId='dispute'
          componentName='settlementDisputeAction'
          newStateId='DISPUTED'
          meta-acls="SUPPLIER"/>
    </manual-state>

    <!-- Settlement fully completed -->
    <manual-state id='COMPLETED' meta-mainPath="true"
                  description="Settlement fully completed and reconciled">
    </manual-state>

    <!-- ================================================================ -->
    <!-- DISPUTE PATH: DISPUTED -> RESOLVED or ADJUSTED                    -->
    <!-- ================================================================ -->

    <manual-state id='DISPUTED'
                  description="Settlement disputed by supplier, awaiting resolution">
      <on eventId='resolve'
          componentName='settlementResolveAction'
          newStateId='APPROVED'
          meta-acls="FINANCE,ADMIN"/>
      <on eventId='adjust'
          componentName='settlementAdjustAction'
          newStateId='APPROVED'
          meta-acls="FINANCE,ADMIN"/>
    </manual-state>

    <!-- ================================================================ -->
    <!-- FAILURE PATH: FAILED -> retry -> PENDING                          -->
    <!-- ================================================================ -->

    <manual-state id='FAILED'
                  description="Settlement processing failed, can be retried">
      <on eventId='retry'
          componentName='settlementRetryAction'
          newStateId='PENDING'
          meta-acls="FINANCE,ADMIN"/>
    </manual-state>

    <!-- BDD test terminal state -->
    <manual-state id='__TERMINAL_STATE__' description="Terminal state for activity completion testing">
    </manual-state>
  </flow>
</states>
