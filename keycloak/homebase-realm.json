{
  "realm": "homebase",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "CUSTOMER",
        "description": "Default customer role for storefront users"
      },
      {
        "name": "ADMIN",
        "description": "Administrator with full platform access"
      },
      {
        "name": "WAREHOUSE",
        "description": "Warehouse staff for inventory and shipping"
      },
      {
        "name": "SUPPLIER",
        "description": "Supplier/seller role for marketplace"
      },
      {
        "name": "SYSTEM",
        "description": "System-level operations (webhooks, batch jobs)"
      }
    ]
  },
  "defaultRoles": ["CUSTOMER"],
  "clients": [
    {
      "clientId": "homebase-storefront",
      "name": "HomeBase Storefront",
      "description": "Angular customer-facing storefront",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "rootUrl": "http://localhost:4200",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4200/*"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "scope-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "scope",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "user.attribute": "roles"
          }
        }
      ]
    },
    {
      "clientId": "homebase-admin",
      "name": "HomeBase Admin",
      "description": "Thymeleaf admin panel",
      "enabled": true,
      "publicClient": false,
      "secret": "admin-secret-change-in-production",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "rootUrl": "http://localhost:8080",
      "baseUrl": "/admin",
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "homebase-system",
      "name": "HomeBase System Client",
      "description": "Service account for system operations (webhooks, batch)",
      "enabled": true,
      "publicClient": false,
      "secret": "system-secret-change-in-production",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "protocolMappers": [
        {
          "name": "system-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "claim.value": "[\"SYSTEM\"]",
            "jsonType.label": "JSON",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@homebase.in",
      "email": "admin@homebase.in",
      "enabled": true,
      "firstName": "Admin",
      "lastName": "HomeBase",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": true
        }
      ],
      "realmRoles": ["ADMIN", "CUSTOMER"]
    },
    {
      "username": "warehouse@homebase.in",
      "email": "warehouse@homebase.in",
      "enabled": true,
      "firstName": "Warehouse",
      "lastName": "Staff",
      "credentials": [
        {
          "type": "password",
          "value": "warehouse123",
          "temporary": true
        }
      ],
      "realmRoles": ["WAREHOUSE"]
    },
    {
      "username": "supplier@homebase.in",
      "email": "supplier@homebase.in",
      "enabled": true,
      "firstName": "Test",
      "lastName": "Supplier",
      "credentials": [
        {
          "type": "password",
          "value": "supplier123",
          "temporary": true
        }
      ],
      "realmRoles": ["SUPPLIER"]
    },
    {
      "username": "customer@homebase.in",
      "email": "customer@homebase.in",
      "enabled": true,
      "firstName": "Test",
      "lastName": "Customer",
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": true
        }
      ],
      "realmRoles": ["CUSTOMER"]
    }
  ],
  "scopeMappings": [
    {
      "client": "homebase-storefront",
      "roles": ["CUSTOMER", "SUPPLIER"]
    },
    {
      "client": "homebase-admin",
      "roles": ["ADMIN", "WAREHOUSE", "SUPPLIER"]
    },
    {
      "client": "homebase-system",
      "roles": ["SYSTEM"]
    }
  ]
}
