<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CatalogCategories">

    <resultMap id="categoryResult" type="map">
        <result property="id" column="ID"/>
        <result property="name" column="name"/>
        <result property="slug" column="slug"/>
        <result property="imageUrl" column="image_url"/>
        <result property="bannerImageUrl" column="banner_image_url"/>
        <result property="active" column="active"/>
        <result property="featured" column="featured"/>
        <result property="level" column="level"/>
        <result property="productCount" column="product_count"/>
    </resultMap>

    <resultMap id="menuResult" type="map">
        <result property="id" column="ID"/>
        <result property="name" column="name"/>
        <result property="slug" column="slug"/>
        <result property="parentId" column="parent_id"/>
        <result property="level" column="level"/>
        <result property="imageUrl" column="image_url"/>
        <result property="icon" column="icon"/>
        <result property="displayOrder" column="display_order"/>
    </resultMap>

    <!-- categoryBanners: Categories with banner images -->
    <select id='getBanners-count' resultType="int">
        select count(*) from catalog_categories
        <where>
            AND banner_image_url IS NOT NULL
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
    </select>

    <select id="getBanners" resultMap="categoryResult">
        SELECT * FROM catalog_categories
        <where>
            AND banner_image_url IS NOT NULL
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- categoryMenu: Navigation menu categories -->
    <select id='getMenu-count' resultType="int">
        select count(*) from catalog_categories
        <where>
            AND active = true
            AND show_in_menu = true
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="level != null">
                AND level = #{level}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
    </select>

    <select id="getMenu" resultMap="menuResult">
        SELECT * FROM catalog_categories
        <where>
            AND active = true
            AND show_in_menu = true
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="level != null">
                AND level = #{level}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

</mapper>
