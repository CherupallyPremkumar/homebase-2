<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CatalogCollections">

    <resultMap id="collectionResult" type="map">
        <result property="id" column="ID"/>
        <result property="name" column="name"/>
        <result property="slug" column="slug"/>
        <result property="type" column="type"/>
        <result property="imageUrl" column="image_url"/>
        <result property="featured" column="featured"/>
        <result property="active" column="active"/>
        <result property="productCount" column="product_count"/>
    </resultMap>

    <!-- userCollections: Active collections by type -->
    <select id='getUserCollections-count' resultType="int">
        select count(*) from collections
        <where>
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
    </select>

    <select id="getUserCollections" resultMap="collectionResult">
        SELECT * FROM collections
        <where>
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

</mapper>
