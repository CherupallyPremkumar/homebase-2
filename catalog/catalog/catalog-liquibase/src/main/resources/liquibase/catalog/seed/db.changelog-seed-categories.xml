        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-052"/><column name="category_id" value="436"/>
            <column name="attribute_name" value="Weight (kg)"/><column name="attribute_type" value="NUMBER"/>
