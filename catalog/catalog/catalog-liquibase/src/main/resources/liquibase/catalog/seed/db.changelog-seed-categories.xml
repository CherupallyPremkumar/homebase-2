        <!-- Furniture (436) — Dimensions, Material, Weight -->
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-050"/><column name="category_id" value="436"/>
            <column name="attribute_name" value="Dimensions (LxWxH cm)"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="1"/>
