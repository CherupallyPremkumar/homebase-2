        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-012"/><column name="category_id" value="166"/>
            <column name="attribute_name" value="Material"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="3"/>
        </insert>
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-013"/><column name="category_id" value="166"/>
            <column name="attribute_name" value="Pattern"/><column name="attribute_type" value="SELECT"/>
            <column name="is_required" valueBoolean="false"/>
            <column name="allowed_values" value='["Solid","Striped","Printed","Checked","Embroidered"]'/>
            <column name="sort_order" valueNumeric="4"/>
        </insert>

        <!-- Food (412) — FSSAI No, Expiry, Net Qty, Nutritional Info -->
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-020"/><column name="category_id" value="412"/>
            <column name="attribute_name" value="FSSAI Number"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="1"/>
        </insert>
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-021"/><column name="category_id" value="412"/>
            <column name="attribute_name" value="Expiry Date"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="2"/>
        </insert>
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-022"/><column name="category_id" value="412"/>
            <column name="attribute_name" value="Net Quantity"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="3"/>
        </insert>
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-023"/><column name="category_id" value="412"/>
            <column name="attribute_name" value="Nutritional Info"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="4"/>
        </insert>

        <!-- Health & Beauty (469) — Ingredients, Expiry, Mfg Date -->
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-030"/><column name="category_id" value="469"/>
            <column name="attribute_name" value="Ingredients"/><column name="attribute_type" value="TEXT"/>
