        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-032"/><column name="category_id" value="469"/>
            <column name="attribute_name" value="Manufacturing Date"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="3"/>
        </insert>

        <!-- Media/Books (783) — ISBN, Author, Publisher, Language -->
        <insert tableName="category_attributes" schemaName="hm_catalog">
            <column name="id" value="ATTR-040"/><column name="category_id" value="783"/>
            <column name="attribute_name" value="ISBN"/><column name="attribute_type" value="TEXT"/>
            <column name="is_required" valueBoolean="true"/><column name="sort_order" valueNumeric="1"/>
        </insert>
        <insert tableName="category_attributes" schemaName="hm_catalog">
