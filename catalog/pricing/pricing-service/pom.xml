<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>com.homebase.ecom.pricing</groupId>
		<artifactId>pricing</artifactId>
		<version>${revision}</version>
		<relativePath>../pom.xml</relativePath>
	</parent>

	<artifactId>pricing-service</artifactId>
	<packaging>jar</packaging>
	<name>pricing-service</name>

	<dependencies>
		<dependency>
			<groupId>com.homebase.ecom.pricing</groupId>
			<artifactId>pricing-api</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.pricing</groupId>
			<artifactId>pricing-domain</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.pricing</groupId>
			<artifactId>pricing-infrastructure</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>owiz</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>chenile-core</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.cconfig</groupId>
			<artifactId>cconfig-api</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.cconfig</groupId>
			<artifactId>cconfig-service</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.shared</groupId>
			<artifactId>shared-api</artifactId>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.rulesengine</groupId>
			<artifactId>rules-engine-client</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>chenile-http</artifactId>
		</dependency>

		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>chenile-proxy</artifactId>
		</dependency>

		<!-- Test dependencies -->
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>service-registry-service</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.junit.vintage</groupId>
			<artifactId>junit-vintage-engine</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>cucumber-utils</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>com.h2database</groupId>
			<artifactId>h2</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>chenile-security-api</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>chenile-security</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>cucumber-sec-utils</artifactId>
			<scope>test</scope>
		</dependency>
		<dependency>
			<groupId>com.github.dasniko</groupId>
			<artifactId>testcontainers-keycloak</artifactId>
			<version>3.4.0</version>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<configuration>
					<argLine>-Dspring.classformat.ignore=true</argLine>
					<systemPropertyVariables>
						<DOCKER_API_VERSION>1.44</DOCKER_API_VERSION>
					</systemPropertyVariables>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
