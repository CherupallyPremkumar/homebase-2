<?xml version="1.0" encoding="UTF-8"?>
<states>
  <!-- Enablement and default actions are manually wired in RulesEngineConfiguration -->

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <!-- ════════════════════════════════════════════════════════════════════════ -->
  <!-- Event definitions with ACLs and payload types                          -->
  <!-- ════════════════════════════════════════════════════════════════════════ -->
  <event-information eventId='submit'     meta-acls="ADMIN,POLICY_ADMIN"   meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>
  <event-information eventId='approve'    meta-acls="ADMIN"                meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>
  <event-information eventId='revert'     meta-acls="ADMIN,POLICY_ADMIN"   meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>
  <event-information eventId='activate'   meta-acls="ADMIN"                meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>
  <event-information eventId='deprecate'  meta-acls="ADMIN"                meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>
  <event-information eventId='deactivate' meta-acls="ADMIN"                meta-bodyType="com.homebase.ecom.rulesengine.api.dto.RuleSetEventPayload"/>

  <flow id='ruleSet-flow' default='true'>
    <entry-action componentName="ruleSetEntryAction" />
    <exit-action componentName="ruleSetExitAction" />

    <!-- New rule set, not yet submitted for review -->
    <status id='DRAFT' initialState='true' meta-mainPath="true"
            description="New rule set, not yet submitted">
      <on eventId='submit'
          componentName="ruleSetSubmitAction"
          newStateId='REVIEW'
          meta-mainPath="true" meta-acls="ADMIN,POLICY_ADMIN"/>
      <on eventId='activate'
          componentName="ruleSetActivateAction"
          newStateId='ACTIVE'
          meta-acls="ADMIN"/>
    </status>

    <!-- Rule set under review by admin -->
    <status id='REVIEW' meta-mainPath="true"
            description="Rule set under review">
      <on eventId='approve'
          componentName="ruleSetApproveAction"
          newStateId='ACTIVE'
          meta-mainPath="true" meta-acls="ADMIN"/>
      <on eventId='revert'
          componentName="ruleSetRevertAction"
          newStateId='DRAFT'
          meta-acls="ADMIN,POLICY_ADMIN"/>
    </status>

    <!-- Rule set is active and being enforced -->
    <status id='ACTIVE' meta-mainPath="true"
            description="Rule set is active and being enforced">
      <on eventId='deprecate'
          componentName="ruleSetDeprecateAction"
          newStateId='DEPRECATED'
          meta-mainPath="true" meta-acls="ADMIN"/>
      <on eventId='deactivate'
          componentName="ruleSetDeactivateAction"
          newStateId='DRAFT'
          meta-acls="ADMIN"/>
    </status>

    <!-- Rule set deprecated, no longer enforced -->
    <status id='DEPRECATED'
            description="Rule set is deprecated and no longer enforced">
      <on eventId='activate'
          componentName="ruleSetActivateAction"
          newStateId='ACTIVE'
          meta-acls="ADMIN"/>
    </status>

    <!-- BDD test terminal state -->
    <manual-state id='__TERMINAL_STATE__' description="Terminal state for activity completion testing">
    </manual-state>
  </flow>
</states>
