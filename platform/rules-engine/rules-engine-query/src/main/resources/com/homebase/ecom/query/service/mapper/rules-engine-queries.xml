<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="RulesEngine">

    <resultMap id="ruleSetResult" type="com.homebase.ecom.rulesengine.query.dto.RuleSetQueryDto">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="targetModule" column="target_module"/>
        <result property="defaultEffect" column="default_effect"/>
        <result property="active" column="active"/>
        <result property="stateId" column="state_id"/>
        <result property="flowId" column="flow_id"/>
        <result property="createdTime" column="created_time"/>
        <result property="lastModifiedTime" column="last_modified_time"/>
        <result property="tenant" column="tenant"/>
    </resultMap>

    <resultMap id="ruleResult" type="com.homebase.ecom.rulesengine.query.dto.RuleQueryDto">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="expression" column="expression"/>
        <result property="effect" column="effect"/>
        <result property="priority" column="priority"/>
        <result property="policyId" column="policy_id"/>
        <result property="policyName" column="policy_name"/>
    </resultMap>

    <resultMap id="decisionResult" type="com.homebase.ecom.rulesengine.query.dto.DecisionQueryDto">
        <result property="id" column="id"/>
        <result property="policyId" column="policy_id"/>
        <result property="subjectId" column="subject_id"/>
        <result property="effect" column="effect"/>
        <result property="reasons" column="reasons"/>
        <result property="targetModule" column="target_module"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <select id="getRuleSets" resultMap="ruleSetResult">
        SELECT p.id, p.name, p.description, p.target_module, p.default_effect,
               p.active, p.state_id, p.flow_id,
               p.created_time, p.last_modified_time, p.tenant
        FROM policy p
        <where>
            <if test="name != null">AND p.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="targetModule != null">AND p.target_module = #{targetModule}</if>
            <if test="active != null">AND p.active = #{active}</if>
            <if test="stateId != null">AND p.state_id IN <foreach item="item" collection="stateId" open="(" separator="," close=")">#{item}</foreach></if>
        </where>
        ${orderby} ${pagination}
    </select>

    <select id="getRuleSets-count" resultType="int">
        SELECT count(*) FROM policy p
        <where>
            <if test="name != null">AND p.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="targetModule != null">AND p.target_module = #{targetModule}</if>
            <if test="active != null">AND p.active = #{active}</if>
            <if test="stateId != null">AND p.state_id IN <foreach item="item" collection="stateId" open="(" separator="," close=")">#{item}</foreach></if>
        </where>
    </select>

    <select id="getRulesByRuleSet" resultMap="ruleResult">
        SELECT r.id, r.name, r.expression, r.effect, r.priority,
               r.policy_id, p.name AS policy_name
        FROM policy_rule r JOIN policy p ON r.policy_id = p.id
        <where>
            <if test="policyId != null">AND r.policy_id = #{policyId}</if>
        </where>
        ${orderby} ${pagination}
    </select>

    <select id="getRulesByRuleSet-count" resultType="int">
        SELECT count(*) FROM policy_rule r JOIN policy p ON r.policy_id = p.id
        <where>
            <if test="policyId != null">AND r.policy_id = #{policyId}</if>
        </where>
    </select>

    <select id="getDecisions" resultMap="decisionResult">
        SELECT d.id, d.policy_id, d.subject_id, d.effect,
               d.reasons, d.target_module, d.created_time
        FROM decisions d
        <where>
            <if test="targetModule != null">AND d.target_module = #{targetModule}</if>
            <if test="effect != null">AND d.effect IN <foreach item="item" collection="effect" open="(" separator="," close=")">#{item}</foreach></if>
            <if test="createdTime != null">AND d.created_time BETWEEN #{createdTime[0]} AND #{createdTime[1]}</if>
            <if test="policyId != null">AND d.policy_id = #{policyId}</if>
        </where>
        ${orderby} ${pagination}
    </select>

    <select id="getDecisions-count" resultType="int">
        SELECT count(*) FROM decisions d
        <where>
            <if test="targetModule != null">AND d.target_module = #{targetModule}</if>
            <if test="effect != null">AND d.effect IN <foreach item="item" collection="effect" open="(" separator="," close=")">#{item}</foreach></if>
            <if test="createdTime != null">AND d.created_time BETWEEN #{createdTime[0]} AND #{createdTime[1]}</if>
            <if test="policyId != null">AND d.policy_id = #{policyId}</if>
        </where>
    </select>

    <resultMap id="factDefinitionResult" type="map">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="dataType" column="data_type"/>
        <result property="module" column="module"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <select id="getFactDefinitions" resultMap="factDefinitionResult">
        SELECT fd.id, fd.name, fd.description, fd.data_type, fd.module, fd.created_time
        FROM fact_definition fd
        <where>
            <if test="name != null">AND fd.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="dataType != null">AND fd.data_type = #{dataType}</if>
            <if test="module != null">AND fd.module = #{module}</if>
        </where>
        ${orderby} ${pagination}
    </select>

    <select id="getFactDefinitions-count" resultType="int">
        SELECT count(*) FROM fact_definition fd
        <where>
            <if test="name != null">AND fd.name LIKE CONCAT('%', #{name}, '%')</if>
            <if test="dataType != null">AND fd.data_type = #{dataType}</if>
            <if test="module != null">AND fd.module = #{module}</if>
        </where>
    </select>

</mapper>
