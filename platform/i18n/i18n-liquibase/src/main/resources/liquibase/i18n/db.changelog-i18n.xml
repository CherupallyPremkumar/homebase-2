<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Schema creation — MUST be first                                    -->
    <!-- ================================================================== -->
    <changeSet id="i18n-000-create-schema" author="homebase">
        <sql>CREATE SCHEMA IF NOT EXISTS hm_i18n</sql>
    </changeSet>

    <!-- ================================================================== -->
    <!-- currencies — supported currencies with symbols and precision        -->
    <!-- ================================================================== -->
    <changeSet id="i18n-001-create-currencies" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="currencies" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="currencies" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="code" type="VARCHAR(3)"><constraints unique="true"/></column>
            <column name="name" type="VARCHAR(100)"/>
            <column name="symbol" type="VARCHAR(10)"/>
            <column name="decimal_places" type="INT" defaultValueNumeric="2"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- exchange_rates — currency conversion rates with date tracking        -->
    <!-- ================================================================== -->
    <changeSet id="i18n-002-create-exchange-rates" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="exchange_rates" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="exchange_rates" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="base_currency_id" type="VARCHAR(255)"><constraints nullable="false" foreignKeyName="fk_exchange_base_currency" references="currencies(id)"/></column>
            <column name="target_currency_id" type="VARCHAR(255)"><constraints nullable="false" foreignKeyName="fk_exchange_target_currency" references="currencies(id)"/></column>
            <column name="rate" type="DECIMAL(18,8)"/>
            <column name="rate_date" type="DATE"/>
            <column name="source" type="VARCHAR(50)"/>
            <column name="is_current" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_exchange_rates_base" tableName="exchange_rates" schemaName="hm_i18n">
            <column name="base_currency_id"/>
        </createIndex>
        <createIndex indexName="idx_exchange_rates_current" tableName="exchange_rates" schemaName="hm_i18n">
            <column name="is_current"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- countries — supported countries with region classification           -->
    <!-- ================================================================== -->
    <changeSet id="i18n-003-create-countries" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="countries" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="countries" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="country_code" type="VARCHAR(2)"><constraints unique="true"/></column>
            <column name="country_code_3" type="VARCHAR(3)"/>
            <column name="name" type="VARCHAR(100)"/>
            <column name="region" type="VARCHAR(50)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="requires_import_duty" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- country_settings — locale defaults per country                      -->
    <!-- ================================================================== -->
    <changeSet id="i18n-004-create-country-settings" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="country_settings" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="country_settings" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="country_id" type="VARCHAR(255)"><constraints unique="true" nullable="false" foreignKeyName="fk_country_settings_country" references="countries(id)"/></column>
            <column name="default_currency_id" type="VARCHAR(255)"><constraints nullable="false" foreignKeyName="fk_country_settings_currency" references="currencies(id)"/></column>
            <column name="default_language_code" type="VARCHAR(5)"/>
            <column name="date_format" type="VARCHAR(20)"/>
            <column name="number_format" type="VARCHAR(20)"/>
            <column name="timezone" type="VARCHAR(50)"/>
            <column name="phone_code" type="VARCHAR(5)"/>
            <column name="is_eu_member" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <createIndex indexName="idx_country_settings_country" tableName="country_settings" schemaName="hm_i18n">
            <column name="country_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- locale_languages — supported languages with directionality          -->
    <!-- ================================================================== -->
    <changeSet id="i18n-005-create-locale-languages" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="locale_languages" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="locale_languages" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="language_code" type="VARCHAR(5)"><constraints unique="true"/></column>
            <column name="language_name" type="VARCHAR(100)"/>
            <column name="native_name" type="VARCHAR(100)"/>
            <column name="text_direction" type="VARCHAR(3)" defaultValue="LTR"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- locale_translations — entity field translations by language          -->
    <!-- ================================================================== -->
    <changeSet id="i18n-006-create-locale-translations" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="locale_translations" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="locale_translations" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="entity_type" type="VARCHAR(50)"/>
            <column name="entity_id" type="VARCHAR(255)"/>
            <column name="language_code" type="VARCHAR(5)"/>
            <column name="field_name" type="VARCHAR(100)"/>
            <column name="field_value" type="TEXT"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <createIndex indexName="idx_translations_entity" tableName="locale_translations" schemaName="hm_i18n">
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="language_code"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- import_duties — customs duty rates by HS code and country pair       -->
    <!-- ================================================================== -->
    <changeSet id="i18n-007-create-import-duties" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="import_duties" schemaName="hm_i18n"/></not></preConditions>
        <createTable tableName="import_duties" schemaName="hm_i18n">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="hs_code" type="VARCHAR(12)"/>
            <column name="importing_country_id" type="VARCHAR(255)"><constraints nullable="false" foreignKeyName="fk_duties_importing_country" references="countries(id)"/></column>
            <column name="exporting_country_id" type="VARCHAR(255)"><constraints nullable="false" foreignKeyName="fk_duties_exporting_country" references="countries(id)"/></column>
            <column name="duty_percentage" type="INT"/>
            <column name="duty_amount_fixed" type="BIGINT"/>
            <column name="minimum_duty" type="BIGINT"/>
            <column name="effective_date" type="DATE"/>
            <column name="expiry_date" type="DATE"/>
            <column name="preferential_agreement" type="VARCHAR(100)"/>
            <column name="notes" type="VARCHAR(500)"/>
        </createTable>
        <createIndex indexName="idx_duties_importing" tableName="import_duties" schemaName="hm_i18n">
            <column name="importing_country_id"/>
        </createIndex>
        <createIndex indexName="idx_duties_hs" tableName="import_duties" schemaName="hm_i18n">
            <column name="hs_code"/>
        </createIndex>
    </changeSet>

