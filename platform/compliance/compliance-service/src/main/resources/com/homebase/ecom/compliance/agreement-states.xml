<?xml version="1.0" encoding="UTF-8"?>
<states>
    <event-information eventId="publish"   meta-acls="LEGAL_ADMIN,test.premium" meta-bodyType="com.homebase.ecom.compliance.dto.AgreementPayload"/>
    <event-information eventId="supersede" meta-acls="LEGAL_ADMIN,test.premium" meta-bodyType="com.homebase.ecom.compliance.dto.AgreementPayload"/>
    <event-information eventId="suspend"   meta-acls="LEGAL_ADMIN,COMPLIANCE_OFFICER,test.premium"/>
    <event-information eventId="reinstate" meta-acls="LEGAL_ADMIN,test.premium"/>
    <event-information eventId="retire"    meta-acls="LEGAL_ADMIN,test.premium"/>

    <flow id="agreement" initial-state="DRAFT" default="true">
        <security-strategy componentName="stmSecurityStrategy"/>

        <manual-state id="DRAFT" initialState="true" meta-mainPath="true">
            <on eventId="publish" newStateId="PUBLISHED"/>
        </manual-state>

        <manual-state id="PUBLISHED" meta-mainPath="true">
            <on eventId="supersede" newStateId="SUPERSEDED"/>
            <on eventId="suspend"   newStateId="SUSPENDED"/>
            <on eventId="retire"    newStateId="RETIRED"/>
        </manual-state>

        <manual-state id="SUPERSEDED" meta-isFinal="true"/>

        <manual-state id="SUSPENDED">
            <on eventId="reinstate" newStateId="PUBLISHED"/>
            <on eventId="retire"    newStateId="RETIRED"/>
        </manual-state>

        <manual-state id="RETIRED" meta-isFinal="true"/>
    </flow>
</states>
