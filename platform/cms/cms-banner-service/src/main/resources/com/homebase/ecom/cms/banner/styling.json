{
  "rules": [
    {
      "expression": "stateId=='ACTIVE'",
      "style": {"color": "Green", "thickness": 2.0}
    },
    {
      "expression": "stateId=='SCHEDULED'",
      "style": {"color": "Orange", "thickness": 2.0}
    },
    {
      "expression": "stateId=='EXPIRED'",
      "style": {"color": "Gray", "thickness": 1.5}
    },
    {
      "expression": "highlight==true",
      "style": {"color": "Fuchsia", "thickness": 2.5}
    }
  ]
}
