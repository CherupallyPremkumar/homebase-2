<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- tax_rates — GST rates per HSN code with effective dates             -->
    <!-- ================================================================== -->
    <changeSet id="tax-001-create-tax-rates" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="tax_rates"/></not></preConditions>
        <createTable tableName="tax_rates">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="hsn_code" type="VARCHAR(8)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="gst_rate" type="DECIMAL(5,2)"><constraints nullable="false"/></column>
            <column name="cess_rate" type="DECIMAL(5,2)" defaultValueNumeric="0"/>
            <column name="tcs_rate" type="DECIMAL(5,2)" defaultValueNumeric="1"/>
            <column name="effective_from" type="DATE"/>
            <column name="effective_to" type="DATE"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_tax_rates_hsn" tableName="tax_rates">
            <column name="hsn_code"/>
            <column name="active"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- tax_category_mapping — product category → HSN code                  -->
    <!-- ================================================================== -->
    <changeSet id="tax-002-create-tax-category-mapping" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="tax_category_mapping"/></not></preConditions>
        <createTable tableName="tax_category_mapping">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="product_category" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="sub_category" type="VARCHAR(100)"/>
            <column name="hsn_code" type="VARCHAR(8)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(500)"/>
        </createTable>
        <createIndex indexName="idx_tax_cat_mapping_category" tableName="tax_category_mapping">
            <column name="product_category"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- tax_regions — Indian state/UT codes for GST jurisdiction             -->
    <!-- ================================================================== -->
    <changeSet id="tax-003-create-tax-regions" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="tax_regions"/></not></preConditions>
        <createTable tableName="tax_regions">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_code" type="VARCHAR(2)"><constraints nullable="false" unique="true"/></column>
            <column name="state_name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="state_alpha" type="VARCHAR(5)"><constraints nullable="false"/></column>
            <column name="union_territory" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- tax_exemptions — B2B, exports, SEZ, essential goods                 -->
    <!-- ================================================================== -->
    <changeSet id="tax-004-create-tax-exemptions" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="tax_exemptions"/></not></preConditions>
        <createTable tableName="tax_exemptions">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="exemption_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="exemption_value" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="full_exemption" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_tax_exemptions_type" tableName="tax_exemptions">
            <column name="exemption_type"/>
            <column name="active"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- order_tax_lines — per-order historical tax records                   -->
    <!-- ================================================================== -->
    <changeSet id="tax-005-create-order-tax-lines" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="order_tax_lines"/></not></preConditions>
        <createTable tableName="order_tax_lines">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="hsn_code" type="VARCHAR(8)"/>
            <column name="tax_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="taxable_amount" type="DECIMAL(19,2)"><constraints nullable="false"/></column>
            <column name="gst_rate" type="DECIMAL(5,2)"/>
            <column name="cgst_amount" type="DECIMAL(19,2)" defaultValueNumeric="0"/>
            <column name="sgst_amount" type="DECIMAL(19,2)" defaultValueNumeric="0"/>
            <column name="igst_amount" type="DECIMAL(19,2)" defaultValueNumeric="0"/>
            <column name="cess_amount" type="DECIMAL(19,2)" defaultValueNumeric="0"/>
            <column name="tcs_amount" type="DECIMAL(19,2)" defaultValueNumeric="0"/>
            <column name="total_tax" type="DECIMAL(19,2)"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_order_tax_lines_order" tableName="order_tax_lines">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
