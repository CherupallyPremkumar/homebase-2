    <!--
        CConfig: Production-grade platform configuration
        Columns: module_name, key_name, avalue, custom_attribute, path
        custom_attribute defaults to __GLOBAL__

        Organization:
        - cart module: limits, TTL, pricing thresholds
        - checkout module: timeouts, retry, address validation
        - order module: cancellation, fraud, lifecycle
        - payment module: gateways, retry, limits
        - shipping module: carriers, free shipping, delivery SLA
        - return module: windows, restocking, eligibility
        - product module: listing limits, media, moderation
        - inventory module: low-stock, reservation TTL
        - promo module: stacking, limits, min order
        - review module: moderation, auto-publish
        - support module: SLA, auto-close
        - settlement module: payout schedule, commission
        - notification module: channels, rate limits, DND
        - platform module: maintenance, feature flags
    -->
