<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Schema creation — MUST be first                                    -->
    <!-- ================================================================== -->
    <changeSet id="supplier_lifecycle-000-create-schema" author="homebase">
        <sql>CREATE SCHEMA IF NOT EXISTS hm_supplier_lifecycle</sql>
    </changeSet>

    <!-- supplier_lifecycle_saga (STM entity — extends AbstractJpaStateEntity) -->
    <changeSet id="supplier-lifecycle-001-create-saga" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="supplier_lifecycle_saga" schemaName="hm_supplier_lifecycle"/></not></preConditions>
        <createTable tableName="supplier_lifecycle_saga" schemaName="hm_supplier_lifecycle">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="action" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="reason" type="VARCHAR(1000)"/>
            <column name="products_affected" type="INT" defaultValueNumeric="0"/>
            <column name="catalog_entries_removed" type="INT" defaultValueNumeric="0"/>
            <column name="inventory_frozen" type="INT" defaultValueNumeric="0"/>
            <column name="orders_cancelled" type="INT" defaultValueNumeric="0"/>
            <column name="error_message" type="VARCHAR(2000)"/>
            <column name="retry_count" type="INT" defaultValueNumeric="0"/>
        </createTable>
        <createIndex indexName="idx_supplier_lifecycle_saga_supplier" tableName="supplier_lifecycle_saga" schemaName="hm_supplier_lifecycle">
            <column name="supplier_id"/>
        </createIndex>
    </changeSet>

    <!-- supplier_lifecycle_saga_activity -->
    <changeSet id="supplier-lifecycle-002-create-saga-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="supplier_lifecycle_saga_activity" schemaName="hm_supplier_lifecycle"/></not></preConditions>
        <createTable tableName="supplier_lifecycle_saga_activity" schemaName="hm_supplier_lifecycle">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="saga_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>
    </changeSet>

    <!-- supplier_performance_metrics -->
    <changeSet id="supplier-lifecycle-003-create-performance-metrics" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="supplier_performance_metrics" schemaName="hm_supplier_lifecycle"/></not></preConditions>
        <createTable tableName="supplier_performance_metrics" schemaName="hm_supplier_lifecycle">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="metric_date" type="DATE"><constraints nullable="false"/></column>
            <column name="period_type" type="VARCHAR(10)" defaultValue="DAILY"/>
            <column name="total_orders" type="INT" defaultValueNumeric="0"/>
            <column name="orders_fulfilled" type="INT" defaultValueNumeric="0"/>
            <column name="orders_cancelled" type="INT" defaultValueNumeric="0"/>
            <column name="orders_returned" type="INT" defaultValueNumeric="0"/>
            <column name="defect_rate_pct" type="DECIMAL(5,2)"/>
            <column name="on_time_ship_rate_pct" type="DECIMAL(5,2)"/>
            <column name="late_ship_rate_pct" type="DECIMAL(5,2)"/>
            <column name="return_rate_pct" type="DECIMAL(5,2)"/>
            <column name="cancellation_rate_pct" type="DECIMAL(5,2)"/>
            <column name="customer_satisfaction_avg" type="DECIMAL(3,2)"/>
        </createTable>
    </changeSet>

    <!-- supplier_probation_history -->
    <changeSet id="supplier-lifecycle-004-create-probation-history" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="supplier_probation_history" schemaName="hm_supplier_lifecycle"/></not></preConditions>
        <createTable tableName="supplier_probation_history" schemaName="hm_supplier_lifecycle">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="lifecycle_saga_id" type="VARCHAR(255)"/>
            <column name="probation_type" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="reason" type="VARCHAR(1000)"><constraints nullable="false"/></column>
            <column name="triggered_by_metric" type="VARCHAR(50)"/>
            <column name="metric_value" type="DECIMAL(8,2)"/>
            <column name="threshold_value" type="DECIMAL(8,2)"/>
            <column name="start_date" type="DATE"><constraints nullable="false"/></column>
            <column name="end_date" type="DATE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
        </createTable>
    </changeSet>

    <!-- supplier_appeal_requests -->
    <changeSet id="supplier-lifecycle-005-create-appeal-requests" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="supplier_appeal_requests" schemaName="hm_supplier_lifecycle"/></not></preConditions>
        <createTable tableName="supplier_appeal_requests" schemaName="hm_supplier_lifecycle">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="probation_id" type="VARCHAR(255)"/>
            <column name="lifecycle_saga_id" type="VARCHAR(255)"/>
            <column name="previous_action" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="appeal_reason" type="VARCHAR(2000)"><constraints nullable="false"/></column>
            <column name="supporting_docs_json" type="TEXT"/>
            <column name="corrective_action_plan" type="VARCHAR(2000)"/>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="reviewed_by" type="VARCHAR(255)"/>
            <column name="review_notes" type="VARCHAR(2000)"/>
            <column name="reviewed_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
