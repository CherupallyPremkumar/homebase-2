<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="payment-001-create-payment" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="payment"/></not></preConditions>
        <createTable tableName="payment">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="customer_id" type="VARCHAR(255)"/>
            <column name="amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(3)" defaultValue="INR"/>
            <column name="payment_method" type="VARCHAR(20)"/>
            <column name="gateway_transaction_id" type="VARCHAR(255)"/>
            <column name="gateway_response" type="TEXT"/>
            <column name="retry_count" type="INT" defaultValueNumeric="0"/>
            <column name="failure_reason" type="TEXT"/>
        </createTable>
    </changeSet>

    <changeSet id="payment-002-create-payment-activity-log" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="payment_activity_log"/></not></preConditions>
        <createTable tableName="payment_activity_log">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="payment_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="TEXT"/>
            <column name="success" type="BOOLEAN"/>
        </createTable>
    </changeSet>

    <!-- Add missing columns to payment for Amazon-standard schema -->
    <changeSet id="payment-003-add-payment-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="payment"/>
            <not><columnExists tableName="payment" columnName="checkout_id"/></not>
        </preConditions>
        <addColumn tableName="payment">
            <column name="checkout_id" type="VARCHAR(255)"/>
            <column name="payment_method_type" type="VARCHAR(50)"/>
            <column name="card_last_four" type="VARCHAR(4)"/>
            <column name="card_brand" type="VARCHAR(50)"/>
            <column name="upi_id" type="VARCHAR(255)"/>
            <column name="gateway_name" type="VARCHAR(50)"/>
            <column name="gateway_order_id" type="VARCHAR(255)"/>
            <column name="gateway_payment_id" type="VARCHAR(255)"/>
            <column name="idempotency_key" type="VARCHAR(255)">
                <constraints unique="true" uniqueConstraintName="uk_payment_idempotency_key"/>
            </column>
            <column name="refund_amount" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
            <column name="refund_reason" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

    <!-- payment_refunds (BaseJpaEntity) -->
    <changeSet id="payment-004-create-payment-refunds" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="payment_refunds"/></not>
        </preConditions>
        <createTable tableName="payment_refunds">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="payment_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(3)" defaultValue="INR"/>
            <column name="reason" type="VARCHAR(500)"/>
            <column name="refund_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="gateway_refund_id" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="processed_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="payment_refunds" baseColumnNames="payment_id"
            referencedTableName="payment" referencedColumnNames="id" constraintName="fk_payment_refunds_payment"/>
        <createIndex indexName="idx_payment_refunds_payment" tableName="payment_refunds">
            <column name="payment_id"/>
        </createIndex>
    </changeSet>

    <!-- payment_webhook_log (BaseJpaEntity) -->
    <changeSet id="payment-005-create-payment-webhook-log" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="payment_webhook_log"/></not>
        </preConditions>
        <createTable tableName="payment_webhook_log">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="gateway_name" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="event_type" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="payload" type="TEXT"><constraints nullable="false"/></column>
            <column name="signature" type="VARCHAR(500)"/>
            <column name="processed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="payment_id" type="VARCHAR(255)"/>
            <column name="error_message" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex indexName="idx_webhook_log_gateway_event" tableName="payment_webhook_log">
            <column name="gateway_name"/>
            <column name="event_type"/>
        </createIndex>
        <createIndex indexName="idx_webhook_log_payment" tableName="payment_webhook_log">
            <column name="payment_id"/>
        </createIndex>
    </changeSet>

    <!-- saved_payment_methods (BaseJpaEntity) -->
    <changeSet id="payment-006-create-saved-payment-methods" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="saved_payment_methods"/></not>
        </preConditions>
        <createTable tableName="saved_payment_methods">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="customer_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="method_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="display_name" type="VARCHAR(255)"/>
            <column name="card_last_four" type="VARCHAR(4)"/>
            <column name="card_brand" type="VARCHAR(50)"/>
            <column name="card_expiry_month" type="INT"/>
            <column name="card_expiry_year" type="INT"/>
            <column name="upi_id" type="VARCHAR(255)"/>
            <column name="gateway_token" type="VARCHAR(500)"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_saved_payment_customer" tableName="saved_payment_methods">
            <column name="customer_id"/>
        </createIndex>
        <addUniqueConstraint tableName="saved_payment_methods" columnNames="gateway_token"
            constraintName="uk_payment_method_token"/>
    </changeSet>

    <!-- Indexes on payment table -->
    <changeSet id="payment-007-add-payment-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="payment"/>
            <not><indexExists indexName="idx_payment_order"/></not>
        </preConditions>
        <createIndex indexName="idx_payment_order" tableName="payment">
            <column name="order_id"/>
        </createIndex>
        <createIndex indexName="idx_payment_customer" tableName="payment">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_payment_state" tableName="payment">
            <column name="state_id"/>
        </createIndex>
        <createIndex indexName="idx_payment_idempotency" tableName="payment">
            <column name="idempotency_key"/>
        </createIndex>
    </changeSet>

    <!-- Add gateway fee columns to payment -->
    <changeSet id="payment-008-add-fee-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="payment"/>
            <not><columnExists tableName="payment" columnName="gateway_fee"/></not>
        </preConditions>
        <addColumn tableName="payment">
            <column name="gateway_fee" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
            <column name="gateway_fee_percent" type="DECIMAL(5,2)" defaultValueNumeric="0"/>
            <column name="gst_on_fee" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
