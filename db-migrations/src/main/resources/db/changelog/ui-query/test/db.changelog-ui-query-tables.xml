        </createTable>
    </changeSet>

    <!-- Variant Media -->
    <changeSet id="ui-query-test-variant-media" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="variant_media"/></not></preConditions>
        <createTable tableName="variant_media">
            <column name="variant_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
