<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Test-only: creates all cross-module tables needed by ui-query BDD tests.
        Uses preConditions so safe to run alongside production changelogs.
    -->

    <!-- Products -->
    <changeSet id="ui-query-test-products" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="products"/></not></preConditions>
        <sql>
            CREATE TABLE products (
                id VARCHAR(255) NOT NULL PRIMARY KEY,
                name VARCHAR(255), description VARCHAR(2000), short_description VARCHAR(500),
                brand VARCHAR(255), category_id VARCHAR(255), slug VARCHAR(300),
                meta_title VARCHAR(200), meta_description VARCHAR(500),
                state_id VARCHAR(100), flow_id VARCHAR(100),
                version BIGINT DEFAULT 0, created_time TIMESTAMP, last_modified_time TIMESTAMP,
                created_by VARCHAR(255), last_modified_by VARCHAR(255), tenant VARCHAR(255),
                state_entry_time TIMESTAMP, sla_yellow_date TIMESTAMP, sla_red_date TIMESTAMP,
                sla_tending_late INT DEFAULT 0, sla_late INT DEFAULT 0, test_entity BOOLEAN DEFAULT FALSE
            )
        </sql>
    </changeSet>

    <!-- Categories -->
    <changeSet id="ui-query-test-categories" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="categories"/></not></preConditions>
        <createTable tableName="categories">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="parent_id" type="VARCHAR(255)"/>
            <column name="path" type="VARCHAR(255)"/>
            <column name="depth" type="INTEGER" defaultValueNumeric="0"/>
            <column name="display_order" type="INTEGER" defaultValueNumeric="0"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <!-- Product Variants -->
    <changeSet id="ui-query-test-product-variants" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="product_variants"/></not></preConditions>
        <createTable tableName="product_variants">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(255)"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <!-- Variant Attributes -->
    <changeSet id="ui-query-test-variant-attributes" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="variant_attributes"/></not></preConditions>
        <createTable tableName="variant_attributes">
            <column name="variant_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="attribute_key" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="attribute_value" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!-- Media Assets -->
    <changeSet id="ui-query-test-media-assets" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="media_assets"/></not></preConditions>
        <createTable tableName="media_assets">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="original_url" type="VARCHAR(1000)"/>
            <column name="cdn_url" type="VARCHAR(1000)"/>
            <column name="thumbnail_url" type="VARCHAR(1000)"/>
            <column name="medium_url" type="VARCHAR(1000)"/>
            <column name="zoom_url" type="VARCHAR(1000)"/>
            <column name="type" type="VARCHAR(50)"/>
            <column name="mime_type" type="VARCHAR(255)"/>
            <column name="file_size_bytes" type="BIGINT" defaultValueNumeric="0"/>
            <column name="width" type="INTEGER" defaultValueNumeric="0"/>
            <column name="height" type="INTEGER" defaultValueNumeric="0"/>
            <column name="alt_text" type="VARCHAR(255)"/>
            <column name="processing_status" type="VARCHAR(50)" defaultValue="PENDING"/>
        </createTable>
    </changeSet>

    <!-- Product Media -->
