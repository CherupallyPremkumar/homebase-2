    <!--
        Offers table: includes BOTH old (seller_id, price) and new (supplier_id, selling_price)
        column names so product-testdata inserts (old names) AND our queries (new names) both work.
        In production, V61 migration renames columns. In H2 test, both exist side by side.
    -->
    <changeSet id="ui-query-test-offers" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="offers"/></not></preConditions>
        <sql>
            CREATE TABLE offers (
                id VARCHAR(255) NOT NULL PRIMARY KEY,
                product_id VARCHAR(255) NOT NULL,
                variant_id VARCHAR(255),
                -- Old column names (kept for product-testdata compatibility)
                seller_id VARCHAR(255),
                price NUMERIC(10,2),
                -- New column names (V61 production schema)
                supplier_id VARCHAR(255),
                selling_price NUMERIC(10,2),
                mrp NUMERIC(10,2),
                discount_percent NUMERIC(5,2) DEFAULT 0,
                currency VARCHAR(3) DEFAULT 'INR',
                active BOOLEAN DEFAULT TRUE,
                buy_box_winner BOOLEAN DEFAULT FALSE,
                fulfillment_type VARCHAR(20) DEFAULT 'MERCHANT',
                shipping_cost NUMERIC(10,2) DEFAULT 0,
                delivery_days INT,
                state_id VARCHAR(100),
                flow_id VARCHAR(100),
                state_entry_time TIMESTAMP,
                sla_yellow_date TIMESTAMP, sla_red_date TIMESTAMP,
                sla_tending_late INT DEFAULT 0, sla_late INT DEFAULT 0,
                version BIGINT DEFAULT 0, created_time TIMESTAMP, last_modified_time TIMESTAMP,
                created_by VARCHAR(255), last_modified_by VARCHAR(255), tenant VARCHAR(255),
                test_entity BOOLEAN DEFAULT FALSE,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        </sql>
    </changeSet>

