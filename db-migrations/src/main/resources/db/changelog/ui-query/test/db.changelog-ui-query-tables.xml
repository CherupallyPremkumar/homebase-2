        </createTable>
    </changeSet>

    <!-- Category Attributes -->
    <changeSet id="ui-query-test-category-attributes" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="category_attributes"/></not></preConditions>
        <createTable tableName="category_attributes">
            <column name="category_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="attribute_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <!-- Product Attribute Values -->
    <changeSet id="ui-query-test-product-attr-values" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="product_attribute_values"/></not></preConditions>
        <createTable tableName="product_attribute_values">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"/>
            <column name="attribute_id" type="VARCHAR(255)"/>
            <column name="option_id" type="VARCHAR(255)"/>
            <column name="raw_value" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!-- Product Activity Log -->
    <changeSet id="ui-query-test-product-activity" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="product_activity_log"/></not></preConditions>
        <createTable tableName="product_activity_log">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
            <column name="activity_success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="last_modified_by" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!--
        Offers table: includes BOTH old (seller_id, price) and new (supplier_id, selling_price)
        column names so product-testdata inserts (old names) AND our queries (new names) both work.
        In production, V61 migration renames columns. In H2 test, both exist side by side.
    -->
    <changeSet id="ui-query-test-offers" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="offers"/></not></preConditions>
        <sql>
            CREATE TABLE offers (
                id VARCHAR(255) NOT NULL PRIMARY KEY,
                product_id VARCHAR(255) NOT NULL,
                variant_id VARCHAR(255),
                -- Old column names (kept for product-testdata compatibility)
                seller_id VARCHAR(255),
                price NUMERIC(10,2),
                -- New column names (V61 production schema)
                supplier_id VARCHAR(255),
                selling_price NUMERIC(10,2),
                mrp NUMERIC(10,2),
                discount_percent NUMERIC(5,2) DEFAULT 0,
                currency VARCHAR(3) DEFAULT 'INR',
                active BOOLEAN DEFAULT TRUE,
                buy_box_winner BOOLEAN DEFAULT FALSE,
                fulfillment_type VARCHAR(20) DEFAULT 'MERCHANT',
                shipping_cost NUMERIC(10,2) DEFAULT 0,
                delivery_days INT,
                state_id VARCHAR(100),
                flow_id VARCHAR(100),
                state_entry_time TIMESTAMP,
                sla_yellow_date TIMESTAMP, sla_red_date TIMESTAMP,
                sla_tending_late INT DEFAULT 0, sla_late INT DEFAULT 0,
                version BIGINT DEFAULT 0, created_time TIMESTAMP, last_modified_time TIMESTAMP,
                created_by VARCHAR(255), last_modified_by VARCHAR(255), tenant VARCHAR(255),
                test_entity BOOLEAN DEFAULT FALSE,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        </sql>
    </changeSet>

    <!-- Inventory Item -->
    <changeSet id="ui-query-test-inventory-item" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="inventory_item"/></not></preConditions>
        <sql>
            CREATE TABLE inventory_item (
                id VARCHAR(255) NOT NULL PRIMARY KEY,
                sku VARCHAR(255), asin VARCHAR(255),
                product_id VARCHAR(255), variant_id VARCHAR(255),
                quantity INT DEFAULT 0, available_quantity INT DEFAULT 0,
                reserved_quantity INT DEFAULT 0, inbound_quantity INT DEFAULT 0,
                damaged_quantity INT DEFAULT 0,
                primary_fc VARCHAR(255),
                is_fba BOOLEAN DEFAULT FALSE, is_merchant_fulfilled BOOLEAN DEFAULT TRUE,
                low_stock_threshold INT DEFAULT 10, out_of_stock_threshold INT DEFAULT 0,
                status VARCHAR(50) DEFAULT 'AVAILABLE',
                last_sale_at TIMESTAMP, last_restock_at TIMESTAMP,
                version BIGINT DEFAULT 0, created_time TIMESTAMP, last_modified_time TIMESTAMP,
                created_by VARCHAR(255), last_modified_by VARCHAR(255), tenant VARCHAR(255),
                state_id VARCHAR(100), flow_id VARCHAR(100),
                state_entry_time TIMESTAMP, sla_yellow_date TIMESTAMP, sla_red_date TIMESTAMP,
                sla_tending_late INT DEFAULT 0, sla_late INT DEFAULT 0,
                test_entity BOOLEAN DEFAULT FALSE, description VARCHAR(255)
            )
        </sql>
    </changeSet>

    <!-- Product Reviews -->
    <changeSet id="ui-query-test-product-reviews" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="product_reviews"/></not></preConditions>
        <createTable tableName="product_reviews">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="customer_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="rating" type="INT"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="body" type="TEXT"/>
            <column name="images" type="TEXT"/>
            <column name="verified_purchase" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="helpful_count" type="INT" defaultValueNumeric="0"/>
