    <!--
        Test-only: creates all cross-module tables needed by ui-query BDD tests.
        Uses preConditions so safe to run alongside production changelogs.
    -->

    <!-- Products -->
    <changeSet id="ui-query-test-products" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="products"/></not></preConditions>
        <sql>
            CREATE TABLE products (
                id VARCHAR(255) NOT NULL PRIMARY KEY,
                name VARCHAR(255), description VARCHAR(2000), short_description VARCHAR(500),
                brand VARCHAR(255), category_id VARCHAR(255), slug VARCHAR(300),
                base_price NUMERIC(12,2), hsn_code VARCHAR(20),
                country_of_origin VARCHAR(100), weight_grams INT,
                warranty_months INT, is_returnable BOOLEAN DEFAULT TRUE,
                return_window_days INT DEFAULT 7,
                meta_title VARCHAR(200), meta_description VARCHAR(500),
                state_id VARCHAR(100), flow_id VARCHAR(100),
                version BIGINT DEFAULT 0, created_time TIMESTAMP, last_modified_time TIMESTAMP,
                created_by VARCHAR(255), last_modified_by VARCHAR(255), tenant VARCHAR(255),
                state_entry_time TIMESTAMP, sla_yellow_date TIMESTAMP, sla_red_date TIMESTAMP,
                sla_tending_late INT DEFAULT 0, sla_late INT DEFAULT 0, test_entity BOOLEAN DEFAULT FALSE
            )
        </sql>
    </changeSet>

