    </changeSet>

    <!-- Attribute Options -->
    <changeSet id="ui-query-test-attribute-options" author="homebase-test">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="attribute_options"/></not></preConditions>
        <createTable tableName="attribute_options">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="attribute_id" type="VARCHAR(255)"/>
