                total_amount DECIMAL(12,2) NOT NULL, currency VARCHAR(3) DEFAULT 'INR',
                shipping_address_id VARCHAR(255), billing_address_id VARCHAR(255),
                payment_method_id VARCHAR(255), notes TEXT, cancel_reason VARCHAR(1000),
                description VARCHAR(2000), item_count INT DEFAULT 0,
                shipping_address TEXT,
                state_id VARCHAR(255),
                state_id VARCHAR(100), flow_id VARCHAR(100),
                created_time TIMESTAMP, updated_time TIMESTAMP,
