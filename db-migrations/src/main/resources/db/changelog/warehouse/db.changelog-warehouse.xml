<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Warehouses — fulfillment center master data                        -->
    <!-- ================================================================== -->
    <changeSet id="warehouse-001-create-warehouses" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="warehouses"/></not>
        </preConditions>
        <createTable tableName="warehouses">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="warehouse_code" type="VARCHAR(20)"><constraints nullable="false" unique="true"/></column>
            <column name="warehouse_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="warehouse_type" type="VARCHAR(30)" defaultValue="FULFILLMENT_CENTER"/>
            <column name="address_line1" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="address_line2" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="state" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="pincode" type="VARCHAR(10)"><constraints nullable="false"/></column>
            <column name="country" type="VARCHAR(2)" defaultValue="IN"/>
            <column name="latitude" type="DECIMAL(10,7)"/>
            <column name="longitude" type="DECIMAL(10,7)"/>
            <column name="timezone" type="VARCHAR(50)" defaultValue="Asia/Kolkata"/>
            <column name="contact_phone" type="VARCHAR(20)"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="manager_id" type="VARCHAR(255)"/>
            <column name="max_capacity_units" type="INT"/>
            <column name="current_utilization_pct" type="DECIMAL(5,2)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="is_returns_center" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="operating_hours_json" type="TEXT"/>
            <column name="supported_carriers_json" type="TEXT"/>
        </createTable>
        <createIndex tableName="warehouses" indexName="idx_wh_pincode">
            <column name="pincode"/>
        </createIndex>
        <createIndex tableName="warehouses" indexName="idx_wh_active_type">
            <column name="is_active"/>
            <column name="warehouse_type"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Warehouse Locations — bin/shelf/aisle structure                    -->
    <!-- ================================================================== -->
    <changeSet id="warehouse-002-create-warehouse-locations" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="warehouse_locations"/></not>
        </preConditions>
        <createTable tableName="warehouse_locations">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="location_code" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="zone" type="VARCHAR(10)"/>
            <column name="aisle" type="VARCHAR(10)"/>
            <column name="shelf" type="VARCHAR(10)"/>
            <column name="bin" type="VARCHAR(10)"/>
            <column name="location_type" type="VARCHAR(30)" defaultValue="PICKABLE"/>
            <column name="capacity_units" type="INT"/>
            <column name="current_units" type="INT" defaultValueNumeric="0"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="warehouse_locations" baseColumnNames="warehouse_id"
            referencedTableName="warehouses" referencedColumnNames="id"
            constraintName="fk_wl_warehouse"/>
        <addUniqueConstraint tableName="warehouse_locations" columnNames="warehouse_id, location_code"
            constraintName="uq_wl_warehouse_location"/>
        <createIndex tableName="warehouse_locations" indexName="idx_wl_warehouse_type">
            <column name="warehouse_id"/>
            <column name="location_type"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Warehouse Inventory — real-time stock by location                  -->
    <!-- ================================================================== -->
    <changeSet id="warehouse-003-create-warehouse-inventory" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="warehouse_inventory"/></not>
        </preConditions>
        <createTable tableName="warehouse_inventory">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="location_id" type="VARCHAR(255)"/>
            <column name="product_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="quantity_on_hand" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_reserved" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_available" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_damaged" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_in_transit" type="INT" defaultValueNumeric="0"/>
            <column name="reorder_point" type="INT"/>
            <column name="reorder_quantity" type="INT"/>
            <column name="last_counted_at" type="TIMESTAMP"/>
            <column name="last_received_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="warehouse_inventory" baseColumnNames="warehouse_id"
            referencedTableName="warehouses" referencedColumnNames="id"
            constraintName="fk_wi_warehouse"/>
        <addUniqueConstraint tableName="warehouse_inventory" columnNames="warehouse_id, sku, location_id"
            constraintName="uq_wi_warehouse_sku_loc"/>
        <createIndex tableName="warehouse_inventory" indexName="idx_wi_sku">
            <column name="sku"/>
        </createIndex>
        <createIndex tableName="warehouse_inventory" indexName="idx_wi_warehouse_product">
            <column name="warehouse_id"/>
            <column name="product_id"/>
        </createIndex>
        <createIndex tableName="warehouse_inventory" indexName="idx_wi_low_stock">
            <column name="warehouse_id"/>
            <column name="quantity_available"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
