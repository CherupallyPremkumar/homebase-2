            <column name="location_type" value="BULK"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- Warehouse Staff -->
        <insert tableName="warehouse_staff">
            <column name="id" value="staff-1"/>
            <column name="warehouse_id" value="WH-CHENNAI"/>
            <column name="user_id" value="user-8"/>
            <column name="employee_code" value="CHN-EMP-001"/>
            <column name="role" value="PICKER"/>
            <column name="department" value="FULFILLMENT"/>
            <column name="shift_pattern" value="DAY"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="joined_at" valueDate="2025-06-01"/>
            <column name="tenant" value="homebase"/>
        </insert>

    </changeSet>

</databaseChangeLog>
