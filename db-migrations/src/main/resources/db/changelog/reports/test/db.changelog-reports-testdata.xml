    <!--
        Reports test data: report_definition, scheduled_report, report_history
        4 report definitions, 2 scheduled reports, 6 history entries
    -->
    <changeSet id="reports-test-data" author="homebase-test">

        <!-- ============================================================ -->
        <!-- REPORT DEFINITIONS — 4 standard reports                      -->
        <!-- ============================================================ -->

        <insert tableName="report_definition">
            <column name="id" value="rpt-def-001"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="admin"/>
            <column name="created_time" valueDate="2026-01-10T09:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-10T09:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="name" value="Daily Sales Summary"/>
            <column name="description" value="Aggregated daily sales including orders, revenue, units sold, discounts, and customer breakdown. Provides day-over-day comparison."/>
            <column name="category" value="SALES"/>
            <column name="query_template" value="SELECT summary_date, total_orders, total_revenue, total_units_sold, avg_order_value, new_customers, returning_customers FROM daily_sales_summary WHERE summary_date BETWEEN :start_date AND :end_date ORDER BY summary_date DESC"/>
            <column name="available_formats" value="PDF,CSV,Excel"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>

        <insert tableName="report_definition">
            <column name="id" value="rpt-def-002"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="admin"/>
            <column name="created_time" valueDate="2026-01-10T09:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-10T09:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="name" value="Monthly Revenue Report"/>
            <column name="description" value="Month-end revenue report with breakdown by category, payment method, and region. Includes tax collection summary and refund adjustments."/>
            <column name="category" value="SALES"/>
            <column name="query_template" value="SELECT DATE_TRUNC('month', created_time) AS month, SUM(total_amount) AS revenue, SUM(tax_amount) AS tax, COUNT(*) AS order_count FROM orders WHERE created_time BETWEEN :start_date AND :end_date GROUP BY month ORDER BY month DESC"/>
            <column name="available_formats" value="PDF,Excel"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>

        <insert tableName="report_definition">
            <column name="id" value="rpt-def-003"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="admin"/>
            <column name="created_time" valueDate="2026-01-15T11:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-15T11:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="name" value="Seller Performance Report"/>
            <column name="description" value="Per-seller metrics including order count, revenue, fulfillment speed, return rate, cancellation rate, and customer ratings. Used for seller tier evaluation."/>
            <column name="category" value="SELLER"/>
            <column name="query_template" value="SELECT supplier_id, total_orders, total_revenue, avg_fulfillment_days, avg_rating, cancellation_rate FROM supplier_performance WHERE period_year = :year AND period_month = :month"/>
            <column name="available_formats" value="PDF,CSV,Excel"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>

        <insert tableName="report_definition">
            <column name="id" value="rpt-def-004"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="admin"/>
            <column name="created_time" valueDate="2026-01-20T14:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-20T14:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="name" value="Inventory Turnover Report"/>
            <column name="description" value="Warehouse-level inventory turnover analysis showing stock movement velocity, dead stock identification, and reorder recommendations."/>
            <column name="category" value="OPERATIONS"/>
            <column name="query_template" value="SELECT w.warehouse_name, i.product_id, i.quantity_on_hand, i.quantity_reserved, i.reorder_point FROM inventory_item i JOIN warehouses w ON i.warehouse_id = w.id WHERE i.quantity_on_hand > 0 ORDER BY i.quantity_on_hand DESC"/>
            <column name="available_formats" value="CSV,Excel"/>
            <column name="is_active" valueBoolean="true"/>
        </insert>

