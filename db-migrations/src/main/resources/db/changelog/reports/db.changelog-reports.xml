<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Reports — report definitions, scheduling, and execution history    -->
    <!-- Infrastructure module (no STM — reports have no state transitions) -->
    <!-- ================================================================== -->

    <!-- report_definition (ReportDefinitionEntity extends BaseJpaEntity) -->
    <changeSet id="reports-001-create-report-definition" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="report_definition"/></not>
        </preConditions>
        <createTable tableName="report_definition">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="description" type="TEXT"/>
            <column name="category" type="VARCHAR(50)"/>
            <column name="query_template" type="TEXT"/>
            <column name="available_formats" type="VARCHAR(100)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_report_def_category" tableName="report_definition">
            <column name="category"/>
        </createIndex>
        <createIndex indexName="idx_report_def_active" tableName="report_definition">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- scheduled_report (ScheduledReportEntity extends BaseJpaEntity) -->
    <changeSet id="reports-002-create-scheduled-report" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="scheduled_report"/></not>
        </preConditions>
        <createTable tableName="scheduled_report">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="report_definition_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="format" type="VARCHAR(10)"/>
            <column name="frequency" type="VARCHAR(20)"/>
            <column name="cron_expression" type="VARCHAR(100)"/>
            <column name="next_run_at" type="TIMESTAMP"/>
            <column name="recipient_email" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>
            <column name="last_run_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="scheduled_report" baseColumnNames="report_definition_id"
            referencedTableName="report_definition" referencedColumnNames="id"
            constraintName="fk_sched_report_def"/>
        <createIndex indexName="idx_sched_report_def_id" tableName="scheduled_report">
            <column name="report_definition_id"/>
        </createIndex>
        <createIndex indexName="idx_sched_report_status" tableName="scheduled_report">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_sched_report_next_run" tableName="scheduled_report">
            <column name="next_run_at"/>
        </createIndex>
    </changeSet>

    <!-- report_history (ReportHistoryEntity extends BaseJpaEntity) -->
    <changeSet id="reports-003-create-report-history" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="report_history"/></not>
        </preConditions>
        <createTable tableName="report_history">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="report_definition_id" type="VARCHAR(255)"/>
            <column name="scheduled_report_id" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="format" type="VARCHAR(10)"/>
            <column name="generated_by" type="VARCHAR(255)"/>
            <column name="file_url" type="VARCHAR(1000)"/>
            <column name="file_size_bytes" type="BIGINT"/>
            <column name="record_count" type="INT"/>
            <column name="status" type="VARCHAR(20)"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="error_message" type="VARCHAR(2000)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="report_history" baseColumnNames="report_definition_id"
            referencedTableName="report_definition" referencedColumnNames="id"
            constraintName="fk_report_hist_def"/>
        <addForeignKeyConstraint baseTableName="report_history" baseColumnNames="scheduled_report_id"
            referencedTableName="scheduled_report" referencedColumnNames="id"
            constraintName="fk_report_hist_sched"/>
        <createIndex indexName="idx_report_hist_def_id" tableName="report_history">
            <column name="report_definition_id"/>
        </createIndex>
        <createIndex indexName="idx_report_hist_sched_id" tableName="report_history">
            <column name="scheduled_report_id"/>
        </createIndex>
        <createIndex indexName="idx_report_hist_status" tableName="report_history">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_report_hist_generated_by" tableName="report_history">
            <column name="generated_by"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
