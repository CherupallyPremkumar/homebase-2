<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        V63: Catalog production schema alignment.
        Adds missing columns to categories and collections tables
        to match JPA entities (CategoryEntity, CollectionEntity, CategoryMetadataEntity).
    -->
    <changeSet id="V63__catalog_production_schema" author="homebase" runOnChange="false">

        <!-- ================================================================ -->
        <!-- categories: add level, icon, featured, product_count, metadata   -->
        <!-- ================================================================ -->
        <addColumn tableName="catalog_categories">
            <column name="level" type="INT" defaultValueNumeric="0"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="icon" type="VARCHAR(100)"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="featured" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="product_count" type="BIGINT" defaultValueNumeric="0"/>
        </addColumn>
        <!-- CategoryMetadataEntity (embedded) -->
        <addColumn tableName="catalog_categories">
            <column name="meta_title" type="VARCHAR(100)"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="meta_description" type="VARCHAR(200)"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="meta_keywords" type="VARCHAR(200)"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="banner_image_url" type="VARCHAR(500)"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="show_in_menu" type="BOOLEAN" defaultValueBoolean="true"/>
        </addColumn>
        <addColumn tableName="catalog_categories">
            <column name="show_in_footer" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>

        <!-- ================================================================ -->
        <!-- collections: add type, dates, featured, auto_update, rules, count -->
        <!-- ================================================================ -->
        <addColumn tableName="collections">
            <column name="type" type="VARCHAR(20)" defaultValue="CURATED">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="collections">
            <column name="start_date" type="TIMESTAMP"/>
        </addColumn>
        <addColumn tableName="collections">
            <column name="end_date" type="TIMESTAMP"/>
        </addColumn>
        <addColumn tableName="collections">
            <column name="featured" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
        <addColumn tableName="collections">
            <column name="auto_update" type="BOOLEAN" defaultValueBoolean="false"/>
        </addColumn>
        <addColumn tableName="collections">
            <column name="rule_expression" type="VARCHAR(1000)"/>
        </addColumn>
        <addColumn tableName="collections">
            <column name="product_count" type="BIGINT" defaultValueNumeric="0"/>
        </addColumn>

        <!-- ================================================================ -->
        <!-- Indexes for new columns                                          -->
        <!-- ================================================================ -->
        <createIndex indexName="idx_catalog_categories_featured" tableName="catalog_categories">
            <column name="featured"/>
        </createIndex>
        <createIndex indexName="idx_catalog_categories_level" tableName="catalog_categories">
            <column name="level"/>
        </createIndex>
        <createIndex indexName="idx_catalog_categories_show_in_menu" tableName="catalog_categories">
            <column name="show_in_menu"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_collections_type" tableName="collections">
            <column name="type"/>
        </createIndex>
        <createIndex indexName="idx_collections_featured" tableName="collections">
            <column name="featured"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_collections_auto_update" tableName="collections">
            <column name="auto_update"/>
        </createIndex>

        <!-- Set level for existing root categories (parent_id IS NULL) -->
        <sql>UPDATE catalog_categories SET level = 0 WHERE parent_id IS NULL</sql>

    </changeSet>

    <!--
        V64: Catalog items — add description, projection fields, and PostgreSQL full-text search.
    -->
    <changeSet id="V64__catalog_items_fts_and_projection" author="homebase" runOnChange="false">

        <!-- ================================================================ -->
        <!-- catalog_items: add description + projection fields               -->
        <!-- ================================================================ -->
        <addColumn tableName="catalog_items">
            <column name="description" type="VARCHAR(2000)"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="brand" type="VARCHAR(255)"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="image_url" type="VARCHAR(500)"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="in_stock" type="BOOLEAN" defaultValueBoolean="true"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="available_qty" type="INT" defaultValueNumeric="0"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="average_rating" type="NUMERIC(3,2)" defaultValueNumeric="0"/>
        </addColumn>
        <addColumn tableName="catalog_items">
            <column name="review_count" type="INT" defaultValueNumeric="0"/>
        </addColumn>

    </changeSet>

    <!--
        V64b: PostgreSQL full-text search (tsvector + GIN index + trigger).
        Uses dbms="postgresql" — skipped on H2 tests.
    -->
    <changeSet id="V64b__catalog_items_fts_postgresql" author="homebase" runOnChange="false" dbms="postgresql">

        <!-- search_vector column -->
        <sql>ALTER TABLE catalog_items ADD COLUMN search_vector tsvector</sql>

        <!-- Populate from existing data -->
        <sql>
            UPDATE catalog_items SET search_vector =
                to_tsvector('english',
                    COALESCE(name, '') || ' ' ||
                    COALESCE(description, '') || ' ' ||
                    COALESCE(brand, '')
                )
        </sql>

        <!-- GIN index for fast FTS -->
        <sql>CREATE INDEX idx_catalog_items_fts ON catalog_items USING GIN(search_vector)</sql>

        <!-- Auto-update trigger: keeps search_vector in sync on INSERT/UPDATE -->
        <sql>
            CREATE OR REPLACE FUNCTION catalog_items_search_trigger() RETURNS trigger AS $$
            BEGIN
                NEW.search_vector :=
                    to_tsvector('english',
                        COALESCE(NEW.name, '') || ' ' ||
                        COALESCE(NEW.description, '') || ' ' ||
                        COALESCE(NEW.brand, '')
                    );
                RETURN NEW;
            END
            $$ LANGUAGE plpgsql;

            CREATE TRIGGER trg_catalog_items_search
            BEFORE INSERT OR UPDATE OF name, description, brand
            ON catalog_items
            FOR EACH ROW EXECUTE FUNCTION catalog_items_search_trigger();
        </sql>

        <!-- pg_trgm extension for fuzzy/typo matching -->
        <sql>CREATE EXTENSION IF NOT EXISTS pg_trgm</sql>
        <sql>CREATE INDEX idx_catalog_items_name_trgm ON catalog_items USING GIN(name gin_trgm_ops)</sql>

    </changeSet>

</databaseChangeLog>
