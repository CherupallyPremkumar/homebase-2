<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- catalog_items (CatalogItemEntity extends BaseJpaEntity) -->
    <changeSet id="catalog-001-create-catalog-items" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="catalog_items"/></not>
        </preConditions>
        <createTable tableName="catalog_items">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="product_id" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="featured" type="BOOLEAN"/>
            <column name="display_order" type="INT"/>
            <column name="active" type="BOOLEAN"/>
            <column name="visibility_start_date" type="TIMESTAMP"/>
            <column name="visibility_end_date" type="TIMESTAMP"/>
            <column name="name" type="VARCHAR(255)"/>
            <column name="price" type="DECIMAL(19,2)"/>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="brand" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="in_stock" type="BOOLEAN"/>
            <column name="available_qty" type="INT"/>
            <column name="average_rating" type="DECIMAL(3,2)"/>
            <column name="review_count" type="INT"/>
        </createTable>
        <createIndex indexName="idx_catalog_items_product" tableName="catalog_items">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <!-- catalog_item_tags (@ElementCollection on CatalogItemEntity) -->
    <changeSet id="catalog-002-create-catalog-item-tags" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="catalog_item_tags"/></not>
        </preConditions>
        <createTable tableName="catalog_item_tags">
            <column name="catalog_item_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="tag" type="VARCHAR(255)"/>
        </createTable>
        <createIndex indexName="idx_catalog_item_tags_item" tableName="catalog_item_tags">
            <column name="catalog_item_id"/>
        </createIndex>
    </changeSet>

    <!-- catalog_categories (CategoryEntity extends BaseJpaEntity, @Embedded CategoryMetadataEntity) -->
    <changeSet id="catalog-003-create-catalog-categories" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="catalog_categories"/></not>
        </preConditions>
        <createTable tableName="catalog_categories">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="parent_id" type="VARCHAR(50)"/>
            <column name="level" type="INT"/>
            <column name="display_order" type="INT"/>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="icon" type="VARCHAR(100)"/>
            <column name="active" type="BOOLEAN"/>
            <column name="featured" type="BOOLEAN"/>
            <column name="product_count" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <!-- Embedded CategoryMetadataEntity -->
            <column name="meta_title" type="VARCHAR(100)"/>
            <column name="meta_description" type="VARCHAR(200)"/>
            <column name="meta_keywords" type="VARCHAR(200)"/>
            <column name="banner_image_url" type="VARCHAR(500)"/>
            <column name="show_in_menu" type="BOOLEAN"/>
            <column name="show_in_footer" type="BOOLEAN"/>
        </createTable>
        <addUniqueConstraint tableName="catalog_categories" columnNames="slug" constraintName="uk_catalog_categories_slug"/>
    </changeSet>

    <!-- category_product_mapping (CategoryProductMappingEntity extends BaseJpaEntity) -->
    <changeSet id="catalog-004-create-category-product-mapping" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="category_product_mapping"/></not>
        </preConditions>
        <createTable tableName="category_product_mapping">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="category_id" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="product_id" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="display_order" type="INT"/>
            <column name="added_by" type="VARCHAR(50)"/>
        </createTable>
        <createIndex indexName="idx_cat_prod_mapping_cat" tableName="category_product_mapping">
            <column name="category_id"/>
        </createIndex>
        <createIndex indexName="idx_cat_prod_mapping_prod" tableName="category_product_mapping">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <!-- collections (CollectionEntity extends BaseJpaEntity) -->
    <changeSet id="catalog-005-create-collections" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="collections"/></not>
        </preConditions>
        <createTable tableName="collections">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="name" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="type" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="start_date" type="TIMESTAMP"/>
            <column name="end_date" type="TIMESTAMP"/>
            <column name="active" type="BOOLEAN"/>
            <column name="featured" type="BOOLEAN"/>
            <column name="display_order" type="INT"/>
            <column name="auto_update" type="BOOLEAN"/>
            <column name="rule_expression" type="VARCHAR(1000)"/>
            <column name="product_count" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="collections" columnNames="slug" constraintName="uk_collections_slug"/>
    </changeSet>

    <!-- collection_product_mapping (CollectionProductMappingEntity extends BaseJpaEntity) -->
    <changeSet id="catalog-006-create-collection-product-mapping" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="collection_product_mapping"/></not>
        </preConditions>
        <createTable tableName="collection_product_mapping">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="collection_id" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="product_id" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="display_order" type="INT"/>
            <column name="added_by" type="VARCHAR(50)"/>
        </createTable>
        <createIndex indexName="idx_coll_prod_mapping_coll" tableName="collection_product_mapping">
            <column name="collection_id"/>
        </createIndex>
        <createIndex indexName="idx_coll_prod_mapping_prod" tableName="collection_product_mapping">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <!-- Add Amazon-standard columns to catalog_items -->
    <changeSet id="catalog-007-add-catalog-item-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="catalog_items"/>
            <not><columnExists tableName="catalog_items" columnName="variant_id"/></not>
        </preConditions>
        <addColumn tableName="catalog_items">
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="supplier_id" type="VARCHAR(255)"/>
            <column name="offer_price" type="DECIMAL(12,2)"/>
            <column name="mrp" type="DECIMAL(12,2)"/>
            <column name="discount_percent" type="DECIMAL(5,2)"/>
            <column name="category_id" type="VARCHAR(255)"/>
            <column name="hsn_code" type="VARCHAR(20)"/>
            <column name="weight_grams" type="INT"/>
            <column name="country_of_origin" type="VARCHAR(100)"/>
            <column name="is_returnable" type="BOOLEAN" defaultValueBoolean="true"/>
        </addColumn>
    </changeSet>

    <!-- Indexes on catalog_items -->
    <changeSet id="catalog-008-add-catalog-item-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="catalog_items"/>
            <not><indexExists indexName="idx_catalog_items_category"/></not>
        </preConditions>
        <createIndex indexName="idx_catalog_items_category" tableName="catalog_items">
            <column name="category_id"/>
        </createIndex>
        <createIndex indexName="idx_catalog_items_brand" tableName="catalog_items">
            <column name="brand"/>
        </createIndex>
        <createIndex indexName="idx_catalog_items_active" tableName="catalog_items">
            <column name="active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
