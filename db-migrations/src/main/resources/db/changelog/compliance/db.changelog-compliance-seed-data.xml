    <!--
        Compliance seed data — production regulations, agreements, policies:
        - 6 regulations (Indian ecommerce laws)
        - 5 agreements (STM states: PUBLISHED, DRAFT, LEGAL_REVIEW, SUPERSEDED)
        - 4 acceptances (supplier + customer signed agreements)
        - 6 platform policies (STM states: PUBLISHED, DRAFT, SUPERSEDED)
        - 5 compliance mappings (regulation → rule → policy traceability)
        - 2 compliance audits
    -->
    <changeSet id="compliance-013-seed-data" author="homebase">

        <!-- ============================================================ -->
        <!-- REGULATIONS — Indian ecommerce laws                          -->
        <!-- ============================================================ -->

        <!-- Consumer Protection Act 2019 -->
        <insert tableName="regulations">
            <column name="id" value="reg-cpa-2019"/>
            <column name="act_name" value="Consumer Protection Act, 2019"/>
            <column name="section" value="Section 44 — Liability of e-commerce entities"/>
            <column name="requirement_summary" value="E-commerce entities must ensure no unfair trade practices, allow cancellation and returns within reasonable time, display total price including all charges, and provide grievance redressal mechanism."/>
            <column name="full_text_url" value="https://legislative.gov.in/sites/default/files/A2019-35.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
            <column name="applicable_to" value="MARKETPLACE"/>
            <column name="enforcement_date" valueDate="2020-07-20"/>
            <column name="category" value="CONSUMER_RIGHTS"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- Consumer Protection (E-Commerce) Rules 2020 -->
        <insert tableName="regulations">
            <column name="id" value="reg-ecom-rules-2020"/>
            <column name="act_name" value="Consumer Protection (E-Commerce) Rules, 2020"/>
            <column name="section" value="Rule 4 — Duties of e-commerce entity"/>
            <column name="requirement_summary" value="Must display seller details, country of origin, return/refund/exchange policy, grievance officer contact, delivery/shipment date, security of payment methods, and total price breakdown."/>
            <column name="full_text_url" value="https://consumeraffairs.nic.in/sites/default/files/E-Commerce-Rules.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
            <column name="applicable_to" value="MARKETPLACE"/>
            <column name="enforcement_date" valueDate="2020-07-23"/>
            <column name="category" value="CONSUMER_RIGHTS"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- GST Act -->
        <insert tableName="regulations">
            <column name="id" value="reg-gst-2017"/>
            <column name="act_name" value="Central Goods and Services Tax Act, 2017"/>
            <column name="section" value="Section 52 — TCS by e-commerce operator"/>
            <column name="requirement_summary" value="E-commerce operator must collect TCS at 1% (0.5% CGST + 0.5% SGST) on net value of taxable supplies made through it. Must file GSTR-8 monthly."/>
            <column name="full_text_url" value="https://www.cbic.gov.in/resources/htdocs-cbec/gst/cgst-act.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
            <column name="applicable_to" value="MARKETPLACE"/>
            <column name="enforcement_date" valueDate="2018-10-01"/>
            <column name="category" value="TAXATION"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- IT Act 2000 -->
        <insert tableName="regulations">
            <column name="id" value="reg-it-act-2000"/>
            <column name="act_name" value="Information Technology Act, 2000"/>
            <column name="section" value="Section 43A — Compensation for failure to protect data"/>
            <column name="requirement_summary" value="Body corporate possessing sensitive personal data must implement reasonable security practices. Failure to protect data makes them liable for compensation."/>
            <column name="full_text_url" value="https://www.meity.gov.in/writereaddata/files/itbill2000.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
            <column name="applicable_to" value="ALL"/>
            <column name="enforcement_date" valueDate="2009-10-27"/>
            <column name="category" value="DATA_PRIVACY"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- Digital Personal Data Protection Act 2023 -->
        <insert tableName="regulations">
            <column name="id" value="reg-dpdp-2023"/>
            <column name="act_name" value="Digital Personal Data Protection Act, 2023"/>
            <column name="section" value="Section 6 — Consent for processing personal data"/>
            <column name="requirement_summary" value="Personal data may be processed only with consent of the Data Principal. Consent must be free, specific, informed, unconditional, and unambiguous. Must provide notice before consent."/>
            <column name="full_text_url" value="https://www.meity.gov.in/writereaddata/files/Digital%20Personal%20Data%20Protection%20Act%202023.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
            <column name="applicable_to" value="ALL"/>
            <column name="enforcement_date" valueDate="2024-01-01"/>
            <column name="category" value="DATA_PRIVACY"/>
            <column name="is_active" valueBoolean="true"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- FDI Policy for E-Commerce -->
        <insert tableName="regulations">
            <column name="id" value="reg-fdi-ecom"/>
            <column name="act_name" value="Press Note 2 of 2018 — FDI Policy for E-Commerce"/>
            <column name="section" value="Marketplace model conditions"/>
            <column name="requirement_summary" value="Marketplace must not exercise ownership over inventory. No single vendor can contribute more than 25% of sales. Platform cannot influence pricing. Must provide equal treatment to all sellers."/>
            <column name="full_text_url" value="https://dpiit.gov.in/sites/default/files/pn2_2018.pdf"/>
            <column name="jurisdiction" value="INDIA"/>
