<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- V17: Create shipments table                                        -->
    <!-- ================================================================== -->
    <changeSet id="V17__create_shipments_table" author="homebase" runOnChange="false">
        <createTable tableName="shipments">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_shipment_order" referencedTableName="orders" referencedColumnNames="id"/>
            </column>
            <column name="carrier" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tracking_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="tracking_url" type="VARCHAR(512)"/>
            <column name="shipped_at" type="TIMESTAMP"/>
            <column name="estimated_delivery" type="TIMESTAMP"/>
            <column name="status" type="VARCHAR(30)" defaultValue="SHIPPED"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_shipment_order" tableName="shipments">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- V50: Shipping production readiness                                 -->
    <!-- ================================================================== -->
    <changeSet id="V50__shipping_production_readiness" author="homebase" runOnChange="false">
        <!-- Add new columns -->
        <addColumn tableName="shipments">
            <column name="customer_id" type="VARCHAR(36)"/>
            <column name="shipping_method" type="VARCHAR(20)" defaultValue="STANDARD"/>
            <column name="from_address" type="JSONB"/>
            <column name="to_address" type="JSONB"/>
            <column name="weight" type="VARCHAR(20)"/>
            <column name="dimensions" type="VARCHAR(50)"/>
            <column name="delivery_attempts" type="INT" defaultValueNumeric="0"/>
            <column name="delivery_instructions" type="TEXT"/>
            <column name="current_location" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="estimated_delivery_date" type="TIMESTAMP"/>
            <column name="actual_delivery_date" type="TIMESTAMP"/>
            <column name="state_id" type="VARCHAR(50)"/>
            <column name="flow_id" type="VARCHAR(50)"/>
        </addColumn>

        <!-- Make tracking_number nullable -->
        <dropNotNullConstraint tableName="shipments" columnName="tracking_number" columnDataType="VARCHAR(255)"/>

        <!-- Change carrier default -->
        <addDefaultValue tableName="shipments" columnName="carrier" defaultValue="HOMEBASE-LOGISTICS"/>

        <!-- Indexes for common queries -->
        <createIndex indexName="idx_shipment_customer" tableName="shipments">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_shipment_state" tableName="shipments">
            <column name="state_id"/>
        </createIndex>
        <createIndex indexName="idx_shipment_carrier" tableName="shipments">
            <column name="carrier"/>
        </createIndex>
        <createIndex indexName="idx_shipment_tracking" tableName="shipments">
            <column name="tracking_number"/>
        </createIndex>
        <createIndex indexName="idx_shipment_method" tableName="shipments">
            <column name="shipping_method"/>
        </createIndex>

        <!-- Shipping activity log table -->
        <createTable tableName="shipping_activity">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="shipping_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_shipping_activity_shipment" referencedTableName="shipments" referencedColumnNames="id"/>
            </column>
            <column name="activity_name" type="VARCHAR(100)"/>
            <column name="activity_comment" type="TEXT"/>
            <column name="activity_success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_shipping_activity_shipment" tableName="shipping_activity">
            <column name="shipping_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
