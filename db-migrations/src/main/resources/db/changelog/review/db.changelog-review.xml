<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="review-001-create-product-reviews" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="product_reviews"/></not></preConditions>
        <createTable tableName="product_reviews">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="product_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="customer_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="rating" type="INT"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="body" type="TEXT"/>
            <column name="images" type="TEXT"/>
            <column name="verified_purchase" type="BOOLEAN"/>
            <column name="helpful_count" type="INT"/>
            <column name="report_count" type="INT"/>
            <column name="moderator_notes" type="TEXT"/>
        </createTable>
    </changeSet>

    <changeSet id="review-002-create-review-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="review_activity"/></not></preConditions>
        <createTable tableName="review_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="review_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!-- Add columns to product_reviews -->
    <changeSet id="review-003-add-review-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="product_reviews"/>
            <not><columnExists tableName="product_reviews" columnName="variant_id"/></not>
        </preConditions>
        <addColumn tableName="product_reviews">
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="review_source" type="VARCHAR(50)" defaultValue="WEB"/>
        </addColumn>
    </changeSet>

    <!-- review_images (BaseJpaEntity) -->
    <changeSet id="review-004-create-review-images" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="review_images"/></not>
        </preConditions>
        <createTable tableName="review_images">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="review_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="image_url" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="thumbnail_url" type="VARCHAR(500)"/>
            <column name="sort_order" type="INT" defaultValueNumeric="0"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="review_images" baseColumnNames="review_id"
                                 referencedTableName="product_reviews" referencedColumnNames="id"
                                 constraintName="fk_review_images_review"/>
        <createIndex indexName="idx_review_images_review" tableName="review_images">
            <column name="review_id"/>
        </createIndex>
    </changeSet>

    <!-- review_votes (BaseJpaEntity) -->
    <changeSet id="review-005-create-review-votes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="review_votes"/></not>
        </preConditions>
        <createTable tableName="review_votes">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="review_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="user_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="vote_type" type="VARCHAR(20)"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="review_votes" columnNames="review_id, user_id"
                             constraintName="uk_review_votes_review_user"/>
        <createIndex indexName="idx_review_votes_review" tableName="review_votes">
            <column name="review_id"/>
        </createIndex>
    </changeSet>

    <!-- Indexes on product_reviews -->
    <changeSet id="review-006-add-review-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="product_reviews"/>
            <not><indexExists indexName="idx_product_reviews_product"/></not>
        </preConditions>
        <createIndex indexName="idx_product_reviews_product" tableName="product_reviews">
            <column name="product_id"/>
        </createIndex>
        <createIndex indexName="idx_product_reviews_customer" tableName="product_reviews">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_product_reviews_state" tableName="product_reviews">
            <column name="state_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
