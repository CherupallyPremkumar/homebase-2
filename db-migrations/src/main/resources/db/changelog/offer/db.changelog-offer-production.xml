<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- V61: Offers production-grade — variant-level pricing, STM, supplier -->
    <!-- ================================================================== -->
    <changeSet id="V61__offers_production_readiness" author="homebase" runOnChange="false">
        <!-- 1. Add variant_id (offers are per-variant, not per-product) -->
        <addColumn tableName="offers">
            <column name="variant_id" type="VARCHAR(255)"/>
        </addColumn>

        <!-- 2. Rename price → selling_price, add mrp + discount -->
        <renameColumn tableName="offers" oldColumnName="price" newColumnName="selling_price"
                      columnDataType="NUMERIC(10,2)"/>
        <addColumn tableName="offers">
            <column name="mrp" type="NUMERIC(10,2)"/>
            <column name="discount_percent" type="NUMERIC(5,2)" defaultValueNumeric="0"/>
            <column name="currency" type="VARCHAR(3)" defaultValue="INR"/>
        </addColumn>

        <!-- 3. Rename seller_id → supplier_id (Amazon standard) -->
        <renameColumn tableName="offers" oldColumnName="seller_id" newColumnName="supplier_id"
                      columnDataType="VARCHAR(36)"/>

        <!-- 4. Add STM columns (Chenile state machine) -->
        <addColumn tableName="offers">
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flowId" type="VARCHAR(100)"/>
            <column name="stateId" type="VARCHAR(100)"/>
        </addColumn>

        <!-- 5. Migrate existing boolean active → stateId -->
        <sql>UPDATE offers SET "stateId" = CASE WHEN active = true THEN 'ACTIVE' ELSE 'INACTIVE' END</sql>

        <!-- 6. Add buy-box fields -->
        <addColumn tableName="offers">
            <column name="buy_box_winner" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="fulfillment_type" type="VARCHAR(20)" defaultValue="MERCHANT"/>
            <column name="shipping_cost" type="NUMERIC(10,2)" defaultValueNumeric="0"/>
            <column name="delivery_days" type="INT"/>
        </addColumn>

        <!-- 7. Indexes -->
        <createIndex indexName="idx_offers_variant_id" tableName="offers">
            <column name="variant_id"/>
        </createIndex>
        <createIndex indexName="idx_offers_state" tableName="offers">
            <column name="stateId"/>
        </createIndex>
        <createIndex indexName="idx_offers_supplier" tableName="offers">
            <column name="supplier_id"/>
        </createIndex>
        <createIndex indexName="idx_offers_buy_box" tableName="offers">
            <column name="buy_box_winner"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
