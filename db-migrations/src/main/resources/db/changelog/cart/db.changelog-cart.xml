<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ============================================================ -->
    <!-- CART TABLE                                                    -->
    <!-- ============================================================ -->
    <changeSet id="create-cart-table" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="cart"/></not>
        </preConditions>
        <createTable tableName="cart">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="VARCHAR(36)"/>
            <column name="session_id" type="VARCHAR(100)"/>
            <column name="subtotal" type="BIGINT" defaultValueNumeric="0"/>
            <column name="currency" type="VARCHAR(3)" defaultValue="INR"/>
            <column name="coupon_codes" type="VARCHAR(500)"/>
            <column name="discount_amount" type="BIGINT" defaultValueNumeric="0"/>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="description" type="VARCHAR(1000)"/>
            <!-- BaseJpaEntity columns -->
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
            <!-- AbstractJpaStateEntity columns -->
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flowId" type="VARCHAR(100)"/>
            <column name="stateId" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <changeSet id="idx-cart-customer" author="homebase">
        <createIndex indexName="idx_cart_customer_id" tableName="cart">
            <column name="customer_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="idx-cart-state" author="homebase">
        <createIndex indexName="idx_cart_state_id" tableName="cart">
            <column name="stateId"/>
        </createIndex>
    </changeSet>

    <changeSet id="idx-cart-expires-at" author="homebase">
        <createIndex indexName="idx_cart_expires_at" tableName="cart">
            <column name="expires_at"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================ -->
    <!-- CART ITEM TABLE                                               -->
    <!-- ============================================================ -->
    <changeSet id="create-cart-item-table" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="cart_item"/></not>
        </preConditions>
        <createTable tableName="cart_item">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cart_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_cart_item_cart"
                             references="cart(id)"/>
            </column>
            <column name="product_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="variant_id" type="VARCHAR(36)"/>
            <column name="sku" type="VARCHAR(100)"/>
            <column name="product_name" type="VARCHAR(500)"/>
            <column name="quantity" type="INT" defaultValueNumeric="1"/>
            <column name="unit_price" type="BIGINT"/>
            <!-- BaseJpaEntity columns -->
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

    <changeSet id="idx-cart-item-cart" author="homebase">
        <createIndex indexName="idx_cart_item_cart_id" tableName="cart_item">
            <column name="cart_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="idx-cart-item-product" author="homebase">
        <createIndex indexName="idx_cart_item_product_id" tableName="cart_item">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================ -->
    <!-- CART ACTIVITY LOG TABLE                                       -->
    <!-- ============================================================ -->
    <changeSet id="create-cart-activity-log-table" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="cart_activity_log"/></not>
        </preConditions>
        <createTable tableName="cart_activity_log">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cart_id" type="VARCHAR(36)">
                <constraints nullable="false"
                             foreignKeyName="fk_cart_activity_cart"
                             references="cart(id)"/>
            </column>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="TEXT"/>
            <!-- BaseJpaEntity columns -->
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

    <!-- ============================================================ -->
    <!-- PHASE 1: Add total, notes, supplier_id, line_total           -->
    <!-- ============================================================ -->
    <changeSet id="add-cart-total-notes" author="homebase">
        <addColumn tableName="cart">
            <column name="total" type="BIGINT" defaultValueNumeric="0"/>
            <column name="notes" type="VARCHAR(1000)"/>
        </addColumn>
    </changeSet>

    <changeSet id="add-cart-item-supplier-linetotal" author="homebase">
        <addColumn tableName="cart_item">
            <column name="supplier_id" type="VARCHAR(36)"/>
            <column name="line_total" type="BIGINT" defaultValueNumeric="0"/>
        </addColumn>
    </changeSet>

    <changeSet id="idx-cart-session" author="homebase">
        <createIndex indexName="idx_cart_session_id" tableName="cart">
            <column name="session_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
