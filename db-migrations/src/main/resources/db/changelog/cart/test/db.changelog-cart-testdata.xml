    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        All money values are in PAISE (smallest currency unit for INR).
        e.g., 150000 = Rs.1500.00, 49900 = Rs.499.00
        Currency field determines the divisor (INR=100, USD=100, JPY=1).
    -->
    <changeSet id="cart-test-data" author="homebase">

        <!-- ACTIVE carts (user shopping) -->
        <!-- cart-1: 2 items => Widget A (2 x 50000) + Gadget B (1 x 49900) = 149900 paise = Rs.1499.00 -->
        <insert tableName="cart">
            <column name="id" value="cart-1"/>
            <column name="customer_id" value="user-1"/>
            <column name="state_id" value="ACTIVE"/>
            <column name="flow_id" value="cart-flow"/>
            <column name="subtotal" valueNumeric="149900"/>
            <column name="currency" value="INR"/>
            <column name="created_time" valueDate="2026-01-10T10:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-15T10:00:00"/>
            <column name="tenant" value="homebase"/>
        </insert>
