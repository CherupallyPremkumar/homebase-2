<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Rules Engine test data — production-grade business rules
        STM states: DRAFT, PUBLISHED, DEPRECATED, ARCHIVED

        3-layer model:
          cconfig  = simple defaults (cart.max.items = 10)
          rules    = conditional logic (IF price > 10000 THEN max_qty = 2)
          policy   = legal text backing (Consumer Protection Act 2019)

        Policies cover:
          1. Cart quantity limits (price-based)
          2. Return eligibility (category + time + condition)
          3. Fraud detection (order value + velocity + new customer)
          4. Seller commission (performance-based dynamic rates)
          5. Shipping eligibility (pincode + weight + hazmat)
          6. Promo validation (stacking, min order, category exclusion)
          7. Supplier performance (auto-probation triggers)
          8. Product listing (quality gates for publishing)
    -->
    <changeSet id="rules-engine-production-data" author="homebase-test">

        <!-- ============================================================ -->
        <!-- POLICY 1: Cart Quantity Limits — PUBLISHED                    -->
        <!-- Backs cconfig defaults with price-based overrides             -->
        <!-- ============================================================ -->
        <insert tableName="policy">
            <column name="id" value="policy-cart-limits"/>
            <column name="name" value="Cart Quantity Limit Policy"/>
            <column name="description" value="Dynamic cart quantity limits based on product price tiers. Overrides cconfig defaults when conditions match."/>
            <column name="default_effect" value="ALLOW"/>
            <column name="active" valueBoolean="true"/>
            <column name="target_module" value="cart"/>
            <column name="state_id" value="ACTIVE"/>
            <column name="flow_id" value="ruleSet-flow"/>
            <column name="created_time" valueDate="2025-06-01T10:00:00"/>
            <column name="last_modified_time" valueDate="2026-01-15T10:00:00"/>
            <column name="tenant" value="homebase"/>
            <column name="version" valueNumeric="4"/>
        </insert>

        <!-- High-value items (>10000): max 2 per cart -->
        <insert tableName="policy_rule">
            <column name="id" value="rule-cart-high-value-limit"/>
            <column name="name" value="High-Value Item Quantity Limit"/>
            <column name="expression" value="product.price > 10000 and requestedQuantity > 2"/>
            <column name="effect" value="DENY"/>
            <column name="priority" valueNumeric="100"/>
            <column name="policy_id" value="policy-cart-limits"/>
            <column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="policy_rule_metadata">
            <column name="rule_id" value="rule-cart-high-value-limit"/>
            <column name="meta_key" value="userMessage"/>
            <column name="meta_value" value="Items above Rs.10,000 are limited to 2 per order"/>
        </insert>

        <!-- Mid-range items (1000-10000): max 5 per cart -->
        <insert tableName="policy_rule">
            <column name="id" value="rule-cart-mid-value-limit"/>
            <column name="name" value="Mid-Range Item Quantity Limit"/>
            <column name="expression" value="product.price >= 1000 and product.price &lt;= 10000 and requestedQuantity > 5"/>
            <column name="effect" value="DENY"/>
            <column name="priority" valueNumeric="200"/>
            <column name="policy_id" value="policy-cart-limits"/>
            <column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="policy_rule_metadata">
            <column name="rule_id" value="rule-cart-mid-value-limit"/>
            <column name="meta_key" value="userMessage"/>
            <column name="meta_value" value="Items between Rs.1,000-10,000 are limited to 5 per order"/>
        </insert>

        <!-- Budget items (<1000): max 10 per cart (default) -->
        <insert tableName="policy_rule">
            <column name="id" value="rule-cart-budget-limit"/>
            <column name="name" value="Budget Item Quantity Limit"/>
            <column name="expression" value="product.price &lt; 1000 and requestedQuantity > 10"/>
            <column name="effect" value="DENY"/>
            <column name="priority" valueNumeric="300"/>
            <column name="policy_id" value="policy-cart-limits"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- Max cart value overall -->
        <insert tableName="policy_rule">
            <column name="id" value="rule-cart-max-value"/>
            <column name="name" value="Maximum Cart Value"/>
            <column name="expression" value="cartTotal > 500000"/>
            <column name="effect" value="DENY"/>
            <column name="priority" valueNumeric="50"/>
            <column name="policy_id" value="policy-cart-limits"/>
            <column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="policy_rule_metadata">
            <column name="rule_id" value="rule-cart-max-value"/>
            <column name="meta_key" value="userMessage"/>
            <column name="meta_value" value="Cart total cannot exceed Rs.5,00,000. Please remove some items."/>
        </insert>

