<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- tax_rates (TaxRateEntity extends BaseJpaEntity) -->
    <changeSet id="tax-001-create-tax-rates" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="tax_rates"/></not>
        </preConditions>
        <createTable tableName="tax_rates">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="region_code" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="tax_type" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="rate" type="DECIMAL(10,4)"><constraints nullable="false"/></column>
            <column name="effective_from" type="DATE"/>
            <column name="effective_to" type="DATE"/>
            <column name="active" type="BOOLEAN"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_tax_rates_region" tableName="tax_rates">
            <column name="region_code"/>
            <column name="active"/>
        </createIndex>
    </changeSet>

    <!-- tax_category_mapping (TaxCategoryMappingEntity extends BaseJpaEntity) -->
    <changeSet id="tax-002-create-tax-category-mapping" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="tax_category_mapping"/></not>
        </preConditions>
        <createTable tableName="tax_category_mapping">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="category_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="hsn_code" type="VARCHAR(255)"/>
            <column name="tax_rate_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
        </createTable>
    </changeSet>

    <!-- order_tax_lines (OrderTaxLineEntity extends BaseJpaEntity) -->
    <changeSet id="tax-003-create-order-tax-lines" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="order_tax_lines"/></not>
        </preConditions>
        <createTable tableName="order_tax_lines">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_item_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="tax_rate_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="tax_type" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="taxable_amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="tax_amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="rate_applied" type="DECIMAL(10,4)"><constraints nullable="false"/></column>
        </createTable>
        <createIndex indexName="idx_order_tax_lines_order" tableName="order_tax_lines">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
