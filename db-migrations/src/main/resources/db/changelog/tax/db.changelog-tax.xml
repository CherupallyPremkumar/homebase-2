<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- V40: Tax rates, category mappings, and order tax lines             -->
    <!-- ================================================================== -->
    <changeSet id="V40__create_tax_tables" author="homebase" runOnChange="false">
        <createTable tableName="tax_rates">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="region_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tax_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="rate" type="NUMERIC(6,4)">
                <constraints nullable="false"/>
            </column>
            <column name="effective_from" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="effective_to" type="DATE"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <createTable tableName="tax_category_mapping">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_id" type="VARCHAR(36)">
                <constraints foreignKeyName="fk_tax_cat_map_category" referencedTableName="categories" referencedColumnNames="id"/>
            </column>
            <column name="hsn_code" type="VARCHAR(20)"/>
            <column name="tax_rate_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_tax_cat_map_rate" referencedTableName="tax_rates" referencedColumnNames="id"/>
            </column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <createTable tableName="order_tax_lines">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_order_tax_lines_order" referencedTableName="orders" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="order_item_id" type="VARCHAR(36)">
                <constraints foreignKeyName="fk_order_tax_lines_item" referencedTableName="order_items" referencedColumnNames="id"/>
            </column>
            <column name="tax_rate_id" type="VARCHAR(36)">
                <constraints nullable="false" foreignKeyName="fk_order_tax_lines_rate" referencedTableName="tax_rates" referencedColumnNames="id"/>
            </column>
            <column name="tax_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="taxable_amount" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="tax_amount" type="NUMERIC(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="rate_applied" type="NUMERIC(6,4)">
                <constraints nullable="false"/>
            </column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <createIndex indexName="idx_tax_rates_region" tableName="tax_rates">
            <column name="region_code"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_tax_category_hsn" tableName="tax_category_mapping">
            <column name="hsn_code"/>
        </createIndex>
        <createIndex indexName="idx_order_tax_lines_order" tableName="order_tax_lines">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
