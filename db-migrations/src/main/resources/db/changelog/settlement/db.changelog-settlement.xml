<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001-create-settlements-table" author="homebase">
        <createTable tableName="settlements">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="supplier_id" type="VARCHAR(255)"/>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="order_amount" type="DECIMAL(19,2)"/>
            <column name="commission_amount" type="DECIMAL(19,2)"/>
            <column name="platform_fee" type="DECIMAL(19,2)"/>
            <column name="net_amount" type="DECIMAL(19,2)"/>
            <column name="currency" type="VARCHAR(3)"/>
            <column name="settlement_period_start" type="DATE"/>
            <column name="settlement_period_end" type="DATE"/>
            <column name="disbursement_reference" type="VARCHAR(255)"/>
            <column name="state_id" type="VARCHAR(50)"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="settlements" indexName="idx_settlement_supplier">
            <column name="supplier_id"/>
        </createIndex>
        <createIndex tableName="settlements" indexName="idx_settlement_order">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="settlements" indexName="idx_settlement_period">
            <column name="settlement_period_start"/>
            <column name="settlement_period_end"/>
        </createIndex>
        <createIndex tableName="settlements" indexName="idx_settlement_state">
            <column name="state_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-settlement-adjustments-table" author="homebase">
        <createTable tableName="settlement_adjustments">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="settlement_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,2)">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="TEXT"/>
            <column name="adjusted_by" type="VARCHAR(255)"/>
            <column name="adjusted_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_adjustment_settlement"
            baseTableName="settlement_adjustments"
            baseColumnNames="settlement_id"
            referencedTableName="settlements"
            referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="003-create-settlement-activity-table" author="homebase">
        <createTable tableName="settlement_activity">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="settlement_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="activity_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="activity_success" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="activity_comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_activity_settlement"
            baseTableName="settlement_activity"
            baseColumnNames="settlement_id"
            referencedTableName="settlements"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
