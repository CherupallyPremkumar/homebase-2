    <!-- return_processing_saga (ReturnProcessingSagaEntity extends AbstractJpaStateEntity) -->
    <changeSet id="saga-003-create-return-processing-saga" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="return_processing_saga"/></not>
        </preConditions>
        <createTable tableName="return_processing_saga">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="return_request_id" type="VARCHAR(255)"/>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="order_item_id" type="VARCHAR(255)"/>
            <column name="refund_amount" type="DECIMAL(19,2)"/>
            <column name="shipment_id" type="VARCHAR(255)"/>
            <column name="settlement_adjustment_id" type="VARCHAR(255)"/>
            <column name="refund_id" type="VARCHAR(255)"/>
            <column name="error_message" type="VARCHAR(2000)"/>
            <column name="retry_count" type="INT" defaultValueNumeric="0"/>
        </createTable>
        <createIndex indexName="idx_return_processing_saga_return" tableName="return_processing_saga">
            <column name="return_request_id"/>
        </createIndex>
    </changeSet>

    <!-- return_processing_saga_activity (ReturnProcessingSagaActivityLogEntity extends BaseJpaEntity) -->
    <changeSet id="saga-004-create-return-processing-saga-activity" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="return_processing_saga_activity"/></not>
        </preConditions>
        <createTable tableName="return_processing_saga_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="saga_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
