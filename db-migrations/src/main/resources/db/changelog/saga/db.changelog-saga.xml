    <!-- supplier_lifecycle_saga_activity (SupplierLifecycleSagaActivityLogEntity extends BaseJpaEntity) -->
    <changeSet id="saga-006-create-supplier-lifecycle-saga-activity" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="supplier_lifecycle_saga_activity"/></not>
        </preConditions>
        <createTable tableName="supplier_lifecycle_saga_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="saga_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>
    </changeSet>

    <!-- ============================================================ -->
    <!-- RETURN PROCESSING — inspection, disposition, labels          -->
    <!-- ============================================================ -->

    <!-- return_inspections — QA on returned items -->
    <changeSet id="saga-007-create-return-inspections" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="return_inspections"/></not>
        </preConditions>
        <createTable tableName="return_inspections">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="return_request_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="saga_id" type="VARCHAR(255)"/>
            <column name="order_item_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(100)"/>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="inspector_id" type="VARCHAR(255)"/>
            <column name="inspection_date" type="TIMESTAMP"/>
            <column name="condition_code" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="is_resellable" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="damage_description" type="VARCHAR(2000)"/>
            <column name="images_json" type="TEXT"/>
            <column name="notes" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex tableName="return_inspections" indexName="idx_ri_return_request">
            <column name="return_request_id"/>
        </createIndex>
        <createIndex tableName="return_inspections" indexName="idx_ri_warehouse_date">
            <column name="warehouse_id"/>
            <column name="inspection_date"/>
        </createIndex>
    </changeSet>

    <!-- return_dispositions — what happens to returned item -->
    <changeSet id="saga-008-create-return-dispositions" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="return_dispositions"/></not>
        </preConditions>
        <createTable tableName="return_dispositions">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="return_request_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="inspection_id" type="VARCHAR(255)"/>
            <column name="order_item_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(100)"/>
            <column name="disposition_type" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="original_price" type="DECIMAL(19,2)"/>
            <column name="recovered_value" type="DECIMAL(19,2)"/>
            <column name="loss_amount" type="DECIMAL(19,2)"/>
            <column name="restocked_warehouse_id" type="VARCHAR(255)"/>
            <column name="restocked_at" type="TIMESTAMP"/>
            <column name="liquidation_channel" type="VARCHAR(100)"/>
            <column name="decided_by" type="VARCHAR(255)"/>
            <column name="notes" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex tableName="return_dispositions" indexName="idx_rd_return_request">
            <column name="return_request_id"/>
        </createIndex>
        <createIndex tableName="return_dispositions" indexName="idx_rd_disposition_type">
            <column name="disposition_type"/>
        </createIndex>
    </changeSet>

    <!-- return_labels — return shipping labels -->
    <changeSet id="saga-009-create-return-labels" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="return_labels"/></not>
        </preConditions>
        <createTable tableName="return_labels">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="return_request_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="carrier" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="tracking_number" type="VARCHAR(255)"/>
            <column name="label_url" type="VARCHAR(500)"/>
            <column name="label_format" type="VARCHAR(10)" defaultValue="PDF"/>
            <column name="expiry_date" type="DATE"/>
            <column name="is_used" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="pickup_scheduled_date" type="DATE"/>
            <column name="pickup_address_json" type="TEXT"/>
        </createTable>
        <createIndex tableName="return_labels" indexName="idx_rl_return_request">
            <column name="return_request_id"/>
        </createIndex>
        <createIndex tableName="return_labels" indexName="idx_rl_tracking">
            <column name="tracking_number"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================ -->
    <!-- SUPPLIER LIFECYCLE — performance, probation, appeals         -->
    <!-- ============================================================ -->

    <!-- supplier_performance_metrics — KPIs for buy-box eligibility -->
    <changeSet id="saga-010-create-supplier-performance-metrics" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="supplier_performance_metrics"/></not>
        </preConditions>
        <createTable tableName="supplier_performance_metrics">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="metric_date" type="DATE"><constraints nullable="false"/></column>
            <column name="period_type" type="VARCHAR(10)" defaultValue="DAILY"/>
            <column name="total_orders" type="INT" defaultValueNumeric="0"/>
            <column name="orders_fulfilled" type="INT" defaultValueNumeric="0"/>
            <column name="orders_cancelled" type="INT" defaultValueNumeric="0"/>
            <column name="orders_returned" type="INT" defaultValueNumeric="0"/>
            <column name="defect_rate_pct" type="DECIMAL(5,2)"/>
            <column name="on_time_ship_rate_pct" type="DECIMAL(5,2)"/>
            <column name="late_ship_rate_pct" type="DECIMAL(5,2)"/>
            <column name="return_rate_pct" type="DECIMAL(5,2)"/>
            <column name="cancellation_rate_pct" type="DECIMAL(5,2)"/>
            <column name="customer_satisfaction_avg" type="DECIMAL(3,2)"/>
            <column name="avg_response_time_hours" type="DECIMAL(8,2)"/>
            <column name="total_revenue" type="DECIMAL(19,2)"/>
            <column name="total_refunds" type="DECIMAL(19,2)"/>
            <column name="buy_box_win_rate_pct" type="DECIMAL(5,2)"/>
        </createTable>
        <addUniqueConstraint tableName="supplier_performance_metrics"
            columnNames="supplier_id, metric_date, period_type"
            constraintName="uq_spm_supplier_date_period"/>
        <createIndex tableName="supplier_performance_metrics" indexName="idx_spm_supplier_date">
            <column name="supplier_id"/>
            <column name="metric_date"/>
        </createIndex>
        <createIndex tableName="supplier_performance_metrics" indexName="idx_spm_defect_rate">
            <column name="defect_rate_pct"/>
        </createIndex>
    </changeSet>

    <!-- supplier_probation_history — probation tracking -->
    <changeSet id="saga-011-create-supplier-probation-history" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="supplier_probation_history"/></not>
        </preConditions>
        <createTable tableName="supplier_probation_history">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="lifecycle_saga_id" type="VARCHAR(255)"/>
            <column name="probation_type" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="reason" type="VARCHAR(1000)"><constraints nullable="false"/></column>
            <column name="triggered_by_metric" type="VARCHAR(50)"/>
            <column name="metric_value" type="DECIMAL(8,2)"/>
            <column name="threshold_value" type="DECIMAL(8,2)"/>
            <column name="start_date" type="DATE"><constraints nullable="false"/></column>
            <column name="end_date" type="DATE"/>
            <column name="status" type="VARCHAR(30)" defaultValue="ACTIVE"/>
            <column name="repeat_offense_count" type="INT" defaultValueNumeric="0"/>
            <column name="resolved_at" type="TIMESTAMP"/>
            <column name="resolution_notes" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex tableName="supplier_probation_history" indexName="idx_sph_supplier_status">
            <column name="supplier_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="supplier_probation_history" indexName="idx_sph_start_date">
            <column name="start_date"/>
        </createIndex>
    </changeSet>

    <!-- supplier_appeal_requests — supplier appeals for reinstatement -->
    <changeSet id="saga-012-create-supplier-appeal-requests" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="supplier_appeal_requests"/></not>
        </preConditions>
        <createTable tableName="supplier_appeal_requests">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="supplier_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="probation_id" type="VARCHAR(255)"/>
            <column name="lifecycle_saga_id" type="VARCHAR(255)"/>
            <column name="previous_action" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="appeal_reason" type="VARCHAR(2000)"><constraints nullable="false"/></column>
            <column name="supporting_docs_json" type="TEXT"/>
            <column name="corrective_action_plan" type="VARCHAR(2000)"/>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="assigned_reviewer" type="VARCHAR(255)"/>
            <column name="decision_date" type="TIMESTAMP"/>
            <column name="decided_by" type="VARCHAR(255)"/>
            <column name="decision_notes" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex tableName="supplier_appeal_requests" indexName="idx_sar_supplier_status">
            <column name="supplier_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="supplier_appeal_requests" indexName="idx_sar_pending">
            <column name="status"/>
            <column name="created_time"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
