<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- V44: CMS pages and banners                                         -->
    <!-- ================================================================== -->
    <changeSet id="V44__create_cms_tables" author="homebase" runOnChange="false">
        <createTable tableName="cms_pages">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_cms_pages_slug"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="TEXT"/>
            <column name="page_type" type="VARCHAR(50)"/>
            <column name="meta_title" type="VARCHAR(255)"/>
            <column name="meta_description" type="VARCHAR(500)"/>
            <column name="published" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="published_at" type="TIMESTAMP"/>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <createTable tableName="banners">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="mobile_image_url" type="VARCHAR(1000)"/>
            <column name="link_url" type="VARCHAR(1000)"/>
            <column name="position" type="VARCHAR(50)"/>
            <column name="display_order" type="INT" defaultValueNumeric="0"/>
            <column name="active_from" type="TIMESTAMP"/>
            <column name="active_to" type="TIMESTAMP"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="test_entity" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>

        <createIndex indexName="idx_cms_pages_slug" tableName="cms_pages">
            <column name="slug"/>
        </createIndex>
        <createIndex indexName="idx_banners_position" tableName="banners">
            <column name="position"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_banners_dates" tableName="banners">
            <column name="active_from"/>
            <column name="active_to"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
