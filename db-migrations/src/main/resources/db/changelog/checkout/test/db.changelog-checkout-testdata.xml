            <column name="sku" value="SKU-001"/>
            <column name="product_name" value="Widget A"/>
            <column name="supplier_id" value="supplier-1"/>
            <column name="quantity" valueNumeric="2"/>
            <column name="unit_price" valueNumeric="500.00"/>
            <column name="line_total" valueNumeric="1000.00"/>
