            <column name="idempotency_key" value="idem-chk-4"/>
            <column name="state_id" value="EXPIRED"/>
            <column name="flow_id" value="checkout-flow"/>
            <column name="created_time" valueDate="2025-12-25T10:30:00"/>
            <column name="last_modified_time" valueDate="2025-12-25T11:00:00"/>
            <column name="tenant" value="homebase"/>
            <column name="version" valueNumeric="2"/>
        </insert>

        <!-- Checkout Items for chk-1 -->
        <insert tableName="checkout_item">
