        <insert tableName="checkout_item">
            <column name="id" value="ci-1b"/>
            <column name="checkout_id" value="chk-1"/>
            <column name="product_id" value="prod-2"/>
            <column name="variant_id" value="var-2a"/>
            <column name="sku" value="SKU-002"/>
