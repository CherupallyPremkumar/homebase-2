        </insert>

        <!-- Checkout Saga Log for chk-1 (all steps completed) -->
        <insert tableName="checkout_saga_log">
            <column name="id" value="csl-1a"/>
            <column name="checkout_id" value="chk-1"/>
            <column name="step_name" value="validateAddress"/>
            <column name="step_status" value="COMPLETED"/>
            <column name="started_at" valueDate="2026-03-10T14:28:01"/>
            <column name="completed_at" valueDate="2026-03-10T14:28:02"/>
            <column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="checkout_saga_log">
            <column name="id" value="csl-1b"/>
            <column name="checkout_id" value="chk-1"/>
            <column name="step_name" value="reserveInventory"/>
            <column name="step_status" value="COMPLETED"/>
            <column name="started_at" valueDate="2026-03-10T14:28:02"/>
            <column name="completed_at" valueDate="2026-03-10T14:28:05"/>
            <column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="checkout_saga_log">
            <column name="id" value="csl-1c"/>
            <column name="checkout_id" value="chk-1"/>
            <column name="step_name" value="processPayment"/>
            <column name="step_status" value="COMPLETED"/>
            <column name="started_at" valueDate="2026-03-10T14:30:00"/>
            <column name="completed_at" valueDate="2026-03-10T14:32:00"/>
            <column name="tenant" value="homebase"/>
        </insert>

        <!-- Saga Log for chk-3 (payment failed) -->
        <insert tableName="checkout_saga_log">
            <column name="id" value="csl-3a"/>
            <column name="checkout_id" value="chk-3"/>
            <column name="step_name" value="processPayment"/>
            <column name="step_status" value="FAILED"/>
            <column name="started_at" valueDate="2026-03-14T10:02:00"/>
            <column name="completed_at" valueDate="2026-03-14T10:03:00"/>
            <column name="error_message" value="Gateway error: Card declined — insufficient funds"/>
            <column name="tenant" value="homebase"/>
        </insert>

    </changeSet>

</databaseChangeLog>
