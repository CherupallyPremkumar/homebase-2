<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Data Exports — bulk data export tracking                           -->
    <!-- Infrastructure module (no STM — simple status tracking)            -->
    <!-- ================================================================== -->

    <!-- data_export (DataExportEntity extends BaseJpaEntity) -->
    <changeSet id="exports-001-create-data-export" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="data_export"/></not>
        </preConditions>
        <createTable tableName="data_export">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="export_type" type="VARCHAR(100)"/>
            <column name="format" type="VARCHAR(10)"/>
            <column name="status" type="VARCHAR(20)"/>
            <column name="file_name" type="VARCHAR(500)"/>
            <column name="file_url" type="VARCHAR(1000)"/>
            <column name="file_size_bytes" type="BIGINT"/>
            <column name="record_count" type="INT"/>
            <column name="filters_json" type="TEXT"/>
            <column name="requested_by" type="VARCHAR(255)"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="error_message" type="VARCHAR(2000)"/>
        </createTable>
        <createIndex indexName="idx_export_status" tableName="data_export">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_export_type" tableName="data_export">
            <column name="export_type"/>
        </createIndex>
        <createIndex indexName="idx_export_requested_by" tableName="data_export">
            <column name="requested_by"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
