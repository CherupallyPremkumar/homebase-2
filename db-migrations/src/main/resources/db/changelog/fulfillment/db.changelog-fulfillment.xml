<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- Fulfillment Orders — the actual pick/pack/ship work entity         -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-001-create-fulfillment-orders" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fulfillment_orders"/></not>
        </preConditions>
        <createTable tableName="fulfillment_orders">
            <!-- BaseJpaEntity -->
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <!-- AbstractJpaStateEntity -->
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <!-- Fulfillment-specific -->
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="saga_id" type="VARCHAR(255)"/>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="user_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="priority" type="VARCHAR(20)" defaultValue="STANDARD">
                <constraints nullable="false"/>
            </column>
            <column name="fulfillment_type" type="VARCHAR(50)" defaultValue="SHIP_TO_CUSTOMER"/>
            <column name="assigned_picker_id" type="VARCHAR(255)"/>
            <column name="assigned_packer_id" type="VARCHAR(255)"/>
            <column name="pick_started_at" type="TIMESTAMP"/>
            <column name="pick_completed_at" type="TIMESTAMP"/>
            <column name="pack_started_at" type="TIMESTAMP"/>
            <column name="pack_completed_at" type="TIMESTAMP"/>
            <column name="shipped_at" type="TIMESTAMP"/>
            <column name="delivered_at" type="TIMESTAMP"/>
            <column name="cancelled_at" type="TIMESTAMP"/>
            <column name="cancellation_reason" type="VARCHAR(500)"/>
            <column name="total_items" type="INT" defaultValueNumeric="0"/>
            <column name="total_weight_grams" type="INT"/>
            <column name="shipping_method" type="VARCHAR(50)"/>
            <column name="carrier" type="VARCHAR(100)"/>
            <column name="tracking_number" type="VARCHAR(255)"/>
            <column name="estimated_ship_date" type="DATE"/>
            <column name="estimated_delivery_date" type="DATE"/>
            <column name="notes" type="VARCHAR(2000)"/>
        </createTable>
    </changeSet>

    <changeSet id="fulfillment-002-fulfillment-orders-indexes" author="homebase">
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_order_id">
            <column name="order_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_warehouse_id">
            <column name="warehouse_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_state_id">
            <column name="state_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_priority_state">
            <column name="priority"/>
            <column name="state_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_orders" indexName="idx_fo_tracking">
            <column name="tracking_number"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Fulfillment Line Items — each item being fulfilled                 -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-003-create-fulfillment-line-items" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fulfillment_line_items"/></not>
        </preConditions>
        <createTable tableName="fulfillment_line_items">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="fulfillment_order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_item_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="product_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="product_name" type="VARCHAR(500)"/>
            <column name="quantity_ordered" type="INT"><constraints nullable="false"/></column>
            <column name="quantity_allocated" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_picked" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_packed" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_shipped" type="INT" defaultValueNumeric="0"/>
            <column name="quantity_short" type="INT" defaultValueNumeric="0"/>
            <column name="bin_location" type="VARCHAR(50)"/>
            <column name="barcode" type="VARCHAR(100)"/>
            <column name="weight_grams" type="INT"/>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="picked_at" type="TIMESTAMP"/>
            <column name="packed_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="fulfillment_line_items" baseColumnNames="fulfillment_order_id"
            referencedTableName="fulfillment_orders" referencedColumnNames="id"
            constraintName="fk_fli_fulfillment_order"/>
        <createIndex tableName="fulfillment_line_items" indexName="idx_fli_fulfillment_order">
            <column name="fulfillment_order_id"/>
        </createIndex>
        <createIndex tableName="fulfillment_line_items" indexName="idx_fli_sku">
            <column name="sku"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Pick Lists — warehouse pick operations                             -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-004-create-pick-lists" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="pick_lists"/></not>
        </preConditions>
        <createTable tableName="pick_lists">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="fulfillment_order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="assigned_to" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(30)" defaultValue="PENDING"/>
            <column name="item_count" type="INT" defaultValueNumeric="0"/>
            <column name="picked_count" type="INT" defaultValueNumeric="0"/>
            <column name="started_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="notes" type="VARCHAR(1000)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="pick_lists" baseColumnNames="fulfillment_order_id"
            referencedTableName="fulfillment_orders" referencedColumnNames="id"
            constraintName="fk_pl_fulfillment_order"/>
        <createIndex tableName="pick_lists" indexName="idx_pl_warehouse_status">
            <column name="warehouse_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="pick_lists" indexName="idx_pl_assigned_to">
            <column name="assigned_to"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Pack Slips — packing documentation                                 -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-005-create-pack-slips" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="pack_slips"/></not>
        </preConditions>
        <createTable tableName="pack_slips">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="fulfillment_order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="warehouse_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="packed_by" type="VARCHAR(255)"/>
            <column name="tracking_number" type="VARCHAR(255)"/>
            <column name="package_weight_grams" type="INT"/>
            <column name="package_length_cm" type="DECIMAL(8,2)"/>
            <column name="package_width_cm" type="DECIMAL(8,2)"/>
            <column name="package_height_cm" type="DECIMAL(8,2)"/>
            <column name="packaging_type" type="VARCHAR(50)"/>
            <column name="label_url" type="VARCHAR(500)"/>
            <column name="slip_url" type="VARCHAR(500)"/>
            <column name="packed_at" type="TIMESTAMP"/>
            <column name="verified_at" type="TIMESTAMP"/>
            <column name="verified_by" type="VARCHAR(255)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="pack_slips" baseColumnNames="fulfillment_order_id"
            referencedTableName="fulfillment_orders" referencedColumnNames="id"
            constraintName="fk_ps_fulfillment_order"/>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Delivery Attempts — track failed/successful deliveries             -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-006-create-delivery-attempts" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="delivery_attempts"/></not>
        </preConditions>
        <createTable tableName="delivery_attempts">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="fulfillment_order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="shipment_id" type="VARCHAR(255)"/>
            <column name="attempt_number" type="INT"><constraints nullable="false"/></column>
            <column name="attempted_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="result" type="VARCHAR(30)"><constraints nullable="false"/></column>
            <column name="failure_reason" type="VARCHAR(50)"/>
            <column name="failure_details" type="VARCHAR(1000)"/>
            <column name="delivery_agent" type="VARCHAR(255)"/>
            <column name="proof_of_delivery_url" type="VARCHAR(500)"/>
            <column name="recipient_name" type="VARCHAR(255)"/>
            <column name="signature_url" type="VARCHAR(500)"/>
            <column name="next_attempt_date" type="DATE"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="delivery_attempts" baseColumnNames="fulfillment_order_id"
            referencedTableName="fulfillment_orders" referencedColumnNames="id"
            constraintName="fk_da_fulfillment_order"/>
        <createIndex tableName="delivery_attempts" indexName="idx_da_fulfillment_result">
            <column name="fulfillment_order_id"/>
            <column name="result"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Fulfillment Order Activity Log                                     -->
    <!-- ================================================================== -->
    <changeSet id="fulfillment-007-create-fulfillment-order-activity" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fulfillment_order_activity"/></not>
        </preConditions>
        <createTable tableName="fulfillment_order_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="fulfillment_order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="fulfillment_order_activity" baseColumnNames="fulfillment_order_id"
            referencedTableName="fulfillment_orders" referencedColumnNames="id"
            constraintName="fk_foa_fulfillment_order"/>
    </changeSet>

</databaseChangeLog>
