<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CconfigEntries">

    <resultMap id="cconfigResult" type="map">
        <result property="id" column="id"/>
        <result property="moduleName" column="module_name"/>
        <result property="keyName" column="key_name"/>
        <result property="avalue" column="avalue"/>
        <result property="customAttribute" column="custom_attribute"/>
        <result property="tenant" column="tenant"/>
        <result property="createdTime" column="created_time"/>
        <result property="lastModifiedTime" column="last_modified_time"/>
    </resultMap>

    <!-- cconfigEntries: All config entries with filters and pagination -->
    <select id='getAll-count' resultType="int">
        select count(*) from cconfig
        <where>
            <if test="moduleName != null">
                AND module_name = #{moduleName}
            </if>
            <if test="keyName != null">
                AND key_name like #{keyName}
            </if>
            <if test="customAttribute != null">
                AND custom_attribute = #{customAttribute}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
    </select>

    <select id="getAll" resultMap="cconfigResult">
        SELECT * FROM cconfig
        <where>
            <if test="moduleName != null">
                AND module_name = #{moduleName}
            </if>
            <if test="keyName != null">
                AND key_name like #{keyName}
            </if>
            <if test="customAttribute != null">
                AND custom_attribute = #{customAttribute}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- cconfigByModule: Entries for a specific module -->
    <select id='getByModule-count' resultType="int">
        select count(*) from cconfig
        <where>
            AND module_name = #{moduleName}
            <if test="keyName != null">
                AND key_name like #{keyName}
            </if>
            <if test="customAttribute != null">
                AND custom_attribute = #{customAttribute}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
    </select>

    <select id="getByModule" resultMap="cconfigResult">
        SELECT * FROM cconfig
        <where>
            AND module_name = #{moduleName}
            <if test="keyName != null">
                AND key_name like #{keyName}
            </if>
            <if test="customAttribute != null">
                AND custom_attribute = #{customAttribute}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- cconfigFormSchemas: Only form.schema entries -->
    <select id='getFormSchemas-count' resultType="int">
        select count(*) from cconfig
        <where>
            AND key_name like '%form.schema'
            <if test="moduleName != null">
                AND module_name = #{moduleName}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
    </select>

    <select id="getFormSchemas" resultMap="cconfigResult">
        SELECT * FROM cconfig
        <where>
            AND key_name like '%form.schema'
            <if test="moduleName != null">
                AND module_name = #{moduleName}
            </if>
            <if test="tenant != null">
                AND tenant = #{tenant}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

</mapper>
