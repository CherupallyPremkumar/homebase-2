{
  "realm": "homebase",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "CUSTOMER",
        "description": "Default customer role"
      },
      {
        "name": "ADMIN",
        "description": "Platform administrator"
      },
      {
        "name": "WAREHOUSE",
        "description": "Warehouse staff"
      },
      {
        "name": "SUPPLIER",
        "description": "Marketplace supplier"
      },
      {
        "name": "SYSTEM",
        "description": "System-level operations"
      },
      {
        "name": "AGENT",
        "description": "Support agent"
      }
    ]
  },
  "defaultRoles": [
    "CUSTOMER"
  ],
  "clients": [
    {
      "clientId": "homebase-storefront",
      "name": "HomeBase Storefront",
      "enabled": true,
      "publicClient": false,
      "secret": "storefront-secret-sit",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "baseUrl": "/",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "homebase-admin",
      "name": "HomeBase Admin",
      "enabled": true,
      "publicClient": false,
      "secret": "admin-secret-sit",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "baseUrl": "/"
    },
    {
      "clientId": "homebase-backend",
      "name": "HomeBase Backend",
      "description": "Backend services (monolith/microservices)",
      "enabled": true,
      "publicClient": false,
      "secret": "backend-secret-sit",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "bearerOnly": true
    },
    {
      "clientId": "homebase-system",
      "name": "HomeBase System",
      "description": "Service account for system operations",
      "enabled": true,
      "publicClient": false,
      "secret": "system-secret-sit",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
