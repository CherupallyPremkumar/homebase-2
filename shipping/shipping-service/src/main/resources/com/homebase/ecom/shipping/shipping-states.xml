<?xml version="1.0" encoding="UTF-8"?>
<states>
  <flow id='shipping-flow' default='true'>
    <entry-action componentName="shippingEntryAction" />

    <manual-state id='AWAITING_PICKUP' initialState='true' meta-mainPath="true">
      <entry-action componentName="awaitingPickupAction" />
      <on eventId='courierAssigned' 
          componentName='courierAssignedAction'
          newStateId='PICKED_UP' 
          meta-mainPath="true"
          meta-acls="WAREHOUSE"/>
    </manual-state>

    <manual-state id='PICKED_UP' meta-mainPath="true">
      <entry-action componentName="pickedUpAction" />
      <on eventId='inTransit' 
          componentName='inTransitAction'
          newStateId='IN_TRANSIT' 
          meta-mainPath="true"
          meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='IN_TRANSIT' meta-mainPath="true">
      <entry-action componentName="inTransitAction" />
      <on eventId='outForDelivery' 
          componentName='outForDeliveryAction'
          newStateId='OUT_FOR_DELIVERY' 
          meta-mainPath="true"
          meta-acls="SYSTEM"/>
      <on eventId='returnRequested' 
          componentName='returnRequestedAction'
          newStateId='RETURN_REQUESTED'/>
    </manual-state>

    <manual-state id='OUT_FOR_DELIVERY' meta-mainPath="true">
      <entry-action componentName="outForDeliveryAction" />
      <on eventId='markDelivered' 
          componentName='markDeliveredAction'
          newStateId='DELIVERED' 
          meta-mainPath="true"
          meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='DELIVERED' meta-mainPath="true">
      <entry-action componentName="deliveredAction" />
      <on eventId='returnRequested' 
          componentName='returnRequestedAction'
          newStateId='RETURN_REQUESTED'/>
    </manual-state>

    <manual-state id='RETURN_REQUESTED'>
      <entry-action componentName="returnRequestedAction" />
      <on eventId='returnPickup' 
          componentName='returnPickupAction'
          newStateId='IN_TRANSIT'
          meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='RETURNED'>
      <entry-action componentName="returnedAction" />
    </manual-state>
  </flow>
</states>