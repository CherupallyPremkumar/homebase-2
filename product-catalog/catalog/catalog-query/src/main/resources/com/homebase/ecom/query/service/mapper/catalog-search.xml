<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CatalogSearch">

    <resultMap id="searchResult" type="map">
        <result property="id" column="ID"/>
        <result property="productId" column="product_id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="brand" column="brand"/>
        <result property="imageUrl" column="image_url"/>
        <result property="price" column="price"/>
        <result property="inStock" column="in_stock"/>
        <result property="averageRating" column="average_rating"/>
        <result property="reviewCount" column="review_count"/>
        <result property="relevance" column="relevance"/>
    </resultMap>

    <!-- searchCatalog: PostgreSQL full-text search with ranking -->
    <select id='search-count' resultType="int">
        select count(*) from catalog_items
        <where>
            AND active = true
            <if test="searchTerm != null">
                AND search_vector @@ plainto_tsquery('english', #{searchTerm})
            </if>
            <if test="minPrice != null">
                AND price &gt;= #{minPrice}
            </if>
            <if test="maxPrice != null">
                AND price &lt;= #{maxPrice}
            </if>
            <if test="inStock != null">
                AND in_stock = #{inStock}
            </if>
            <if test="brand != null">
                AND brand = #{brand}
            </if>
        </where>
    </select>

    <select id="search" resultMap="searchResult">
        SELECT *,
            <if test="searchTerm != null">
                ts_rank(search_vector, plainto_tsquery('english', #{searchTerm})) AS relevance
            </if>
            <if test="searchTerm == null">
                0 AS relevance
            </if>
        FROM catalog_items
        <where>
            AND active = true
            <if test="searchTerm != null">
                AND search_vector @@ plainto_tsquery('english', #{searchTerm})
            </if>
            <if test="minPrice != null">
                AND price &gt;= #{minPrice}
            </if>
            <if test="maxPrice != null">
                AND price &lt;= #{maxPrice}
            </if>
            <if test="inStock != null">
                AND in_stock = #{inStock}
            </if>
            <if test="brand != null">
                AND brand = #{brand}
            </if>
        </where>
        <if test="searchTerm != null">
            ORDER BY relevance DESC
        </if>
        ${pagination}
    </select>

    <!-- fuzzyCatalog: Trigram-based fuzzy search (typo tolerance) -->
    <select id='fuzzy-count' resultType="int">
        select count(*) from catalog_items
        <where>
            AND active = true
            <if test="searchTerm != null">
                AND similarity(name, #{searchTerm}) &gt; 0.2
            </if>
        </where>
    </select>

    <select id="fuzzy" resultMap="searchResult">
        SELECT *,
            similarity(name, #{searchTerm}) AS relevance
        FROM catalog_items
        <where>
            AND active = true
            <if test="searchTerm != null">
                AND similarity(name, #{searchTerm}) &gt; 0.2
            </if>
            <if test="minPrice != null">
                AND price &gt;= #{minPrice}
            </if>
            <if test="maxPrice != null">
                AND price &lt;= #{maxPrice}
            </if>
            <if test="inStock != null">
                AND in_stock = #{inStock}
            </if>
        </where>
        ORDER BY relevance DESC
        ${pagination}
    </select>

</mapper>
