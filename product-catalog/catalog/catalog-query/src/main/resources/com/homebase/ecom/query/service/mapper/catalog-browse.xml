<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="CatalogBrowse">

    <resultMap id="catalogItemResult" type="map">
        <result property="id" column="ID"/>
        <result property="productId" column="product_id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="brand" column="brand"/>
        <result property="imageUrl" column="image_url"/>
        <result property="price" column="price"/>
        <result property="featured" column="featured"/>
        <result property="active" column="active"/>
        <result property="displayOrder" column="display_order"/>
        <result property="inStock" column="in_stock"/>
        <result property="availableQty" column="available_qty"/>
        <result property="averageRating" column="average_rating"/>
        <result property="reviewCount" column="review_count"/>
    </resultMap>

    <!-- browseCatalog: Active catalog items with optional filters -->
    <select id='browse-count' resultType="int">
        select count(*) from catalog_items
        <where>
            AND active = true
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
            <if test="productId != null">
                AND product_id = #{productId}
            </if>
        </where>
    </select>

    <select id="browse" resultMap="catalogItemResult">
        SELECT * FROM catalog_items
        <where>
            AND active = true
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
            <if test="productId != null">
                AND product_id = #{productId}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- userPicks: Featured catalog items -->
    <select id='getUserPicks-count' resultType="int">
        select count(*) from catalog_items
        <where>
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
            <if test="productId != null">
                AND product_id = #{productId}
            </if>
        </where>
    </select>

    <select id="getUserPicks" resultMap="catalogItemResult">
        SELECT * FROM catalog_items
        <where>
            <if test="featured != null">
                AND featured = #{featured}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
            <if test="name != null">
                AND name like #{name}
            </if>
            <if test="productId != null">
                AND product_id = #{productId}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- itemSuggestions: Items by tags -->
    <select id='getSuggestions-count' resultType="int">
        select count(distinct ci.id) from catalog_items ci
        left join catalog_item_tags cit on ci.id = cit.catalog_item_id
        <where>
            <if test="tags != null">
                AND cit.tag in
                <foreach item="item" index="index" collection="tags"
                         open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="active != null">
                AND ci.active = #{active}
            </if>
        </where>
    </select>

    <select id="getSuggestions" resultMap="catalogItemResult">
        SELECT distinct ci.* FROM catalog_items ci
        left join catalog_item_tags cit on ci.id = cit.catalog_item_id
        <where>
            <if test="tags != null">
                AND cit.tag in
                <foreach item="item" index="index" collection="tags"
                         open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            <if test="active != null">
                AND ci.active = #{active}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

    <!-- catalogByCategory: Items in a specific category -->
    <select id='getByCategory-count' resultType="int">
        select count(*) from catalog_items ci
        join category_product_mapping cpm on ci.product_id = cpm.product_id
        <where>
            <if test="categoryId != null">
                AND cpm.category_id = #{categoryId}
            </if>
            <if test="active != null">
                AND ci.active = #{active}
            </if>
            <if test="name != null">
                AND ci.name like #{name}
            </if>
            <if test="productId != null">
                AND ci.product_id = #{productId}
            </if>
        </where>
    </select>

    <select id="getByCategory" resultMap="catalogItemResult">
        SELECT ci.* FROM catalog_items ci
        join category_product_mapping cpm on ci.product_id = cpm.product_id
        <where>
            <if test="categoryId != null">
                AND cpm.category_id = #{categoryId}
            </if>
            <if test="active != null">
                AND ci.active = #{active}
            </if>
            <if test="name != null">
                AND ci.name like #{name}
            </if>
            <if test="productId != null">
                AND ci.product_id = #{productId}
            </if>
        </where>
        ${orderby} ${pagination}
    </select>

</mapper>
