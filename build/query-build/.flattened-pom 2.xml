<?xml version="1.0" encoding="UTF-8"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>com.homebase.ecom.build</groupId>
    <artifactId>build-parent</artifactId>
    <version>0.0.1-SNAPSHOT</version>
  </parent>
  <groupId>com.homebase.ecom.build</groupId>
  <artifactId>query-build</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <name>Query Build - Standalone Query Service</name>
  <description>Aggregates all query implementation services into a single executable</description>
  <licenses>
    <license>
      <name>MIT License</name>
      <url>http://www.opensource.org/licenses/mit-license.php</url>
    </license>
  </licenses>
  <dependencies>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>cart-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>product-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>inventory-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom.user</groupId>
      <artifactId>user-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>order-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>settlement-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>returnrequest-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>catalog-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>shipping-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>supplier-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom</groupId>
      <artifactId>promo-query-service</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>org.chenile</groupId>
      <artifactId>chenile-query-controller</artifactId>
    </dependency>
    <dependency>
      <groupId>org.chenile</groupId>
      <artifactId>chenile-http</artifactId>
    </dependency>
    <dependency>
      <groupId>org.chenile</groupId>
      <artifactId>service-registry-service</artifactId>
    </dependency>
    <dependency>
      <groupId>com.homebase.ecom.build</groupId>
      <artifactId>build-configurations</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-actuator</artifactId>
    </dependency>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
    </dependency>
    <dependency>
      <groupId>org.postgresql</groupId>
      <artifactId>postgresql</artifactId>
      <scope>runtime</scope>
    </dependency>
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>runtime</scope>
    </dependency>
    <dependency>
      <groupId>org.projectlombok</groupId>
      <artifactId>lombok</artifactId>
      <optional>true</optional>
    </dependency>
  </dependencies>
  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <executions>
          <execution>
            <goals>
              <goal>repackage</goal>
            </goals>
          </execution>
        </executions>
        <configuration>
          <mainClass>com.homebase.ecom.query.QueryBuildApplication</mainClass>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
