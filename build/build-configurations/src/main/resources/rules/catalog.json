{
    "policies": {
        "catalogItem": {
            "maxFeaturedItems": 20,
            "maxTagsPerItem": 10,
            "allowedTags": [
                "trending",
                "bestseller",
                "new",
                "sale",
                "handpicked",
                "seasonal",
                "limited"
            ],
            "defaultDisplayOrder": 999,
            "autoDeactivateOnOutOfStock": true,
            "autoReactivateOnRestock": true
        },
        "category": {
            "maxDepthLevels": 3,
            "maxChildrenPerCategory": 50,
            "nameMinLength": 2,
            "nameMaxLength": 100,
            "requireSlug": true
        },
        "collection": {
            "maxProductsPerCollection": 200,
            "maxFeaturedCollections": 5,
            "requireDescriptionForPublish": true,
            "requireImageForFeaturedCollection": true,
            "ruleExpressionMaxLength": 1000
        }
    },
    "rules": {
        "visibility": {
            "outOfStockThreshold": 0,
            "lowStockThreshold": 5,
            "hideOutOfStockItems": true,
            "showLowStockBadge": true
        },
        "collection": {
            "dynamicCollectionBatchSizeLimit": 500,
            "staleDynamicCollectionRefreshHours": 24,
            "maxDynamicCollections": 20
        },
        "search": {
            "defaultPageSize": 20,
            "maxPageSize": 100,
            "defaultSortField": "displayOrder",
            "searchableFields": [
                "name",
                "tags",
                "categoryId"
            ]
        },
        "merchandising": {
            "featuredBoostEnabled": true,
            "newArrivalWindowDays": 30,
            "bestsellersMinOrderCount": 10
        }
    }
}