<?xml version="1.0" encoding="UTF-8"?>
<flows>
    <flow id="reconciliation-flow">
        <chain>
            <command componentName="fetchGatewayTransactions"/>
            <command componentName="fetchSystemTransactions"/>
            <command componentName="matchTransactions"/>
