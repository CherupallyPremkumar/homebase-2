<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

	<changeSet id="1.0-create-product-reviews" author="homebase">
		<createTable tableName="product_reviews">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="product_id" type="VARCHAR(36)">
				<constraints nullable="false"/>
			</column>
			<column name="customer_id" type="VARCHAR(36)">
				<constraints nullable="false"/>
			</column>
			<column name="order_id" type="VARCHAR(36)"/>
			<column name="rating" type="INT">
				<constraints nullable="false"/>
			</column>
			<column name="title" type="VARCHAR(255)"/>
			<column name="body" type="TEXT"/>
			<column name="images" type="TEXT"/>
			<column name="verified_purchase" type="BOOLEAN" defaultValueBoolean="false"/>
			<column name="helpful_count" type="INT" defaultValueNumeric="0"/>
			<column name="report_count" type="INT" defaultValueNumeric="0"/>
			<column name="moderator_notes" type="TEXT"/>
			<column name="state_id" type="VARCHAR(50)">
				<constraints nullable="false"/>
			</column>
			<column name="flow_id" type="VARCHAR(100)"/>
			<column name="tenant_id" type="VARCHAR(50)"/>
			<column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
			<column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
		</createTable>

		<createIndex tableName="product_reviews" indexName="idx_review_product_id">
			<column name="product_id"/>
		</createIndex>

		<createIndex tableName="product_reviews" indexName="idx_review_customer_id">
			<column name="customer_id"/>
		</createIndex>

		<createIndex tableName="product_reviews" indexName="idx_review_state_id">
			<column name="state_id"/>
		</createIndex>

		<createIndex tableName="product_reviews" indexName="idx_review_product_state">
			<column name="product_id"/>
			<column name="state_id"/>
		</createIndex>

		<createIndex tableName="product_reviews" indexName="idx_review_order_id">
			<column name="order_id"/>
		</createIndex>
	</changeSet>

	<changeSet id="1.0-create-review-activity" author="homebase">
		<createTable tableName="review_activity">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="review_id" type="VARCHAR(36)">
				<constraints nullable="false"/>
			</column>
			<column name="activity_name" type="VARCHAR(100)"/>
			<column name="activity_success" type="BOOLEAN" defaultValueBoolean="true"/>
			<column name="activity_comment" type="TEXT"/>
			<column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
			<column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
		</createTable>

		<addForeignKeyConstraint
			baseTableName="review_activity"
			baseColumnNames="review_id"
			referencedTableName="product_reviews"
			referencedColumnNames="id"
			constraintName="fk_review_activity_review"/>
	</changeSet>

</databaseChangeLog>
