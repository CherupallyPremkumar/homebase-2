<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-notifications-table" author="homebase">
        <createTable tableName="notifications">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="customer_id" type="VARCHAR(255)"/>
            <column name="channel" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="template_id" type="VARCHAR(255)"/>
            <column name="subject" type="VARCHAR(500)"/>
            <column name="body" type="TEXT"/>
            <column name="recipient_address" type="VARCHAR(500)"/>
            <column name="sent_at" type="TIMESTAMP"/>
            <column name="delivered_at" type="TIMESTAMP"/>
            <column name="failure_reason" type="TEXT"/>
            <column name="retry_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="state_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="description" type="VARCHAR(500)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex tableName="notifications" indexName="idx_notif_customer_id">
            <column name="customer_id"/>
        </createIndex>

        <createIndex tableName="notifications" indexName="idx_notif_channel">
            <column name="channel"/>
        </createIndex>

        <createIndex tableName="notifications" indexName="idx_notif_template_id">
            <column name="template_id"/>
        </createIndex>

        <createIndex tableName="notifications" indexName="idx_notif_state_id">
            <column name="state_id"/>
        </createIndex>

        <createIndex tableName="notifications" indexName="idx_notif_sent_at">
            <column name="sent_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-notification-metadata-table" author="homebase">
        <createTable tableName="notification_metadata">
            <column name="notification_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="meta_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="meta_value" type="VARCHAR(1000)"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="notification_metadata"
                baseColumnNames="notification_id"
                referencedTableName="notifications"
                referencedColumnNames="id"
                constraintName="fk_notif_metadata_notification"/>

        <createIndex tableName="notification_metadata" indexName="idx_notif_meta_notification_id">
            <column name="notification_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-notification-activity-log-table" author="homebase">
        <createTable tableName="notification_activity_log">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="notification_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="activity_name" type="VARCHAR(100)"/>
            <column name="activity_comment" type="VARCHAR(500)"/>
            <column name="activity_success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="notification_activity_log"
                baseColumnNames="notification_id"
                referencedTableName="notifications"
                referencedColumnNames="id"
                constraintName="fk_notif_activity_notification"/>
    </changeSet>

</databaseChangeLog>
