<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="notification-001-create-notifications" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="notifications"/></not></preConditions>
        <createTable tableName="notifications">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="customer_id" type="VARCHAR(255)"/>
            <column name="channel" type="VARCHAR(255)"/>
            <column name="template_id" type="VARCHAR(255)"/>
            <column name="subject" type="VARCHAR(255)"/>
            <column name="body" type="TEXT"/>
            <column name="recipient_address" type="VARCHAR(255)"/>
            <column name="sent_at" type="TIMESTAMP"/>
            <column name="delivered_at" type="TIMESTAMP"/>
            <column name="failure_reason" type="TEXT"/>
            <column name="retry_count" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="notification-002-create-notification-metadata" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="notification_metadata"/></not></preConditions>
        <createTable tableName="notification_metadata">
            <column name="notification_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="meta_key" type="VARCHAR(255)"/>
            <column name="meta_value" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="notification-003-create-notification-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="notification_activity"/></not></preConditions>
        <createTable tableName="notification_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="notification_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="VARCHAR(255)"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <changeSet id="notification-004-create-notification-preferences" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="notification_preferences"/></not></preConditions>
        <createTable tableName="notification_preferences">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="user_id" type="VARCHAR(255)"/>
            <column name="channel" type="VARCHAR(255)"/>
            <column name="category" type="VARCHAR(255)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <changeSet id="notification-005-create-notification-templates" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="notification_templates"/></not></preConditions>
        <createTable tableName="notification_templates">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="channel" type="VARCHAR(255)"/>
            <column name="subject_template" type="VARCHAR(255)"/>
            <column name="body_template" type="TEXT"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <addUniqueConstraint tableName="notification_templates" columnNames="code" constraintName="uk_notif_template_code"/>
    </changeSet>

    <!-- Add reference, priority, scheduling, and tracking columns to notifications -->
    <changeSet id="notification-006-add-notification-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notifications"/>
            <not><columnExists tableName="notifications" columnName="reference_type"/></not>
        </preConditions>
        <addColumn tableName="notifications">
            <column name="reference_type" type="VARCHAR(50)"/>
            <column name="reference_id" type="VARCHAR(255)"/>
            <column name="priority" type="VARCHAR(20)" defaultValue="NORMAL"/>
            <column name="scheduled_at" type="TIMESTAMP"/>
            <column name="opened_at" type="TIMESTAMP"/>
            <column name="clicked_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

    <!-- Indexes on notifications -->
    <changeSet id="notification-007-add-notification-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notifications"/>
            <not><indexExists indexName="idx_notifications_customer"/></not>
        </preConditions>
        <createIndex indexName="idx_notifications_customer" tableName="notifications">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_notifications_channel" tableName="notifications">
            <column name="channel"/>
        </createIndex>
        <createIndex indexName="idx_notifications_state" tableName="notifications">
            <column name="state_id"/>
        </createIndex>
        <createIndex indexName="idx_notifications_reference" tableName="notifications">
            <column name="reference_type"/>
            <column name="reference_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Customer Notifications (read model for storefront notification feed) -->
    <!-- ================================================================== -->

    <changeSet id="notification-008-create-customer-notifications" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="customer_notifications"/></not></preConditions>
        <createTable tableName="customer_notifications">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="customer_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="message" type="TEXT"/>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"><constraints nullable="false"/></column>
            <column name="reference_id" type="VARCHAR(255)"/>
            <column name="reference_type" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>

    <changeSet id="notification-009-customer-notifications-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="customer_notifications"/>
            <not><indexExists indexName="idx_customer_notifications_customer"/></not>
        </preConditions>
        <createIndex indexName="idx_customer_notifications_customer" tableName="customer_notifications">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_customer_notifications_tenant_customer" tableName="customer_notifications">
            <column name="tenant"/>
            <column name="customer_id"/>
            <column name="created_time" descending="true"/>
        </createIndex>
        <createIndex indexName="idx_customer_notifications_type" tableName="customer_notifications">
            <column name="type"/>
        </createIndex>
        <createIndex indexName="idx_customer_notifications_reference" tableName="customer_notifications">
            <column name="reference_type"/>
            <column name="reference_id"/>
        </createIndex>
    </changeSet>

    <!-- Add category, is_read, action_url columns to notifications -->
    <changeSet id="notification-010-add-notification-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="notifications"/>
            <not><columnExists tableName="notifications" columnName="category"/></not>
        </preConditions>
        <addColumn tableName="notifications">
            <column name="category" type="VARCHAR(50)"/>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="action_url" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
