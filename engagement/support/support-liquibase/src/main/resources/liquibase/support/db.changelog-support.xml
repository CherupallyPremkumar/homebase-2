        <!-- Seller Guide -->
        <insert tableName="knowledge_base_article">
            <column name="id" value="kb-006"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="support-team"/>
            <column name="created_time" valueDate="2025-06-05T10:00:00"/>
            <column name="last_modified_time" valueDate="2026-03-01T12:00:00"/>
            <column name="version" valueNumeric="4"/>
            <column name="category" value="Seller Guide"/>
            <column name="title" value="Getting started as a HomeBase seller"/>
            <column name="slug" value="seller-getting-started"/>
            <column name="body" value="Start selling on HomeBase in 5 steps: 1. Register — Sign up at seller.homebase.in with your business details. 2. Submit Documents — Upload GST certificate, PAN card, bank account details, and address proof. Verification takes 2-3 business days. 3. List Products — Add products with photos, descriptions, pricing, and inventory. Follow our listing guidelines for best visibility. 4. Receive Orders — Orders appear in your Seller Dashboard. Ship within 2 business days to maintain good ratings. 5. Get Paid — Settlements are processed every 7 days to your registered bank account after deducting commission and TCS. Commission rates: Electronics 8-12%, Fashion 15-20%, Home 10-15%. Need help? Contact seller-support@homebase.in."/>
            <column name="author" value="seller-ops-team"/>
            <column name="view_count" valueNumeric="5670"/>
            <column name="helpful_count" valueNumeric="456"/>
            <column name="not_helpful_count" valueNumeric="23"/>
            <column name="published" valueBoolean="true"/>
            <column name="tags" value='["seller","onboarding","commission","listing","settlement"]'/>
        </insert>
    </changeSet>

</databaseChangeLog>
