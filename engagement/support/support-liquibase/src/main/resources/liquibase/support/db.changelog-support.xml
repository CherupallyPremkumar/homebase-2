        <!-- Returns -->
        <insert tableName="knowledge_base_article">
            <column name="id" value="kb-004"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="support-team"/>
            <column name="created_time" valueDate="2025-06-02T14:00:00"/>
