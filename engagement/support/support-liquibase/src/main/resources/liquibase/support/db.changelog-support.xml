<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- support_tickets (SupportTicketEntity extends AbstractJpaStateEntity) -->
    <changeSet id="support-001-create-support-tickets" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="support_tickets"/></not>
        </preConditions>
        <createTable tableName="support_tickets">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="customer_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="subject" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="category" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="priority" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="description" type="VARCHAR(4000)"/>
            <column name="assigned_agent_id" type="VARCHAR(255)"/>
            <column name="resolved_at" type="TIMESTAMP"/>
            <column name="reopen_count" type="INT" defaultValueNumeric="0"/>
            <column name="sla_breached" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="auto_close_ready" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <createIndex indexName="idx_support_tickets_customer" tableName="support_tickets">
            <column name="customer_id"/>
        </createIndex>
        <createIndex indexName="idx_support_tickets_state" tableName="support_tickets">
            <column name="state_id"/>
        </createIndex>
    </changeSet>

    <!-- ticket_messages (TicketMessageEntity extends BaseJpaEntity, FK to support_tickets) -->
    <changeSet id="support-002-create-ticket-messages" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ticket_messages"/></not>
        </preConditions>
        <createTable tableName="ticket_messages">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="ticket_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="sender_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="sender_type" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="message" type="VARCHAR(4000)"><constraints nullable="false"/></column>
            <column name="message_timestamp" type="TIMESTAMP"/>
            <column name="attachments" type="TEXT"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="ticket_messages" baseColumnNames="ticket_id"
            referencedTableName="support_tickets" referencedColumnNames="id" constraintName="fk_ticket_messages_ticket"/>
        <createIndex indexName="idx_ticket_messages_ticket" tableName="ticket_messages">
            <column name="ticket_id"/>
        </createIndex>
    </changeSet>

    <!-- ticket_activity (SupportTicketActivityLogEntity extends BaseJpaEntity) -->
    <changeSet id="support-003-create-ticket-activity" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ticket_activity"/></not>
        </preConditions>
        <createTable tableName="ticket_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>
    </changeSet>

    <!-- Add channel, related entity, satisfaction, escalation columns to support_tickets -->
    <changeSet id="support-004-add-support-ticket-columns" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="support_tickets"/>
            <not><columnExists tableName="support_tickets" columnName="channel"/></not>
        </preConditions>
        <addColumn tableName="support_tickets">
            <column name="channel" type="VARCHAR(50)" defaultValue="WEB"/>
            <column name="related_entity_type" type="VARCHAR(50)"/>
            <column name="related_entity_id" type="VARCHAR(255)"/>
            <column name="satisfaction_rating" type="INT"/>
            <column name="resolution_notes" type="VARCHAR(2000)"/>
            <column name="escalated" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="escalation_reason" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

    <!-- Indexes on support_tickets -->
    <changeSet id="support-005-add-support-indexes" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="support_tickets"/>
            <not><indexExists indexName="idx_support_order"/></not>
        </preConditions>
        <createIndex indexName="idx_support_order" tableName="support_tickets">
            <column name="order_id"/>
        </createIndex>
        <createIndex indexName="idx_support_priority" tableName="support_tickets">
            <column name="priority"/>
        </createIndex>
        <createIndex indexName="idx_support_agent" tableName="support_tickets">
            <column name="assigned_agent_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- knowledge_base_article (BaseJpaEntity) — self-service help articles -->
    <!-- ================================================================== -->
    <changeSet id="support-006-create-knowledge-base-article" author="homebase">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="knowledge_base_article"/></not>
        </preConditions>
        <createTable tableName="knowledge_base_article">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="category" type="VARCHAR(100)"/>
            <column name="title" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(500)"/>
            <column name="body" type="TEXT"/>
            <column name="author" type="VARCHAR(255)"/>
            <column name="view_count" type="INT" defaultValueNumeric="0"/>
            <column name="helpful_count" type="INT" defaultValueNumeric="0"/>
            <column name="not_helpful_count" type="INT" defaultValueNumeric="0"/>
            <column name="published" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="tags" type="TEXT"/>
        </createTable>
        <createIndex indexName="idx_kb_category" tableName="knowledge_base_article">
            <column name="category"/>
        </createIndex>
        <createIndex indexName="idx_kb_slug" tableName="knowledge_base_article" unique="true">
            <column name="slug"/>
        </createIndex>
        <createIndex indexName="idx_kb_published" tableName="knowledge_base_article">
            <column name="published"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Seed data: 6 knowledge base articles across categories             -->
    <!-- ================================================================== -->
    <changeSet id="support-007-seed-knowledge-base" author="homebase">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM knowledge_base_article WHERE id = 'kb-001'</sqlCheck>
        </preConditions>

        <!-- Getting Started -->
        <insert tableName="knowledge_base_article">
            <column name="id" value="kb-001"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="support-team"/>
            <column name="created_time" valueDate="2025-06-01T10:00:00"/>
            <column name="last_modified_time" valueDate="2025-06-01T10:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="category" value="Getting Started"/>
            <column name="title" value="How to create your HomeBase account"/>
            <column name="slug" value="how-to-create-account"/>
            <column name="body" value="Welcome to HomeBase! Follow these steps to get started: 1. Visit homebase.in and click 'Sign Up'. 2. Enter your mobile number — you will receive an OTP for verification. 3. Fill in your name, email address, and create a password. 4. Add your delivery address (you can add multiple addresses later). 5. Start browsing products! Your account is ready for shopping. Need help? Contact support@homebase.in or call 1800-123-4567."/>
            <column name="author" value="support-team"/>
            <column name="view_count" valueNumeric="4520"/>
            <column name="helpful_count" valueNumeric="389"/>
            <column name="not_helpful_count" valueNumeric="12"/>
            <column name="published" valueBoolean="true"/>
            <column name="tags" value='["signup","registration","new-user","onboarding"]'/>
        </insert>

        <!-- Orders -->
        <insert tableName="knowledge_base_article">
            <column name="id" value="kb-002"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="support-team"/>
            <column name="created_time" valueDate="2025-06-01T10:30:00"/>
            <column name="last_modified_time" valueDate="2026-01-15T09:00:00"/>
            <column name="version" valueNumeric="2"/>
            <column name="category" value="Orders"/>
            <column name="title" value="How to track your order"/>
            <column name="slug" value="how-to-track-order"/>
            <column name="body" value="Track your HomeBase order in 3 easy ways: 1. My Orders page — Go to My Account > My Orders. Click on the order to see real-time tracking with carrier updates. 2. Tracking link — You will receive an SMS and email with a tracking link when your order is shipped. 3. Carrier website — Use the AWB (tracking) number from your order details on the carrier's website (Delhivery, BlueDart, DTDC, etc.). Tracking updates are refreshed every 2 hours. If tracking has not updated in 24 hours, please contact support."/>
            <column name="author" value="support-team"/>
            <column name="view_count" valueNumeric="8930"/>
            <column name="helpful_count" valueNumeric="712"/>
            <column name="not_helpful_count" valueNumeric="45"/>
            <column name="published" valueBoolean="true"/>
            <column name="tags" value='["tracking","order-status","shipping","delivery"]'/>
        </insert>

        <!-- Payments -->
        <insert tableName="knowledge_base_article">
            <column name="id" value="kb-003"/>
            <column name="tenant" value="homebase"/>
            <column name="created_by" value="support-team"/>
            <column name="created_time" valueDate="2025-06-02T11:00:00"/>
            <column name="last_modified_time" valueDate="2025-06-02T11:00:00"/>
            <column name="version" valueNumeric="0"/>
            <column name="category" value="Payments"/>
            <column name="title" value="Payment methods accepted on HomeBase"/>
            <column name="slug" value="payment-methods"/>
            <column name="body" value="HomeBase accepts the following payment methods: UPI — Google Pay, PhonePe, Paytm, BHIM. Credit/Debit Cards — Visa, MasterCard, RuPay, Amex. Net Banking — All major Indian banks. Wallets — Paytm, Amazon Pay, MobiKwik. Cash on Delivery (COD) — Available for orders up to Rs.25,000. EMI — No-cost EMI available on select cards for orders above Rs.3,000. All online payments are secured with 256-bit SSL encryption and 3D Secure authentication."/>
