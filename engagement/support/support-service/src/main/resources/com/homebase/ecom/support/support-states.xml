<?xml version="1.0" encoding="UTF-8"?>
<states>
  <scripting-strategy componentName="ognlScriptingStrategy"/>
  <default-transition-action componentName="supportBaseTransitionAction"/>

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <!-- ================================================================ -->
  <!-- Event definitions with ACLs and payload types                     -->
  <!-- ================================================================ -->

  <event-information eventId='create' meta-acls="CUSTOMER,SYSTEM" meta-bodyType="com.homebase.ecom.support.dto.CreateTicketPayload"/>
  <event-information eventId='assignAgent' meta-acls="SUPPORT_LEAD,SYSTEM" meta-bodyType="com.homebase.ecom.support.dto.AssignAgentPayload"/>
  <event-information eventId='reply' meta-acls="SUPPORT_AGENT,CUSTOMER" meta-bodyType="com.homebase.ecom.support.dto.ReplyPayload"/>
  <event-information eventId='startWork' meta-acls="SUPPORT_AGENT" meta-bodyType="com.homebase.ecom.support.dto.StartWorkPayload"/>
  <event-information eventId='waitOnCustomer' meta-acls="SUPPORT_AGENT" meta-bodyType="com.homebase.ecom.support.dto.WaitOnCustomerPayload"/>
  <event-information eventId='resumeWork' meta-acls="SUPPORT_AGENT,CUSTOMER" meta-bodyType="com.homebase.ecom.support.dto.ReplyPayload"/>
  <event-information eventId='escalate' meta-acls="SUPPORT_AGENT,CUSTOMER" meta-bodyType="com.homebase.ecom.support.dto.EscalatePayload"/>
  <event-information eventId='resolve' meta-acls="SUPPORT_AGENT" meta-bodyType="com.homebase.ecom.support.dto.ResolveTicketPayload"/>
  <event-information eventId='close' meta-acls="SYSTEM,SUPPORT_AGENT" meta-bodyType="com.homebase.ecom.support.dto.CloseTicketPayload"/>
  <event-information eventId='reopen' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.support.dto.ReopenTicketPayload"/>

  <flow id='support-flow' default='true'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="supportEntryAction" />
    <exit-action componentName="supportExitAction" />

    <!-- ================================================================ -->
    <!-- OPEN: Ticket created, awaiting agent assignment                   -->
    <!-- ================================================================ -->
    <status id='OPEN' initialState='true' meta-mainPath="true"
            description="Support ticket opened, awaiting agent assignment">
      <on eventId='assignAgent'
          componentName='supportAssignAgentAction'
          newStateId='ASSIGNED'
          meta-mainPath="true"
          meta-acls="SUPPORT_LEAD,SYSTEM"/>
      <on eventId='escalate'
          componentName='supportEscalateAction'
          newStateId='ESCALATED'
          meta-acls="CUSTOMER"/>
    </status>

    <!-- ================================================================ -->
    <!-- ASSIGNED: Agent assigned, not yet started working                 -->
    <!-- ================================================================ -->
    <status id='ASSIGNED' meta-mainPath="true"
            description="Ticket assigned to a support agent">
      <on eventId='startWork'
          componentName='supportStartWorkAction'
          newStateId='IN_PROGRESS'
          meta-mainPath="true"
          meta-acls="SUPPORT_AGENT"/>
      <on eventId='reply'
          componentName='supportReplyAction'
          newStateId='ASSIGNED'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
      <on eventId='escalate'
          componentName='supportEscalateAction'
          newStateId='ESCALATED'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
      <on eventId='resolve'
          componentName='supportResolveAction'
          newStateId='RESOLVED'
          meta-acls="SUPPORT_AGENT"/>
    </status>

    <!-- ================================================================ -->
    <!-- IN_PROGRESS: Agent actively working on the ticket                 -->
    <!-- ================================================================ -->
    <status id='IN_PROGRESS' meta-mainPath="true"
            description="Agent actively working on the ticket">
      <on eventId='reply'
          componentName='supportReplyAction'
          newStateId='IN_PROGRESS'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
      <on eventId='waitOnCustomer'
          componentName='supportWaitOnCustomerAction'
          newStateId='WAITING_ON_CUSTOMER'
          meta-acls="SUPPORT_AGENT"/>
      <on eventId='escalate'
          componentName='supportEscalateAction'
          newStateId='ESCALATED'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
      <on eventId='resolve'
          componentName='supportResolveAction'
          newStateId='RESOLVED'
          meta-mainPath="true"
          meta-acls="SUPPORT_AGENT"/>
    </status>

    <!-- ================================================================ -->
    <!-- WAITING_ON_CUSTOMER: Agent waiting for customer response          -->
    <!-- ================================================================ -->
    <status id='WAITING_ON_CUSTOMER'
            description="Waiting for customer response">
      <on eventId='resumeWork'
          componentName='supportReplyAction'
          newStateId='IN_PROGRESS'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
      <on eventId='resolve'
          componentName='supportResolveAction'
          newStateId='RESOLVED'
          meta-acls="SUPPORT_AGENT"/>
      <on eventId='escalate'
          componentName='supportEscalateAction'
          newStateId='ESCALATED'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
    </status>

    <!-- ================================================================ -->
    <!-- ESCALATED: Ticket escalated to senior support or supervisor       -->
    <!-- ================================================================ -->
    <status id='ESCALATED'
            description="Ticket escalated to senior support or supervisor">
      <on eventId='assignAgent'
          componentName='supportAssignAgentAction'
          newStateId='ASSIGNED'
          meta-acls="SUPPORT_LEAD,SYSTEM"/>
      <on eventId='resolve'
          componentName='supportResolveAction'
          newStateId='RESOLVED'
          meta-acls="SUPPORT_AGENT"/>
      <on eventId='reply'
          componentName='supportReplyAction'
          newStateId='ESCALATED'
          meta-acls="SUPPORT_AGENT,CUSTOMER"/>
    </status>

    <!-- ================================================================ -->
    <!-- RESOLVED: Ticket resolved, awaiting auto-close or reopen          -->
    <!-- ================================================================ -->
    <status id='RESOLVED' meta-mainPath="true"
            description="Ticket resolved, awaiting customer confirmation or auto-close">
      <on eventId='reopen'
          componentName='supportReopenAction'
          newStateId='REOPENED'
          meta-acls="CUSTOMER"/>
      <on eventId='close'
          componentName='supportCloseAction'
          newStateId='CLOSED'
          meta-mainPath="true"
          meta-acls="SYSTEM,SUPPORT_AGENT"/>
    </status>

    <!-- ================================================================ -->
    <!-- CLOSED: Terminal state                                            -->
    <!-- ================================================================ -->
    <status id='CLOSED' description="Ticket closed and archived">
      <!-- Terminal state — no transitions out -->
    </status>

    <!-- ================================================================ -->
    <!-- REOPENED: Customer reopened a resolved ticket                      -->
    <!-- ================================================================ -->
    <status id='REOPENED'
            description="Ticket reopened by customer after resolution">
      <on eventId='assignAgent'
          componentName='supportAssignAgentAction'
          newStateId='ASSIGNED'
          meta-acls="SUPPORT_LEAD,SYSTEM"/>
      <on eventId='escalate'
          componentName='supportEscalateAction'
          newStateId='ESCALATED'
          meta-acls="CUSTOMER"/>
    </status>

    <!-- ================================================================ -->
    <!-- AUTO-STATES: SLA and Auto-Close checks                            -->
    <!-- ================================================================ -->

    <!--
      CHECK_SLA: After assignment, check if response time exceeds SLA.
      If slaBreached is true -> ESCALATED
      Else -> stays in current state (IN_PROGRESS)
    -->
    <auto-state id='CHECK_SLA'
                componentName='ifAction'
                condition='slaBreached == true'
                then='breached'
                else='withinSla'>
      <on eventId='breached' newStateId='ESCALATED'/>
      <on eventId='withinSla' newStateId='IN_PROGRESS'/>
    </auto-state>

    <!--
      CHECK_AUTO_CLOSE: After resolution, check if auto-close days have passed.
      If autoCloseReady is true -> CLOSED
      Else -> stays RESOLVED
    -->
    <auto-state id='CHECK_AUTO_CLOSE'
                componentName='ifAction'
                condition='autoCloseReady == true'
                then='autoClose'
                else='stayResolved'>
      <on eventId='autoClose' newStateId='CLOSED'/>
      <on eventId='stayResolved' newStateId='RESOLVED'/>
    </auto-state>

    <!-- BDD test terminal state -->
    <manual-state id='__TERMINAL_STATE__' description="Terminal state for activity completion testing">
    </manual-state>
  </flow>
</states>
