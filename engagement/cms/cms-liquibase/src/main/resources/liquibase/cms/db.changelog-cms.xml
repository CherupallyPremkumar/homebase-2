<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- ================================================================== -->
    <!-- cms_pages — STM-enabled page entity (DRAFT→PUBLISHED→ARCHIVED)     -->
    <!-- ================================================================== -->
    <changeSet id="cms-001-create-cms-pages" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_pages"/></not></preConditions>
        <createTable tableName="cms_pages">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <!-- STM columns -->
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)" defaultValue="DRAFT"/>
            <!-- Domain columns -->
            <column name="slug" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="body" type="TEXT"/>
            <column name="page_type" type="VARCHAR(255)"/>
            <column name="layout_type" type="VARCHAR(50)" defaultValue="custom"/>
            <column name="meta_title" type="VARCHAR(255)"/>
            <column name="meta_description" type="VARCHAR(255)"/>
            <column name="published" type="BOOLEAN"/>
            <column name="published_at" type="TIMESTAMP"/>
        </createTable>
        <addUniqueConstraint tableName="cms_pages" columnNames="slug" constraintName="uk_cms_pages_slug"/>
    </changeSet>

    <!-- ================================================================== -->
    <!-- banners — promotional banners with CMS_MEDIA FK                    -->
    <!-- ================================================================== -->
    <changeSet id="cms-002-create-banners" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="banners"/></not></preConditions>
        <createTable tableName="banners">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="image_url" type="VARCHAR(255)"/>
            <column name="mobile_image_url" type="VARCHAR(255)"/>
            <column name="media_id" type="VARCHAR(255)"/>
            <column name="mobile_media_id" type="VARCHAR(255)"/>
            <column name="link_url" type="VARCHAR(255)"/>
            <column name="position" type="VARCHAR(255)"/>
            <column name="display_order" type="INT" defaultValueNumeric="0"/>
            <column name="active_from" type="TIMESTAMP"/>
            <column name="active_to" type="TIMESTAMP"/>
            <column name="active" type="BOOLEAN"/>
            <column name="click_count" type="INT" defaultValueNumeric="0"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- announcement — system/feature/policy announcements                 -->
    <!-- ================================================================== -->
    <changeSet id="cms-003-create-announcement" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="announcement"/></not></preConditions>
        <createTable tableName="announcement">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="title" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="message" type="TEXT"/>
            <column name="announcement_type" type="VARCHAR(50)"/>
            <column name="target_audience" type="VARCHAR(50)"/>
            <column name="priority" type="VARCHAR(20)" defaultValue="NORMAL"/>
            <column name="status" type="VARCHAR(50)" defaultValue="DRAFT"/>
            <column name="scheduled_date" type="TIMESTAMP"/>
            <column name="expiry_date" type="TIMESTAMP"/>
            <column name="action_url" type="VARCHAR(500)"/>
            <column name="action_label" type="VARCHAR(100)"/>
            <column name="dismissible" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <createIndex indexName="idx_announcement_status" tableName="announcement"><column name="status"/></createIndex>
        <createIndex indexName="idx_announcement_type" tableName="announcement"><column name="announcement_type"/></createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_block — block-based page composition (jsonb data)              -->
    <!-- ================================================================== -->
    <changeSet id="cms-004-create-cms-block" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_block"/></not></preConditions>
        <createTable tableName="cms_block">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="page_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="block_type" type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="data" type="JSONB"><constraints nullable="false"/></column>
            <column name="sort_order" type="INT" defaultValueNumeric="0"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="cms_block" baseColumnNames="page_id"
            referencedTableName="cms_pages" referencedColumnNames="id" constraintName="fk_cms_block_page"/>
        <createIndex indexName="idx_cms_block_page" tableName="cms_block"><column name="page_id"/></createIndex>
        <createIndex indexName="idx_cms_block_type" tableName="cms_block"><column name="block_type"/></createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_page_version — version snapshots for rollback                  -->
    <!-- ================================================================== -->
    <changeSet id="cms-005-create-cms-page-version" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_page_version"/></not></preConditions>
        <createTable tableName="cms_page_version">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="page_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="version_number" type="INT"><constraints nullable="false"/></column>
            <column name="blocks_snapshot" type="JSONB"/>
            <column name="published_by" type="VARCHAR(255)"/>
            <column name="published_at" type="TIMESTAMP"/>
            <column name="change_summary" type="VARCHAR(500)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="cms_page_version" baseColumnNames="page_id"
            referencedTableName="cms_pages" referencedColumnNames="id" constraintName="fk_cms_version_page"/>
        <createIndex indexName="idx_cms_version_page" tableName="cms_page_version"><column name="page_id"/></createIndex>
        <addUniqueConstraint tableName="cms_page_version" columnNames="page_id, version_number" constraintName="uk_cms_version_page_num"/>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_schedule — publish/unpublish scheduling (timestamps in UTC)    -->
    <!-- ================================================================== -->
    <changeSet id="cms-006-create-cms-schedule" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_schedule"/></not></preConditions>
        <createTable tableName="cms_schedule">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="page_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="publish_at" type="TIMESTAMP"><constraints nullable="false"/></column>
            <column name="unpublish_at" type="TIMESTAMP"/>
            <column name="timezone" type="VARCHAR(50)" defaultValue="Asia/Kolkata"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="executed" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="cms_schedule" baseColumnNames="page_id"
            referencedTableName="cms_pages" referencedColumnNames="id" constraintName="fk_cms_schedule_page"/>
        <createIndex indexName="idx_cms_schedule_page" tableName="cms_schedule"><column name="page_id"/></createIndex>
        <createIndex indexName="idx_cms_schedule_publish" tableName="cms_schedule"><column name="publish_at"/></createIndex>
        <sql>COMMENT ON COLUMN cms_schedule.publish_at IS 'Stored as UTC. Use timezone column for display conversion only.';</sql>
        <sql>COMMENT ON COLUMN cms_schedule.unpublish_at IS 'Stored as UTC. Use timezone column for display conversion only.';</sql>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_media — media asset library (S3 + CDN)                         -->
    <!-- ================================================================== -->
    <changeSet id="cms-007-create-cms-media" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_media"/></not></preConditions>
        <createTable tableName="cms_media">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="file_key" type="VARCHAR(500)"><constraints nullable="false"/></column>
            <column name="original_name" type="VARCHAR(255)"/>
            <column name="cdn_url" type="VARCHAR(1000)"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="file_size_bytes" type="BIGINT"/>
            <column name="width" type="INT"/>
            <column name="height" type="INT"/>
            <column name="alt_text" type="VARCHAR(500)"/>
            <column name="folder" type="VARCHAR(255)" defaultValue="general"/>
            <column name="tags" type="VARCHAR(500)"/>
        </createTable>
        <createIndex indexName="idx_cms_media_folder" tableName="cms_media"><column name="folder"/></createIndex>
        <createIndex indexName="idx_cms_media_mime" tableName="cms_media"><column name="mime_type"/></createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_page_activity — STM activity log with full audit trail          -->
    <!-- ================================================================== -->
    <changeSet id="cms-008-create-cms-page-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_page_activity"/></not></preConditions>
        <createTable tableName="cms_page_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="cms_page_id" type="VARCHAR(255)"/>
            <column name="action_type" type="VARCHAR(255)"/>
            <column name="comment" type="TEXT"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="performed_by" type="VARCHAR(255)"/>
            <column name="performed_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="previous_state" type="VARCHAR(100)"/>
            <column name="new_state" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- cms_seo_meta — SEO metadata (OG, Twitter, JSON-LD, robots)         -->
    <!-- ================================================================== -->
    <changeSet id="cms-009-create-cms-seo-meta" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="cms_seo_meta"/></not></preConditions>
        <createTable tableName="cms_seo_meta">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="page_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="og_title" type="VARCHAR(255)"/>
            <column name="og_description" type="VARCHAR(500)"/>
            <column name="og_image_url" type="VARCHAR(1000)"/>
            <column name="og_type" type="VARCHAR(50)" defaultValue="website"/>
            <column name="twitter_card" type="VARCHAR(50)" defaultValue="summary_large_image"/>
            <column name="structured_data" type="JSONB"/>
            <column name="canonical_url" type="VARCHAR(1000)"/>
            <column name="robots" type="VARCHAR(100)" defaultValue="index,follow"/>
            <column name="hreflang" type="VARCHAR(500)"/>
            <column name="keywords" type="VARCHAR(500)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="cms_seo_meta" baseColumnNames="page_id"
            referencedTableName="cms_pages" referencedColumnNames="id" constraintName="fk_cms_seo_meta_page"/>
        <createIndex indexName="idx_cms_seo_meta_page" tableName="cms_seo_meta"><column name="page_id"/></createIndex>
    </changeSet>

    <!-- ================================================================== -->
    <!-- Foreign keys — banner ↔ cms_media                                  -->
    <!-- ================================================================== -->
    <changeSet id="cms-010-add-banner-media-fk" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="banners"/>
            <tableExists tableName="cms_media"/>
            <columnExists tableName="banners" columnName="media_id"/>
        </preConditions>
        <addForeignKeyConstraint baseTableName="banners" baseColumnNames="media_id"
            referencedTableName="cms_media" referencedColumnNames="id" constraintName="fk_banner_media"/>
        <addForeignKeyConstraint baseTableName="banners" baseColumnNames="mobile_media_id"
            referencedTableName="cms_media" referencedColumnNames="id" constraintName="fk_banner_mobile_media"/>
    </changeSet>

    <!-- ================================================================== -->
    <!-- STM columns for banners table                                      -->
    <!-- ================================================================== -->
    <changeSet id="cms-011-add-stm-columns-to-banners" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="banners"/>
            <not><columnExists tableName="banners" columnName="state_id"/></not>
        </preConditions>
        <addColumn tableName="banners">
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)" defaultValue="DRAFT"/>
        </addColumn>
    </changeSet>

    <!-- ================================================================== -->
    <!-- banner_activity — STM activity log for banners                     -->
    <!-- ================================================================== -->
    <changeSet id="cms-012-create-banner-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="banner_activity"/></not></preConditions>
        <createTable tableName="banner_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="banner_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="TEXT"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="performed_by" type="VARCHAR(255)"/>
            <column name="performed_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="previous_state" type="VARCHAR(100)"/>
            <column name="new_state" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <!-- ================================================================== -->
    <!-- STM columns for announcement table                                 -->
    <!-- ================================================================== -->
    <changeSet id="cms-013-add-stm-columns-to-announcement" author="homebase">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="announcement"/>
            <not><columnExists tableName="announcement" columnName="state_entry_time"/></not>
        </preConditions>
        <addColumn tableName="announcement">
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)" defaultValue="DRAFT"/>
        </addColumn>
    </changeSet>

    <!-- ================================================================== -->
    <!-- announcement_activity — STM activity log for announcements          -->
    <!-- ================================================================== -->
    <changeSet id="cms-014-create-announcement-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="announcement_activity"/></not></preConditions>
        <createTable tableName="announcement_activity">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="announcement_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="TEXT"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="performed_by" type="VARCHAR(255)"/>
            <column name="performed_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="previous_state" type="VARCHAR(100)"/>
            <column name="new_state" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
