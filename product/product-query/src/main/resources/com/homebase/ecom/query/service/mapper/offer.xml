<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Offer">
    <resultMap id="offerResultMap" type="com.homebase.ecom.dto.OfferDto">
    <id property="id" column="id"/>
    <result property="productId" column="product_id"/>
    <result property="sellerId" column="seller_id"/>
    <result property="active" column="active"/>
    <association property="price" javaType="com.homebase.ecom.shared.Money">
        <result property="amount" column="price_amount"/>
        <result property="currency" column="currency"/>
    </association>
</resultMap>

    <select id="getByProductIdCount" resultType="int">
        SELECT COUNT(*)
        FROM offers
        <where>
            <if test="productId != null">
                product_id = #{productId}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
        </where>
    </select>

    <select id="getByProductId" resultMap="offerResultMap">
        SELECT
        id,
        product_id,
        seller_id,
        price as price_amount,
        currency,
        active
        FROM offers
        <where>
            <if test="productId != null">
                product_id = #{productId}
            </if>
            <if test="active != null">
                AND active = #{active}
            </if>
        </where>
        <if test="orderby != null">
            ORDER BY ${orderby}
        </if>
        <if test="pagination != null">
            ${pagination}
        </if>
    </select>

</mapper>