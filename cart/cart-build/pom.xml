<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.homebase.ecom.cart</groupId>
        <artifactId>cart-parent</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>cart-build</artifactId>
    <packaging>jar</packaging>

    <name>Cart Build - Standalone Cart Service</name>
    <description>Aggregates all cart service modules into a single executable executable</description>

    <dependencies>
        <!-- Cart Service Modules -->
        <dependency>
            <groupId>com.homebase.ecom.cart</groupId>
            <artifactId>cart-api</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.cart</groupId>
            <artifactId>cart-domain</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.cart</groupId>
            <artifactId>cart-infrastructure</artifactId>
            <version>${revision}</version>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.cart</groupId>
            <artifactId>cart-service</artifactId>
            <version>${revision}</version>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom</groupId>
            <artifactId>cart-query-service</artifactId>
            <version>${revision}</version>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.cart</groupId>
            <artifactId>cart-jobs</artifactId>
        </dependency>

        <!-- Spring Boot and Chenile Infrastructure -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>chenile-http</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- Database Support -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.shared</groupId>
            <artifactId>shared-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>chenile-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>security-interceptor</artifactId>
        </dependency>

    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <mainClass>com.homebase.ecom.cart.CartBuildApplication</mainClass>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
