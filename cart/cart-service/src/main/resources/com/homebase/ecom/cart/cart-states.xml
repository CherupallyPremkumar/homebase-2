<?xml version="1.0" encoding="UTF-8"?>
<states>

  <!-- ================================================================ -->
  <!-- Event definitions with ACLs and payload types                     -->
  <!-- ================================================================ -->
  <event-information eventId='create' meta-acls="CUSTOMER,SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='addItem' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.AddItemCartPayload"/>
  <event-information eventId='removeItem' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.RemoveItemCartPayload"/>
  <event-information eventId='updateQuantity' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.UpdateQuantityCartPayload"/>
  <event-information eventId='applyCoupon' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.ApplyCouponCartPayload"/>
  <event-information eventId='removeCoupon' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.RemoveCouponCartPayload"/>
  <event-information eventId='initiateCheckout' meta-acls="CUSTOMER" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancelCheckout' meta-acls="CUSTOMER" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='completeCheckout' meta-acls="SYSTEM" meta-bodyType="com.homebase.ecom.cart.dto.CompleteCheckoutCartPayload"/>
  <event-information eventId='abandon' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='expire' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='reactivate' meta-acls="CUSTOMER" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='merge' meta-acls="CUSTOMER" meta-bodyType="com.homebase.ecom.cart.dto.MergeCartPayload"/>
  <event-information eventId='markMerged' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='flagUnavailable' meta-acls="SYSTEM" meta-bodyType="com.homebase.ecom.cart.dto.FlagUnavailableCartPayload"/>
  <event-information eventId='refreshPricing' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='expireCoupon' meta-acls="SYSTEM" meta-bodyType="com.homebase.ecom.cart.dto.ExpireCouponCartPayload"/>

  <flow id='cart-flow' default='true'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="cartEntryAction"/>
    <exit-action componentName="cartExitAction"/>

    <!-- ================================================================ -->
    <!-- ACTIVE: Cart created, user adding/removing items                  -->
    <!-- ================================================================ -->
    <manual-state id='ACTIVE' initialState='true' meta-mainPath="true"
                  description="Cart created, user shopping — adding/removing items">
      <on eventId='addItem'
          componentName='cartAddItemAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='removeItem'
          componentName='cartRemoveItemAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='updateQuantity'
          componentName='cartUpdateQuantityAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='applyCoupon'
          componentName='cartApplyCouponAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='removeCoupon'
          componentName='cartRemoveCouponAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='merge'
          componentName='cartMergeAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='initiateCheckout'
          componentName='cartInitiateCheckoutAction'
          newStateId='CHECKOUT_INITIATED'
          meta-mainPath="true" meta-acls="CUSTOMER"/>
      <on eventId='abandon'
          componentName='cartAbandonAction'
          newStateId='ABANDONED'
          meta-acls="SYSTEM"/>
      <on eventId='expire'
          componentName='cartExpireAction'
          newStateId='EXPIRED'
          meta-acls="SYSTEM"/>
      <on eventId='markMerged'
          componentName='cartMarkMergedAction'
          newStateId='MERGED'
          meta-acls="SYSTEM"/>
      <on eventId='flagUnavailable'
          componentName='cartFlagUnavailableAction'
          newStateId='ACTIVE'
          meta-acls="SYSTEM"/>
      <on eventId='refreshPricing'
          componentName='cartRefreshPricingAction'
          newStateId='ACTIVE'
          meta-acls="SYSTEM"/>
      <on eventId='expireCoupon'
          componentName='cartExpireCouponAction'
          newStateId='ACTIVE'
          meta-acls="SYSTEM"/>
    </manual-state>

    <!-- ================================================================ -->
    <!-- CHECKOUT_INITIATED: Cart locked for checkout                      -->
    <!-- Checkout service orchestrates payment, then tells cart "done"     -->
    <!-- ================================================================ -->
    <manual-state id='CHECKOUT_INITIATED' meta-mainPath="true"
                  description="Checkout initiated, inventory reserved, awaiting checkout completion">
      <on eventId='completeCheckout'
          componentName='cartCompleteCheckoutAction'
          newStateId='CHECKOUT_COMPLETED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='cancelCheckout'
          componentName='cartCancelCheckoutAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='abandon'
          componentName='cartAbandonAction'
          newStateId='ABANDONED'
          meta-acls="SYSTEM"/>
      <on eventId='expire'
          componentName='cartExpireAction'
          newStateId='EXPIRED'
          meta-acls="SYSTEM"/>
    </manual-state>

    <!-- ================================================================ -->
    <!-- CHECKOUT_COMPLETED: Order created from cart — terminal            -->
    <!-- ================================================================ -->
    <manual-state id='CHECKOUT_COMPLETED' meta-mainPath="true"
                  description="Checkout completed, order created from cart">
    </manual-state>

    <!-- ================================================================ -->
    <!-- ABANDONED: User abandoned cart — can reactivate                   -->
    <!-- ================================================================ -->
    <manual-state id='ABANDONED'
                  description="Cart abandoned by user or system timeout">
      <on eventId='reactivate'
          componentName='cartReactivateAction'
          newStateId='ACTIVE'
          meta-acls="CUSTOMER"/>
      <on eventId='expire'
          componentName='cartExpireAction'
          newStateId='EXPIRED'
          meta-acls="SYSTEM"/>
    </manual-state>

    <!-- ================================================================ -->
    <!-- EXPIRED: Cart expired — terminal                                  -->
    <!-- ================================================================ -->
    <manual-state id='EXPIRED'
                  description="Cart expired due to inactivity or TTL">
    </manual-state>

    <!-- ================================================================ -->
    <!-- MERGED: Cart merged into another cart — terminal                   -->
    <!-- ================================================================ -->
    <manual-state id='MERGED'
                  description="Cart merged into another user cart after login">
    </manual-state>

  </flow>
</states>
