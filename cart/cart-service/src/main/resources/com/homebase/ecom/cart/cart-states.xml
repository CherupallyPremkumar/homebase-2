<?xml version="1.0" encoding="UTF-8"?>
<states>
  <enablement-strategy componentName="cartConfigBasedEnablementStrategy"/>
  <default-transition-action componentName="cartBaseTransitionAction"/>

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <flow id='cart-flow' default='true'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="cartEntryAction" />
    <exit-action componentName="cartExitAction" />

    <!-- ========== INITIAL STATE ========== -->
    <status id='CREATED' initialState='true' meta-mainPath="true" description="New cart, no items yet">
      <on eventId='addItem' componentName="cartAddItemAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='mergeCart' componentName="cartMergeCartAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
    </status>

    <!-- ========== MAIN SHOPPING STATE ========== -->
    <status id='ACTIVE' meta-mainPath="true" description="User shopping, adding/removing items">
      <on eventId='addItem' componentName="cartAddItemAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='removeItem' componentName="cartRemoveItemAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='updateQuantity' componentName="cartUpdateQuantityAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='addDeliveryAddress' componentName="cartAddDeliveryAddressAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='applyPromoCode' componentName="cartApplyPromoCodeAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      
      <on eventId='moveToWishlist' componentName="cartMoveToWishlistAction" newStateId='SAVED' meta-acls="CUSTOMER"/>
      
      <on eventId='initiateCheckout' componentName="cartInitiateCheckoutAction" newStateId='LOCKED' meta-mainPath="true" meta-acls="CUSTOMER"/>
      
      <on eventId='sessionTimeout' componentName="cartSessionTimeoutAction" newStateId='ABANDONED' meta-acls="SYSTEM"/>
    </status>

    <!-- ========== SAVED (WISH LIST) ========== -->
    <status id='SAVED' description="Items moved to 'Save for Later'">
      <on eventId='moveToCart' componentName="cartMoveToCartAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
    </status>

    <!-- ========== LOCKED (CHECKOUT INITIATED) ========== -->
    <status id='LOCKED' meta-mainPath="true" description="Checkout initiated, price frozen.">
      <on eventId='reserveInventory' componentName="inventoryReserveAction" newStateId='RESERVED' meta-acls="SYSTEM"/>
      <on eventId='abandonCheckout' componentName="cartAbandonCheckoutAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='lockTimeout' componentName="cartLockTimeoutAction" newStateId='EXPIRED' meta-acls="SYSTEM"/>
    </status>

    <!-- ========== RESERVED (INVENTORY SOFT-BLOCKED) ========== -->
    <status id='RESERVED' meta-mainPath="true" description="Inventory soft-blocked for the user.">
      <on eventId='createPaymentSession' componentName="cartCreatePaymentSessionAction" newStateId='PAYMENT_PENDING' meta-mainPath="true" meta-acls="CUSTOMER,SYSTEM"/>
      <on eventId='inventoryReservationFailed' componentName="cartInventoryReservationFailedAction" newStateId='ACTIVE' meta-acls="SYSTEM"/>
      <on eventId='reserveTimeout' componentName="cartReserveTimeoutAction" newStateId='EXPIRED' meta-acls="SYSTEM"/>
    </status>

    <!-- ========== PAYMENT PENDING ========== -->
    <status id='PAYMENT_PENDING' description="User on gateway, awaiting webhook">
      <!-- Payment successful -->
      <on eventId='paymentSuccess' componentName="cartPaymentSuccessAction" newStateId='CONVERTED' meta-mainPath="true" meta-acls="SYSTEM"/>
      
      <!-- Payment failed -->
      <on eventId='paymentFailed' componentName="cartPaymentFailedAction" newStateId='ACTIVE' meta-acls="SYSTEM"/>
    </status>

    <!-- ========== CONVERTED (SUCCESS) ========== -->
    <status id='CONVERTED' description="✅ Order complete, cart is converted">
      <!-- Terminal state -->
    </status>

    <!-- ========== ABANDONED CART ========== -->
    <status id='ABANDONED' description="User abandoned cart mid-checkout or inactive">
      <on eventId='recoverCart' componentName="cartRecoverCartAction" newStateId='ACTIVE' meta-acls="CUSTOMER"/>
      <on eventId='inventoryRelease' componentName="cartInventoryReleaseAction" meta-acls="SYSTEM" />
    </status>

    <!-- ========== EXPIRED CART ========== -->
    <status id='EXPIRED' description="Cart expired due to lock/TTL, or deleted">
       <!-- Terminal State -->
    </status>
  </flow>
</states>