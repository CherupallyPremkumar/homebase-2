<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- Schema creation -->
    <changeSet id="returnrequest-000-create-schema" author="homebase">
        <sql>CREATE SCHEMA IF NOT EXISTS hm_return_request</sql>
    </changeSet>

    <changeSet id="returnrequest-001-create-returnrequest" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="returnrequest" schemaName="hm_return_request"/></not></preConditions>
        <createTable tableName="returnrequest" schemaName="hm_return_request">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="state_entry_time" type="TIMESTAMP"/>
            <column name="sla_yellow_date" type="TIMESTAMP"/>
            <column name="sla_red_date" type="TIMESTAMP"/>
            <column name="sla_tending_late" type="INT" defaultValueNumeric="0"/>
            <column name="sla_late" type="INT" defaultValueNumeric="0"/>
            <column name="flow_id" type="VARCHAR(100)"/>
            <column name="state_id" type="VARCHAR(100)"/>
            <column name="order_id" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="customer_id" type="VARCHAR(255)"/>
            <column name="items_json" type="VARCHAR(4000)"/>
            <column name="reason" type="VARCHAR(1000)"/>
            <column name="return_type" type="VARCHAR(50)"/>
            <column name="total_refund_amount" type="DECIMAL(19,2)"/>
            <column name="restocking_fee" type="DECIMAL(19,2)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="reviewer_id" type="VARCHAR(255)"/>
            <column name="review_notes" type="VARCHAR(2000)"/>
            <column name="rejection_reason" type="VARCHAR(1000)"/>
            <column name="rejection_comment" type="VARCHAR(2000)"/>
            <column name="warehouse_id" type="VARCHAR(255)"/>
            <column name="condition_on_receipt" type="VARCHAR(255)"/>
            <column name="inspector_id" type="VARCHAR(255)"/>
            <column name="inspector_notes" type="VARCHAR(2000)"/>
            <column name="order_delivery_date" type="TIMESTAMP"/>
            <column name="order_total_value" type="DECIMAL(19,2)"/>
        </createTable>
    </changeSet>

    <changeSet id="returnrequest-002-create-returnrequest-activity" author="homebase">
        <preConditions onFail="MARK_RAN"><not><tableExists tableName="returnrequest_activity" schemaName="hm_return_request"/></not></preConditions>
        <createTable tableName="returnrequest_activity" schemaName="hm_return_request">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP"/>
            <column name="last_modified_by" type="VARCHAR(100)"/>
            <column name="tenant" type="VARCHAR(50)"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="returnrequest_id" type="VARCHAR(255)"/>
            <column name="event_id" type="VARCHAR(255)"/>
            <column name="comment" type="VARCHAR(255)"/>
            <column name="success" type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
