{
  "policies": [
    {
      "id": "policy-001",
      "name": "Order Processing Policy",
      "description": "Policy to control order creation, payment processing, and fulfillment",
      "active": true,
      "defaultEffect": "DENY",
      "rules": [
        {
          "id": "rule-001",
          "name": "Premium Members Can Order",
          "expression": "#customer?.membershipLevel == 'PREMIUM' && #customer?.accountStatus == 'ACTIVE'",
          "effect": "ALLOW",
          "priority": 1,
          "active": true
        },
        {
          "id": "rule-002",
          "name": "Standard Members Order Limit",
          "expression": "#customer?.membershipLevel == 'STANDARD' && #order?.totalAmount <= 5000 && #customer?.accountStatus == 'ACTIVE'",
          "effect": "ALLOW",
          "priority": 2,
          "active": true
        },
        {
          "id": "rule-003",
          "name": "Basic Members Order Limit",
          "expression": "#customer?.membershipLevel == 'BASIC' && #order?.totalAmount <= 1000 && #customer?.accountStatus == 'ACTIVE'",
          "effect": "ALLOW",
          "priority": 3,
          "active": true
        },
        {
          "id": "rule-004",
          "name": "Blacklisted Customers Denied",
          "expression": "#customer?.status == 'BLACKLISTED'",
          "effect": "DENY",
          "priority": 0,
          "active": true
        },
        {
          "id": "rule-005",
          "name": "High Value Orders Require Verification",
          "expression": "#order?.totalAmount > 10000 && #customer?.verificationStatus == 'PENDING'",
          "effect": "ABSTAIN",
          "priority": 4,
          "active": true
        }
      ],
      "transientMap": {}
    },
    {
      "id": "policy-payment-001",
      "name": "Payment Processing Policy",
      "description": "Controls which payment methods are allowed for different customer segments",
      "active": true,
      "defaultEffect": "DENY",
      "rules": [
        {
          "id": "rule-payment-001",
          "name": "Credit Card for All Active Customers",
          "expression": "#paymentMethod == 'CREDIT_CARD' && #customer?.status == 'ACTIVE'",
          "effect": "ALLOW",
          "priority": 1,
          "active": true
        },
        {
          "id": "rule-payment-002",
          "name": "Digital Wallets for Premium Only",
          "expression": "#paymentMethod == 'DIGITAL_WALLET' && #customer?.membershipLevel == 'PREMIUM'",
          "effect": "ALLOW",
          "priority": 2,
          "active": true
        },
        {
          "id": "rule-payment-003",
          "name": "COD for Domestic Orders Only",
          "expression": "#paymentMethod == 'COD' && #order?.shippingCountry == 'DOMESTIC' && #order?.totalAmount <= 2000",
          "effect": "ALLOW",
          "priority": 3,
          "active": true
        },
        {
          "id": "rule-payment-004",
          "name": "Deny Expired Cards",
          "expression": "#paymentMethod == 'CREDIT_CARD' && #card?.expiryDate < T(java.time.LocalDate).now().toString()",
          "effect": "DENY",
          "priority": 0,
          "active": true
        },
        {
          "id": "rule-payment-005",
          "name": "UPI for Mobile App",
          "expression": "#paymentMethod == 'UPI' && #device?.type == 'MOBILE'",
          "effect": "ALLOW",
          "priority": 4,
          "active": true
        }
      ],
      "transientMap": {}
    },
    {
      "id": "policy-return-001",
      "name": "Return & Refund Policy",
      "description": "Controls eligibility for product returns and refunds",
      "active": true,
      "defaultEffect": "DENY",
      "rules": [
        {
          "id": "rule-return-001",
          "name": "30-Day Return Window",
          "expression": "#daysSincePurchase <= 30 && #order?.status != 'CANCELLED' && #product?.category != 'DIGITAL'",
          "effect": "ALLOW",
          "priority": 1,
          "active": true
        },
        {
          "id": "rule-return-002",
          "name": "Premium Members Extended Return",
          "expression": "#customer?.membershipLevel == 'PREMIUM' && #daysSincePurchase <= 60 && #product?.returnable == true",
          "effect": "ALLOW",
          "priority": 2,
          "active": true
        },
        {
          "id": "rule-return-003",
          "name": "No Return on Sale Items",
          "expression": "#product?.onSale == true && #product?.saleExclusions?.contains('NO_RETURN')",
          "effect": "DENY",
          "priority": 0,
          "active": true
        },
        {
          "id": "rule-return-004",
          "name": "Digital Products Non-Returnable",
          "expression": "#product?.category == 'DIGITAL'",
          "effect": "DENY",
          "priority": 0,
          "active": true
        }
      ],
      "transientMap": {}
    },
    {
      "id": "policy-discount-001",
      "name": "Discount & Coupon Policy",
      "description": "Controls which discounts and coupons can be applied",
      "active": true,
      "defaultEffect": "DENY",
      "rules": [
        {
          "id": "rule-discount-001",
          "name": "Valid Coupon Code",
          "expression": "#coupon?.status == 'ACTIVE' && #coupon?.expiryDate > T(java.time.LocalDate).now().toString() && #coupon?.usageCount < #coupon?.maxUsage",
          "effect": "ALLOW",
          "priority": 1,
          "active": true
        },
        {
          "id": "rule-discount-002",
          "name": "Expired Coupon",
          "expression": "#coupon?.expiryDate < T(java.time.LocalDate).now().toString()",
          "effect": "DENY",
          "priority": 0,
          "active": true
        },
        {
          "id": "rule-discount-003",
          "name": "Premium Exclusive Discount",
          "expression": "#coupon?.type == 'PREMIUM_EXCLUSIVE' && #customer?.membershipLevel == 'PREMIUM'",
          "effect": "ALLOW",
          "priority": 2,
          "active": true
        }
      ],
      "transientMap": {}
    }
  ],
