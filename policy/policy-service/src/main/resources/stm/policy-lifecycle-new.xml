<?xml version="1.0" encoding="UTF-8"?>
<states>
<!-- Enablement and default actions are manually wired in PolicyConfiguration -->

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <flow id='policy-flow' default='true'>
    <entry-action componentName="policyEntryAction" />
    <exit-action componentName="policyExitAction" />

    <!-- ========== INITIAL STATE ========== -->
    <status id='DRAFT' initialState='true' description="New policy, not yet submitted">
      <on eventId='submit' componentName="policySubmitAction" newStateId='REVIEW'/>
      <on eventId='activate' componentName="policyActivateAction" newStateId='ACTIVE'/>
    </status>

    <!-- ========== REVIEW STATE ========== -->
    <status id='REVIEW' description="Policy under review">
      <on eventId='approve' componentName="policyApproveAction" newStateId='ACTIVE'/>
      <on eventId='revert' componentName="policyRevertAction" newStateId='DRAFT'/>
    </status>

    <!-- ========== ACTIVE STATE ========== -->
    <status id='ACTIVE' description="Policy is active and being enforced">
      <on eventId='deprecate' componentName="policyDeprecateAction" newStateId='DEPRECATED'/>
      <on eventId='deactivate' componentName="policyDeactivateAction" newStateId='DRAFT'/>
    </status>

    <!-- ========== DEPRECATED STATE ========== -->
    <status id='DEPRECATED' description="Policy is deprecated and no longer enforced">
      <on eventId='activate' componentName="policyActivateAction" newStateId='ACTIVE'/>
    </status>

  </flow>
</states>
