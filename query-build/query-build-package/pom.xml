			<groupId>com.homebase.ecom</groupId>
			<artifactId>shipping-query-service</artifactId>
			<version>${revision}</version>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom</groupId>
			<artifactId>supplier-query-service</artifactId>
			<version>${revision}</version>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.promo</groupId>
			<artifactId>promo-query</artifactId>
			<version>${revision}</version>
