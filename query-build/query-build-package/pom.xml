		</dependency>
		<dependency>
			<groupId>com.homebase.ecom.compliance</groupId>
			<artifactId>compliance-query-service</artifactId>
			<version>${revision}</version>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom</groupId>
			<artifactId>notification-query-service</artifactId>
			<version>${revision}</version>
		</dependency>
		<dependency>
			<groupId>com.homebase.ecom</groupId>
			<artifactId>onboarding-query-service</artifactId>
