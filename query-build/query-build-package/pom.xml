		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>service-registry-service</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
			<artifactId>service-registry-delegate</artifactId>
		</dependency>

		<!-- Security -->
		<dependency>
			<groupId>com.homebase.ecom.shared</groupId>
			<artifactId>shared-security</artifactId>
		</dependency>
		<dependency>
			<groupId>org.chenile</groupId>
