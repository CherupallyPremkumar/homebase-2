    <!--
        Order test data - 8 orders covering STM states from order-states.xml:
        CREATED, PAID, FRAUD_HOLD, SHIPPED, PARTIALLY_SHIPPED, DELIVERED,
        CANCELLED, RETURN_REQUESTED, ON_HOLD, DELIVERY_FAILED

        Shared IDs: ord-1..ord-8 (referenced by payment, shipping, settlement, fulfillment, return)

        NOTE: Columns paid_at, shipped_at, delivered_at, cancelled_at, cancellation_window_ends_at
        are NOT in the orders schema. Timestamps are tracked via state_entry_time and
        order_status_history table. Removed to match actual DB schema.
    -->
    <!-- Minimal user_profiles stub for LEFT JOIN in order queries -->
    <changeSet id="order-test-user-profiles-stub" author="homebase-test">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="user_profiles"/></not>
        </preConditions>
        <createTable tableName="user_profiles">
            <column name="id" type="VARCHAR(255)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="tenant" type="VARCHAR(50)"/>
        </createTable>
        <insert tableName="user_profiles">
            <column name="id" value="user-1"/><column name="email" value="priya@example.com"/><column name="tenant" value="homebase"/>
        </insert>
        <insert tableName="user_profiles">
