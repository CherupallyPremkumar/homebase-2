<?xml version="1.0" encoding="UTF-8"?>
<!-- Query-side STM metadata. Stripped from supplier-lifecycle-service. No componentName/conditions. -->
<states>


  <event-information eventId='disableProducts'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='removeCatalog'    meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='freezeInventory'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancelOrders'     meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='notifyCustomers'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='enableProducts'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='restoreCatalog'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='unfreezeInventory' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='notifySupplier'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='fail'             meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancel'           meta-acls="SYSTEM,ADMIN" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='compensate'       meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='retry'            meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>

  <flow id='suspend-flow' default='true'>

    <manual-state id='INITIATED' initialState='true' meta-mainPath="true"
            description="Supplier suspension saga initiated">
      <on eventId='disableProducts' newStateId='PRODUCTS_DISABLED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='cancel' newStateId='CANCELLING' meta-acls="SYSTEM,ADMIN"/>
    </manual-state>

    <manual-state id='PRODUCTS_DISABLED' meta-mainPath="true"
            description="All supplier products disabled from storefront">
      <on eventId='removeCatalog' newStateId='CATALOG_CLEARED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='CATALOG_CLEARED' meta-mainPath="true"
            description="Supplier catalog entries removed">
      <on eventId='freezeInventory' newStateId='INVENTORY_FROZEN' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='INVENTORY_FROZEN' meta-mainPath="true"
            description="Supplier inventory frozen, no new reservations">
      <on eventId='cancelOrders' newStateId='ORDERS_CANCELLED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='ORDERS_CANCELLED' meta-mainPath="true"
            description="Open orders for supplier cancelled">
      <on eventId='notifyCustomers' newStateId='COMPLETED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='COMPLETED' description="Supplier suspension completed successfully"/>

    <manual-state id='CANCELLING' description="Suspension being cancelled, compensating steps">
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='COMPENSATION_DONE' description="All suspension steps compensated"/>

    <manual-state id='FAILED' description="Supplier suspension failed, can be retried or compensated">
      <on eventId='retry' newStateId='INITIATED' meta-acls="SYSTEM"/>
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </manual-state>

  </flow>

  <flow id='reactivate-flow'>

    <manual-state id='INITIATED' initialState='true' meta-mainPath="true"
            description="Supplier reactivation saga initiated">
      <on eventId='enableProducts' newStateId='PRODUCTS_ENABLED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='cancel' newStateId='CANCELLING' meta-acls="SYSTEM,ADMIN"/>
    </manual-state>

    <manual-state id='PRODUCTS_ENABLED' meta-mainPath="true"
            description="Supplier products re-enabled on storefront">
      <on eventId='restoreCatalog' newStateId='CATALOG_RESTORED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='CATALOG_RESTORED' meta-mainPath="true"
            description="Supplier catalog entries restored">
      <on eventId='unfreezeInventory' newStateId='INVENTORY_UNFROZEN' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='INVENTORY_UNFROZEN' meta-mainPath="true"
            description="Supplier inventory unfrozen, reservations allowed">
      <on eventId='notifySupplier' newStateId='COMPLETED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='COMPLETED' description="Supplier reactivation completed successfully"/>

    <manual-state id='CANCELLING' description="Reactivation being cancelled, compensating steps">
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='COMPENSATION_DONE' description="All reactivation steps compensated"/>

    <manual-state id='FAILED' description="Supplier reactivation failed, can be retried or compensated">
      <on eventId='retry' newStateId='INITIATED' meta-acls="SYSTEM"/>
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </manual-state>

  </flow>
</states>
