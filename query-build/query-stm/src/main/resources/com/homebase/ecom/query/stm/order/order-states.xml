<?xml version="1.0" encoding="UTF-8"?>
<!-- Query-side STM metadata. Stripped from order-service. No componentName/conditions. -->
<states>

  <event-information eventId='paymentSucceeded'    meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.PaymentSucceededOrderPayload"/>
  <event-information eventId='paymentFailed'       meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.PaymentFailedOrderPayload"/>
  <event-information eventId='holdForFraud'        meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.HoldForFraudOrderPayload"/>
  <event-information eventId='clearFraud'          meta-acls="ADMIN,SYSTEM"     meta-bodyType="com.homebase.ecom.order.dto.ClearFraudOrderPayload"/>
  <event-information eventId='confirmFraud'        meta-acls="ADMIN"            meta-bodyType="com.homebase.ecom.order.dto.ConfirmFraudOrderPayload"/>
  <event-information eventId='requestCancellation' meta-acls="CUSTOMER,ADMIN"   meta-bodyType="com.homebase.ecom.order.dto.RequestCancellationOrderPayload"/>
  <event-information eventId='confirmCancellation' meta-acls="ADMIN,SYSTEM"     meta-bodyType="com.homebase.ecom.order.dto.ConfirmCancellationOrderPayload"/>
  <event-information eventId='startProcessing'     meta-acls="SYSTEM,WAREHOUSE" meta-bodyType="com.homebase.ecom.order.dto.StartProcessingOrderPayload"/>
  <event-information eventId='partialShip'         meta-acls="WAREHOUSE"        meta-bodyType="com.homebase.ecom.order.dto.PartialShipOrderPayload"/>
  <event-information eventId='markShipped'         meta-acls="WAREHOUSE"        meta-bodyType="com.homebase.ecom.order.dto.MarkShippedOrderPayload"/>
  <event-information eventId='markDelivered'       meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.MarkDeliveredOrderPayload"/>
  <event-information eventId='confirmDelivery'     meta-acls="CUSTOMER,SYSTEM"  meta-bodyType="com.homebase.ecom.order.dto.ConfirmDeliveryOrderPayload"/>
  <event-information eventId='deliveryFailed'      meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.DeliveryFailedOrderPayload"/>
  <event-information eventId='requestRefund'       meta-acls="CUSTOMER,ADMIN"   meta-bodyType="com.homebase.ecom.order.dto.RequestRefundOrderPayload"/>
  <event-information eventId='completeRefund'      meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.order.dto.CompleteRefundOrderPayload"/>
  <event-information eventId='placeOnHold'         meta-acls="ADMIN"            meta-bodyType="com.homebase.ecom.order.dto.PlaceOnHoldOrderPayload"/>
  <event-information eventId='releaseHold'         meta-acls="ADMIN"            meta-bodyType="com.homebase.ecom.order.dto.ReleaseHoldOrderPayload"/>
  <event-information eventId='requestReturn'       meta-acls="CUSTOMER"         meta-bodyType="com.homebase.ecom.order.dto.RequestReturnOrderPayload"/>

  <flow id='order-flow' default='true'>

    <manual-state id='CREATED' initialState='true' meta-mainPath="true"
                  description="Order created, awaiting payment initiation">
      <on eventId='paymentSucceeded' newStateId='PAID' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='paymentFailed' newStateId='PAYMENT_FAILED' meta-acls="SYSTEM"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='PAYMENT_PENDING' meta-mainPath="true"
                  description="Payment initiated, awaiting confirmation from payment gateway">
      <on eventId='paymentSucceeded' newStateId='PAID' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='paymentFailed' newStateId='PAYMENT_FAILED' meta-acls="SYSTEM"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='PAYMENT_FAILED'
                  description="Payment failed, awaiting retry or cancellation">
      <on eventId='paymentSucceeded' newStateId='PAID' meta-acls="SYSTEM"/>
      <on eventId='requestCancellation' newStateId='CANCELLED' meta-acls="CUSTOMER,ADMIN,SYSTEM"/>
    </manual-state>

    <manual-state id='PAID' meta-mainPath="true"
                  description="Payment confirmed, routing through fraud check">
      <on eventId='startProcessing' newStateId='PROCESSING' meta-mainPath="true" meta-acls="SYSTEM,WAREHOUSE"/>
      <on eventId='holdForFraud' newStateId='FRAUD_HOLD' meta-acls="SYSTEM"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='FRAUD_HOLD'
                  description="Order held for fraud review by risk team">
      <on eventId='clearFraud' newStateId='PROCESSING' meta-mainPath="true" meta-acls="ADMIN,SYSTEM"/>
      <on eventId='confirmFraud' newStateId='CANCELLED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='PROCESSING' meta-mainPath="true"
                  description="Order being processed at warehouse">
      <on eventId='markShipped' newStateId='SHIPPED' meta-mainPath="true" meta-acls="WAREHOUSE"/>
      <on eventId='partialShip' newStateId='PARTIALLY_SHIPPED' meta-acls="WAREHOUSE"/>
      <on eventId='placeOnHold' newStateId='ON_HOLD' meta-acls="ADMIN"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='ON_HOLD'
                  description="Order placed on hold by admin">
      <on eventId='releaseHold' newStateId='PROCESSING' meta-mainPath="true" meta-acls="ADMIN"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='PARTIALLY_SHIPPED'
                  description="Some items shipped, remaining items still processing">
      <on eventId='markShipped' newStateId='SHIPPED' meta-mainPath="true" meta-acls="WAREHOUSE"/>
      <on eventId='partialShip' newStateId='PARTIALLY_SHIPPED' meta-acls="WAREHOUSE"/>
    </manual-state>

    <manual-state id='SHIPPED' meta-mainPath="true"
                  description="Order shipped, in transit to customer">
      <on eventId='markDelivered' newStateId='DELIVERED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='deliveryFailed' newStateId='DELIVERY_FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='DELIVERY_FAILED'
                  description="All delivery attempts exhausted, shipment returned to warehouse">
      <on eventId='startProcessing' newStateId='PROCESSING' meta-acls="ADMIN"/>
      <on eventId='requestCancellation' newStateId='CANCEL_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
      <on eventId='requestRefund' newStateId='REFUND_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='DELIVERED' meta-mainPath="true"
                  description="Order delivered to customer">
      <on eventId='confirmDelivery' newStateId='COMPLETED' meta-mainPath="true" meta-acls="CUSTOMER,SYSTEM"/>
      <on eventId='requestReturn' newStateId='RETURN_REQUESTED' meta-acls="CUSTOMER"/>
      <on eventId='requestRefund' newStateId='REFUND_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='COMPLETED' meta-mainPath="true"
                  description="Order completed and confirmed by customer">
      <on eventId='requestReturn' newStateId='RETURN_REQUESTED' meta-acls="CUSTOMER"/>
      <on eventId='requestRefund' newStateId='REFUND_REQUESTED' meta-acls="CUSTOMER,ADMIN"/>
    </manual-state>

    <manual-state id='CANCEL_REQUESTED'
                  description="Cancellation requested, awaiting confirmation">
      <on eventId='confirmCancellation' newStateId='CANCELLED' meta-acls="ADMIN,SYSTEM"/>
    </manual-state>

    <manual-state id='CANCELLATION_DENIED'
                  description="Cancellation denied, window expired or not eligible"/>

    <manual-state id='CANCELLED'
                  description="Order cancelled, inventory released, refund initiated"/>

    <manual-state id='RETURN_REQUESTED'
                  description="Return requested, handed off to return-request BC">
      <on eventId='requestRefund' newStateId='REFUND_REQUESTED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='REFUND_REQUESTED'
                  description="Refund requested, awaiting payment BC processing">
      <on eventId='completeRefund' newStateId='REFUNDED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='REFUNDED'
                  description="Refund completed for the order"/>

  </flow>
</states>
