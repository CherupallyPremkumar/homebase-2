<?xml version="1.0" encoding="UTF-8"?>
<!-- Query-side STM metadata. Stripped from fulfillment-service. No componentName/conditions. -->
<states>

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <event-information eventId='reserveInventory' meta-acls="SYSTEM"           meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='createShipment'   meta-acls="SYSTEM,WAREHOUSE" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='ship'             meta-acls="WAREHOUSE"        meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='notifyCustomer'   meta-acls="SYSTEM"           meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='confirmDelivery'  meta-acls="SYSTEM,CUSTOMER"  meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='fail'             meta-acls="SYSTEM"           meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancel'           meta-acls="SYSTEM,ADMIN"     meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='compensate'       meta-acls="SYSTEM"           meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='retry'            meta-acls="SYSTEM"           meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>

  <flow id='fulfillment-flow' default='true'>

    <status id='INITIATED' initialState='true' meta-mainPath="true"
            description="Fulfillment saga initiated for order">
      <on eventId='reserveInventory' newStateId='INVENTORY_RESERVED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='cancel' newStateId='CANCELLING' meta-acls="SYSTEM,ADMIN"/>
    </status>

    <status id='INVENTORY_RESERVED' meta-mainPath="true"
            description="Inventory reserved for fulfillment">
      <on eventId='createShipment' newStateId='SHIPMENT_CREATED' meta-mainPath="true" meta-acls="SYSTEM,WAREHOUSE"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='cancel' newStateId='CANCELLING' meta-acls="SYSTEM,ADMIN"/>
    </status>

    <status id='SHIPMENT_CREATED' meta-mainPath="true"
            description="Shipment created with carrier">
      <on eventId='ship' newStateId='SHIPPED' meta-mainPath="true" meta-acls="WAREHOUSE"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='cancel' newStateId='CANCELLING' meta-acls="SYSTEM,ADMIN"/>
    </status>

    <status id='SHIPPED' meta-mainPath="true"
            description="Order shipped and in transit">
      <on eventId='notifyCustomer' newStateId='CUSTOMER_NOTIFIED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
    </status>

    <status id='CUSTOMER_NOTIFIED' meta-mainPath="true"
            description="Customer notified about shipment status">
      <on eventId='confirmDelivery' newStateId='COMPLETED' meta-mainPath="true" meta-acls="SYSTEM,CUSTOMER"/>
    </status>

    <status id='COMPLETED' description="Fulfillment completed successfully"/>

    <status id='CANCELLING' description="Fulfillment being cancelled, compensating saga steps">
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </status>

    <status id='COMPENSATION_DONE' description="All saga steps compensated, fulfillment cancelled"/>

    <status id='FAILED' description="Fulfillment failed, can be retried or compensated">
      <on eventId='retry' newStateId='INITIATED' meta-acls="SYSTEM"/>
      <on eventId='compensate' newStateId='COMPENSATION_DONE' meta-acls="SYSTEM"/>
    </status>

  </flow>
</states>
