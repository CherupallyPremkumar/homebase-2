<?xml version="1.0" encoding="UTF-8"?>
<!-- Query-side STM metadata. Stripped from payment-service. No componentName/conditions. -->
<states>

  <event-information eventId='create'                meta-acls="ADMIN,SYSTEM"     meta-bodyType="com.homebase.ecom.payment.dto.InitiatePaymentPayload"/>
  <event-information eventId='process'              meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.ProcessPaymentPayload"/>
  <event-information eventId='initiateCod'          meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.InitiateCodPayload"/>
  <event-information eventId='requestAuthentication' meta-acls="SYSTEM"          meta-bodyType="com.homebase.ecom.payment.dto.RequestAuthenticationPayload"/>
  <event-information eventId='completeAuthentication' meta-acls="SYSTEM,CUSTOMER" meta-bodyType="com.homebase.ecom.payment.dto.CompleteAuthenticationPayload"/>
  <event-information eventId='failAuthentication'   meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.FailAuthenticationPayload"/>
  <event-information eventId='succeed'              meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.ProcessPaymentPayload"/>
  <event-information eventId='fail'                 meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.FailPaymentPayload"/>
  <event-information eventId='timeout'              meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.TimeoutPaymentPayload"/>
  <event-information eventId='retry'                meta-acls="SYSTEM,ADMIN"     meta-bodyType="com.homebase.ecom.payment.dto.RetryPaymentPayload"/>
  <event-information eventId='abandon'              meta-acls="SYSTEM,ADMIN"     meta-bodyType="com.homebase.ecom.payment.dto.AbandonPaymentPayload"/>
  <event-information eventId='settle'               meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.SettlePaymentPayload"/>
  <event-information eventId='initiateRefund'       meta-acls="ADMIN,SYSTEM"     meta-bodyType="com.homebase.ecom.payment.dto.InitiateRefundPayload"/>
  <event-information eventId='processRefund'        meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.ProcessRefundPayload"/>
  <event-information eventId='completeRefund'       meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.CompleteRefundPayload"/>
  <event-information eventId='failRefund'           meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.FailRefundPayload"/>
  <event-information eventId='initiateChargeback'   meta-acls="SYSTEM"           meta-bodyType="com.homebase.ecom.payment.dto.InitiateChargebackPayload"/>
  <event-information eventId='resolveChargeback'    meta-acls="ADMIN"            meta-bodyType="com.homebase.ecom.payment.dto.ResolveChargebackPayload"/>
  <event-information eventId='collectCod'           meta-acls="CARRIER,SYSTEM"   meta-bodyType="com.homebase.ecom.payment.dto.CollectCodPayload"/>

  <flow id='payment-flow' default='true'>

    <manual-state id='INITIATED' initialState='true' meta-mainPath="true"
                  description="Payment initiated, awaiting gateway processing">
      <on eventId='process' newStateId='PROCESSING' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='initiateCod' newStateId='COD_PENDING' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='PROCESSING' meta-mainPath="true"
                  description="Payment being processed by gateway">
      <on eventId='succeed' newStateId='SUCCEEDED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='requestAuthentication' newStateId='AWAITING_AUTHENTICATION' meta-acls="SYSTEM"/>
      <on eventId='fail' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='timeout' newStateId='TIMED_OUT' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='AWAITING_AUTHENTICATION'
                  description="Awaiting 3DS/OTP authentication from customer">
      <on eventId='completeAuthentication' newStateId='PROCESSING' meta-acls="SYSTEM,CUSTOMER"/>
      <on eventId='failAuthentication' newStateId='FAILED' meta-acls="SYSTEM"/>
      <on eventId='timeout' newStateId='TIMED_OUT' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='TIMED_OUT'
                  description="Payment timed out waiting for gateway response">
      <on eventId='retry' newStateId='RETRY' meta-acls="SYSTEM,ADMIN"/>
      <on eventId='abandon' newStateId='ABANDONED' meta-acls="SYSTEM,ADMIN"/>
    </manual-state>

    <manual-state id='SUCCEEDED' meta-mainPath="true"
                  description="Payment succeeded, awaiting settlement">
      <on eventId='settle' newStateId='SETTLED' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='initiateRefund' newStateId='REFUND_INITIATED' meta-acls="ADMIN,SYSTEM"/>
      <on eventId='initiateChargeback' newStateId='CHARGEBACK_INITIATED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='SETTLED' meta-mainPath="true"
                  description="Payment settled, funds transferred">
      <on eventId='initiateRefund' newStateId='REFUND_INITIATED' meta-acls="ADMIN,SYSTEM"/>
      <on eventId='initiateChargeback' newStateId='CHARGEBACK_INITIATED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='FAILED'
                  description="Payment failed at gateway">
      <on eventId='retry' newStateId='RETRY' meta-acls="SYSTEM,ADMIN"/>
      <on eventId='abandon' newStateId='ABANDONED' meta-acls="SYSTEM,ADMIN"/>
    </manual-state>

    <manual-state id='RETRY'
                  description="Payment retry queued">
      <on eventId='process' newStateId='PROCESSING' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='ABANDONED'
                  description="Payment abandoned after max retries or manual abandonment"/>

    <manual-state id='COD_PENDING'
                  description="Cash on delivery — awaiting collection at delivery">
      <on eventId='collectCod' newStateId='SUCCEEDED' meta-mainPath="true" meta-acls="CARRIER,SYSTEM"/>
      <on eventId='fail' newStateId='COD_FAILED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='COD_FAILED'
                  description="COD collection failed at delivery">
      <on eventId='retry' newStateId='COD_PENDING' meta-acls="SYSTEM,ADMIN"/>
      <on eventId='abandon' newStateId='ABANDONED' meta-acls="SYSTEM,ADMIN"/>
    </manual-state>

    <manual-state id='REFUND_INITIATED'
                  description="Refund requested, awaiting gateway processing">
      <on eventId='processRefund' newStateId='REFUND_PROCESSING' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='REFUND_PROCESSING'
                  description="Refund being processed by gateway">
      <on eventId='completeRefund' newStateId='REFUNDED' meta-acls="SYSTEM"/>
      <on eventId='failRefund' newStateId='REFUND_INITIATED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='REFUNDED'
                  description="Full refund completed successfully"/>

    <manual-state id='PARTIALLY_REFUNDED'
                  description="Partial refund completed, additional refunds possible">
      <on eventId='initiateRefund' newStateId='REFUND_INITIATED' meta-acls="ADMIN,SYSTEM"/>
      <on eventId='initiateChargeback' newStateId='CHARGEBACK_INITIATED' meta-acls="SYSTEM"/>
    </manual-state>

    <manual-state id='CHARGEBACK_INITIATED'
                  description="Chargeback initiated by card network, evidence required">
      <on eventId='resolveChargeback' newStateId='SETTLED' meta-acls="ADMIN"/>
    </manual-state>

  </flow>
</states>
