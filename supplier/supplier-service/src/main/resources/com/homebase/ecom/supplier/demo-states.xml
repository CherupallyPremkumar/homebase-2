<?xml version="1.0" encoding="UTF-8"?>
<!-- Demo states XML for Chenile workflow features demonstration.
 Demonstrates activity framework, custom DSL, and enablement strategy.
 NOT used in production — production flow is in supplier-states.xml.
-->
<states>
    <enablement-strategy componentName="supplierConfigBasedEnablementStrategy"/>
	<default-transition-action componentName="supplierBaseTransitionAction"/>
    <add-transition-tag tag="mandatory-activity" meta-activity="MANDATORY"
                         eventIdTag="id"/>
    <add-transition-tag tag="optional-activity" meta-activity="OPTIONAL"
                         eventIdTag="id"/>
    <add-state-tag tag="status" manualState="true"/>
    <add-transition-tag tag="on-action" eventIdTag="id" newStateIdTag="move-to"/>

	<flow id='SupplierFlow' default='false'>
		<entry-action componentName="supplierEntryAction"/>
		<exit-action componentName="supplierExitAction"/>
		<status id='OPENED' initialState='true'>
			<on-action id='assign'  move-to='ASSIGNED'/>
		</status>

		<status id='ASSIGNED'>
			<on-action id='resolve' move-to='RESOLVED' />
		</status>

        <status id='RESOLVED'>
            <mandatory-activity id='doRetrospective'/>
            <mandatory-activity id='doPerfTesting'/>
            <on-action id='close' move-to='CLOSED'/>
        </status>
        <status id='CLOSED' />

	</flow>

</states>
