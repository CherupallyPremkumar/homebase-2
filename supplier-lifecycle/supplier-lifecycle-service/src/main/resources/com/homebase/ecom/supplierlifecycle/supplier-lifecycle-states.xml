<?xml version="1.0" encoding="UTF-8"?>
<states>
  <scripting-strategy componentName="ognlScriptingStrategy"/>
  <default-transition-action componentName="supplierLifecycleBaseTransitionAction"/>

  <add-state-tag tag="status" manualState="true" descriptorClass="org.chenile.stm.model.StateDescriptor"/>

  <!-- ════════════════════════════════════════════════════════════════════════ -->
  <!-- Supplier Lifecycle Saga — two flows:                                   -->
  <!--   suspend-flow:    disable products → clear catalog → freeze inventory -->
  <!--                    → cancel orders → notify customers                  -->
  <!--   reactivate-flow: enable products → restore catalog → unfreeze        -->
  <!--                    → notify supplier                                   -->
  <!--                                                                        -->
  <!-- Cross-BC Events (consumed via Kafka):                                  -->
  <!--   supplier.SUSPENDED    → initiates suspend-flow                       -->
  <!--   supplier.REACTIVATED  → initiates reactivate-flow                    -->
  <!--                                                                        -->
  <!-- Cross-BC Events (published per step via PostSaveHook → Kafka):         -->
  <!--   PRODUCTS_DISABLED  → product.disableProduct (per supplier product)   -->
  <!--   CATALOG_CLEARED    → catalog.removeBySeller                          -->
  <!--   INVENTORY_FROZEN   → inventory.freeze (per supplier SKU)             -->
  <!--   ORDERS_CANCELLED   → order.requestCancellation (per open order)      -->
  <!--   PRODUCTS_ENABLED   → product.enableProduct (per supplier product)    -->
  <!--   CATALOG_RESTORED   → catalog.restoreBySeller                         -->
  <!--   INVENTORY_UNFROZEN → inventory.unfreeze (per supplier SKU)           -->
  <!-- ════════════════════════════════════════════════════════════════════════ -->

  <event-information eventId='disableProducts'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='removeCatalog'    meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='freezeInventory'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancelOrders'     meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='notifyCustomers'  meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='enableProducts'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='restoreCatalog'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='unfreezeInventory' meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='notifySupplier'   meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='fail'             meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='cancel'           meta-acls="SYSTEM,ADMIN" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='compensate'       meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>
  <event-information eventId='retry'            meta-acls="SYSTEM" meta-bodyType="org.chenile.workflow.param.MinimalPayload"/>

  <!-- ════════════════════════════════════════════════════════════════════════ -->
  <!-- SUSPEND FLOW: Disable supplier across all BCs                          -->
  <!-- ════════════════════════════════════════════════════════════════════════ -->

  <flow id='suspend-flow' default='true'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="supplierLifecycleEntryAction" />
    <exit-action componentName="supplierLifecycleExitAction" />

    <status id='INITIATED' initialState='true' meta-mainPath="true"
            description="Supplier suspension saga initiated">
      <on eventId='disableProducts'
          componentName='supplierLifecycleDisableProductsAction'
          newStateId='PRODUCTS_DISABLED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
      <on eventId='cancel'
          componentName='supplierLifecycleCancelAction'
          newStateId='CANCELLING'
          meta-acls="SYSTEM,ADMIN"/>
    </status>

    <status id='PRODUCTS_DISABLED' meta-mainPath="true"
            description="All supplier products disabled from storefront">
      <on eventId='removeCatalog'
          componentName='supplierLifecycleRemoveCatalogAction'
          newStateId='CATALOG_CLEARED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='CATALOG_CLEARED' meta-mainPath="true"
            description="Supplier catalog entries removed">
      <on eventId='freezeInventory'
          componentName='supplierLifecycleFreezeInventoryAction'
          newStateId='INVENTORY_FROZEN'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='INVENTORY_FROZEN' meta-mainPath="true"
            description="Supplier inventory frozen, no new reservations">
      <on eventId='cancelOrders'
          componentName='supplierLifecycleCancelOrdersAction'
          newStateId='ORDERS_CANCELLED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='ORDERS_CANCELLED' meta-mainPath="true"
            description="Open orders for supplier cancelled">
      <on eventId='notifyCustomers'
          componentName='supplierLifecycleNotifyCustomersAction'
          newStateId='COMPLETED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='COMPLETED' description="Supplier suspension completed successfully">
    </status>

    <status id='CANCELLING' description="Suspension being cancelled, compensating steps">
      <on eventId='compensate'
          componentName='supplierLifecycleCompensateAction'
          newStateId='COMPENSATION_DONE'
          meta-acls="SYSTEM"/>
    </status>

    <status id='COMPENSATION_DONE' description="All suspension steps compensated">
    </status>

    <status id='FAILED' description="Supplier suspension failed, can be retried or compensated">
      <on eventId='retry'
          componentName='supplierLifecycleRetryAction'
          newStateId='INITIATED'
          meta-acls="SYSTEM"/>
      <on eventId='compensate'
          componentName='supplierLifecycleCompensateAction'
          newStateId='COMPENSATION_DONE'
          meta-acls="SYSTEM"/>
    </status>

    <manual-state id='__TERMINAL_STATE__' description="Terminal state for activity completion testing">
    </manual-state>
  </flow>

  <!-- ════════════════════════════════════════════════════════════════════════ -->
  <!-- REACTIVATE FLOW: Re-enable supplier across all BCs                     -->
  <!-- ════════════════════════════════════════════════════════════════════════ -->

  <flow id='reactivate-flow'>
    <security-strategy componentName="stmSecurityStrategy"/>
    <entry-action componentName="supplierLifecycleEntryAction" />
    <exit-action componentName="supplierLifecycleExitAction" />

    <status id='INITIATED' initialState='true' meta-mainPath="true"
            description="Supplier reactivation saga initiated">
      <on eventId='enableProducts'
          componentName='supplierLifecycleEnableProductsAction'
          newStateId='PRODUCTS_ENABLED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
      <on eventId='cancel'
          componentName='supplierLifecycleCancelAction'
          newStateId='CANCELLING'
          meta-acls="SYSTEM,ADMIN"/>
    </status>

    <status id='PRODUCTS_ENABLED' meta-mainPath="true"
            description="Supplier products re-enabled on storefront">
      <on eventId='restoreCatalog'
          componentName='supplierLifecycleRestoreCatalogAction'
          newStateId='CATALOG_RESTORED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='CATALOG_RESTORED' meta-mainPath="true"
            description="Supplier catalog entries restored">
      <on eventId='unfreezeInventory'
          componentName='supplierLifecycleUnfreezeInventoryAction'
          newStateId='INVENTORY_UNFROZEN'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='INVENTORY_UNFROZEN' meta-mainPath="true"
            description="Supplier inventory unfrozen, reservations allowed">
      <on eventId='notifySupplier'
          componentName='supplierLifecycleNotifySupplierAction'
          newStateId='COMPLETED'
          meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='fail'
          componentName='supplierLifecycleFailAction'
          newStateId='FAILED'
          meta-acls="SYSTEM"/>
    </status>

    <status id='COMPLETED' description="Supplier reactivation completed successfully">
    </status>

    <status id='CANCELLING' description="Reactivation being cancelled, compensating steps">
      <on eventId='compensate'
          componentName='supplierLifecycleCompensateAction'
          newStateId='COMPENSATION_DONE'
          meta-acls="SYSTEM"/>
    </status>

    <status id='COMPENSATION_DONE' description="All reactivation steps compensated">
    </status>

    <status id='FAILED' description="Supplier reactivation failed, can be retried or compensated">
      <on eventId='retry'
          componentName='supplierLifecycleRetryAction'
          newStateId='INITIATED'
          meta-acls="SYSTEM"/>
      <on eventId='compensate'
          componentName='supplierLifecycleCompensateAction'
          newStateId='COMPENSATION_DONE'
          meta-acls="SYSTEM"/>
    </status>

    <manual-state id='__TERMINAL_STATE__' description="Terminal state for activity completion testing">
    </manual-state>
  </flow>
</states>
