
<states>
  <flow id='supplier-product-flow' default='true'>
    <entry-action componentName="productEntryAction" />
    <exit-action componentName="productExitAction" />
    
    <manual-state id='PENDING_DELIVERY' initialState='true' meta-mainPath="true">
      <on eventId='productDelivered' 
          componentName='productDeliveredCommand'
          newStateId='QUALITY_CHECK' 
          meta-mainPath="true"/>
      <on eventId='cancelProduct' 
          componentName='cancelProductCommand'
          newStateId='DISCONTINUED'/>
    </manual-state>

    <manual-state id='QUALITY_CHECK' meta-mainPath="true">
      <entry-action componentName="qualityCheckInitiateAction" />
      <on eventId='approveQuality' 
          componentName='approveQualityCommand'
          newStateId='APPROVED' 
          meta-mainPath="true"
          meta-acls="QUALITY_CHECKER"/>
      <on eventId='rejectQuality' 
          componentName='rejectQualityCommand'
          newStateId='PENDING_DELIVERY'
          meta-acls="QUALITY_CHECKER"/>
      <on eventId='needsRework' 
          componentName='reworkCommand'
          newStateId='QUALITY_CHECK'
          meta-acls="QUALITY_CHECKER"/>
    </manual-state>

    <manual-state id='APPROVED' meta-mainPath="true">
      <on eventId='publishProduct' 
          componentName='publishProductCommand'
          newStateId='AT_WAREHOUSE' 
          meta-mainPath="true"
          meta-acls="SUPPLIER,ADMIN"/>
    </manual-state>

    <manual-state id='AT_WAREHOUSE' meta-mainPath="true">
      <on eventId='listProduct' 
          componentName='listProductCommand'
          newStateId='ACTIVE' 
          meta-mainPath="true"
          meta-acls="SUPPLIER"/>
    </manual-state>

    <manual-state id='ACTIVE' meta-mainPath="true">
      <entry-action componentName="productLiveNotificationAction" />
      <on eventId='stockSoldOut' 
          componentName='outOfStockCommand'
          newStateId='OUT_OF_STOCK'/>
      <on eventId='discontinueProduct' 
          componentName='discontinueProductCommand'
          newStateId='DISCONTINUED'
          meta-acls="SUPPLIER,ADMIN"/>
      <on eventId='restockProduct' 
          newStateId='ACTIVE'/>
    </manual-state>

    <manual-state id='OUT_OF_STOCK'>
      <on eventId='restockArrive' 
          componentName='restockCommand'
          newStateId='ACTIVE' 
          meta-mainPath="true"/>
      <on eventId='markDiscontinued' 
          newStateId='DISCONTINUED'/>
    </manual-state>

    <manual-state id='DISCONTINUED'>
      <exit-action componentName="productDiscontinuedAction" />
    </manual-state>
  </flow>
</states>