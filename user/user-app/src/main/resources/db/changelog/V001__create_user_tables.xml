<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="V001-create-user-profiles" author="homebase">
        <createTable tableName="user_profiles">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant" type="VARCHAR(50)" defaultValue="homebase"/>
            <column name="keycloak_id" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="first_name" type="VARCHAR(100)"/>
            <column name="last_name" type="VARCHAR(100)"/>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="role" type="VARCHAR(30)" defaultValue="CUSTOMER"/>
            <column name="default_address_id" type="VARCHAR(36)"/>
            <column name="kyc_status" type="VARCHAR(30)"/>
            <column name="login_attempts" type="INT" defaultValueNumeric="0"/>
            <column name="last_login_at" type="TIMESTAMP"/>
            <column name="lock_reason" type="VARCHAR(500)"/>
            <column name="suspend_reason" type="VARCHAR(500)"/>
            <column name="pref_language" type="VARCHAR(10)" defaultValue="en"/>
            <column name="pref_currency" type="VARCHAR(10)" defaultValue="INR"/>
            <column name="pref_email_notif" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="pref_sms_notif" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="pref_timezone" type="VARCHAR(50)" defaultValue="Asia/Kolkata"/>
            <column name="state_id" type="VARCHAR(50)"/>
            <column name="flow_id" type="VARCHAR(50)"/>
            <column name="version" type="INT" defaultValueNumeric="0"/>
            <column name="created_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="user_profiles" columnNames="keycloak_id" constraintName="uk_user_keycloak_id"/>
        <addUniqueConstraint tableName="user_profiles" columnNames="email" constraintName="uk_user_email"/>

        <createIndex tableName="user_profiles" indexName="idx_user_state">
            <column name="state_id"/>
        </createIndex>
        <createIndex tableName="user_profiles" indexName="idx_user_role">
            <column name="role"/>
        </createIndex>
    </changeSet>

    <changeSet id="V001-create-user-address" author="homebase">
        <createTable tableName="user_address">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant" type="VARCHAR(50)" defaultValue="homebase"/>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(50)"/>
            <column name="line1" type="VARCHAR(255)"/>
            <column name="line2" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(100)"/>
            <column name="postal_code" type="VARCHAR(20)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="version" type="INT" defaultValueNumeric="0"/>
            <column name="created_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_address_user"
            baseTableName="user_address" baseColumnNames="user_id"
            referencedTableName="user_profiles" referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="V001-create-user-activity-log" author="homebase">
        <createTable tableName="user_activity_log">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant" type="VARCHAR(50)" defaultValue="homebase"/>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="activity_name" type="VARCHAR(100)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(500)"/>
            <column name="version" type="INT" defaultValueNumeric="0"/>
            <column name="created_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="last_modified_time" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_activity_user"
            baseTableName="user_activity_log" baseColumnNames="user_id"
            referencedTableName="user_profiles" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
