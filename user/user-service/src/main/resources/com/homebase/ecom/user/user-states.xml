<?xml version="1.0" encoding="UTF-8"?>
<states>
  <flow id='user-flow' default='true'>
    <security-strategy componentName="userSecurityStrategy"/>
    <entry-action componentName="userEntryAction"/>
    <exit-action componentName="userExitAction"/>

    <manual-state id='PENDING_VERIFICATION' initialState='true' meta-mainPath="true" description="Created on first login, email not verified">
      <on eventId='verifyEmail' componentName='userVerifyEmailAction' newStateId='ACTIVE' meta-mainPath="true" meta-acls="SYSTEM"/>
      <on eventId='resendVerification' componentName='userResendVerificationAction' meta-acls="CUSTOMER"/>
      <on eventId='deleteAccount' componentName='userDeleteAccountAction' newStateId='DELETED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='ACTIVE' meta-mainPath="true" description="Fully active user">
      <on eventId='updateProfile' componentName='userUpdateProfileAction' meta-acls="CUSTOMER"/>
      <on eventId='changePassword' componentName='userChangePasswordAction' meta-acls="CUSTOMER"/>
      <on eventId='addAddress' componentName='userAddAddressAction' meta-acls="CUSTOMER"/>
      <on eventId='removeAddress' componentName='userRemoveAddressAction' meta-acls="CUSTOMER"/>
      <on eventId='lockAccount' componentName='userLockAccountAction' newStateId='LOCKED' meta-acls="SYSTEM"/>
      <on eventId='suspendUser' componentName='userSuspendUserAction' newStateId='SUSPENDED' meta-acls="ADMIN"/>
      <on eventId='deleteAccount' componentName='userDeleteAccountAction' newStateId='DELETED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='LOCKED' description="Locked after failed login attempts">
      <on eventId='unlockAccount' componentName='userUnlockAccountAction' newStateId='ACTIVE' meta-mainPath="true" meta-acls="ADMIN,SYSTEM"/>
      <on eventId='deleteAccount' componentName='userDeleteAccountAction' newStateId='DELETED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='SUSPENDED' description="Suspended by admin for policy violation">
      <on eventId='reinstateUser' componentName='userReinstateUserAction' newStateId='ACTIVE' meta-mainPath="true" meta-acls="ADMIN"/>
      <on eventId='deleteAccount' componentName='userDeleteAccountAction' newStateId='DELETED' meta-acls="ADMIN"/>
    </manual-state>

    <manual-state id='DELETED' description="Soft-deleted user account"/>
  </flow>
</states>
