<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ================================================================= -->
    <!-- Orders table — aligned with OrderEntity (stateId/flowId convention) -->
    <!-- ================================================================= -->
    <changeSet id="001-create-orders" author="homebase">
        <createTable tableName="orders">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_number" type="VARCHAR(255)">
                <constraints unique="true"/>
            </column>
            <column name="customer_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="subtotal" type="DECIMAL(12,2)"/>
            <column name="tax_amount" type="DECIMAL(12,2)"/>
            <column name="shipping_amount" type="DECIMAL(12,2)"/>
            <column name="total_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)" defaultValue="INR">
                <constraints nullable="false"/>
            </column>
            <column name="shipping_address_id" type="VARCHAR(255)"/>
            <column name="billing_address_id" type="VARCHAR(255)"/>
            <column name="payment_method_id" type="VARCHAR(255)"/>
            <column name="notes" type="TEXT"/>
            <column name="cancel_reason" type="VARCHAR(1000)"/>
            <column name="description" type="VARCHAR(2000)"/>

            <!-- Chenile STM fields (from AbstractJpaStateEntity) -->
            <column name="state_id" type="VARCHAR(255)"/>
            <column name="flow_id" type="VARCHAR(255)"/>
            <column name="created_time" type="TIMESTAMP"/>
            <column name="updated_time" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="orders" indexName="idx_orders_customer_id">
            <column name="customer_id"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_state_id">
            <column name="state_id"/>
        </createIndex>

        <createIndex tableName="orders" indexName="idx_orders_order_number">
            <column name="order_number"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================= -->
    <!-- Order Items table                                                  -->
    <!-- ================================================================= -->
    <changeSet id="001-create-order-items" author="homebase">
        <createTable tableName="order_items">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="variant_id" type="VARCHAR(255)"/>
            <column name="sku" type="VARCHAR(255)"/>
            <column name="product_name" type="VARCHAR(500)"/>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="unit_price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="total_price" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="order_items" baseColumnNames="order_id"
            referencedTableName="orders" referencedColumnNames="id"
            constraintName="fk_order_items_order"/>

        <createIndex tableName="order_items" indexName="idx_order_items_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

    <!-- ================================================================= -->
    <!-- Order Activity Log table                                           -->
    <!-- ================================================================= -->
    <changeSet id="001-create-order-activity" author="homebase">
        <createTable tableName="order_activity">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(255)"/>
            <column name="activity_name" type="VARCHAR(255)"/>
            <column name="activity_success" type="BOOLEAN"/>
            <column name="activity_comment" type="VARCHAR(2000)"/>
        </createTable>

        <createIndex tableName="order_activity" indexName="idx_order_activity_order">
            <column name="order_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
