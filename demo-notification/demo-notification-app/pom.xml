<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.homebase.ecom.demonotification</groupId>
        <artifactId>demo-notification-parent</artifactId>
        <version>${revision}</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>demo-notification-app</artifactId>
    <packaging>jar</packaging>
    <name>demo-notification-app</name>
    <description>Standalone Spring Boot application for demo-notification (runs on port 8081)</description>

    <dependencies>
        <!-- Demo-notification modules -->
        <dependency>
            <groupId>com.homebase.ecom.demonotification</groupId>
            <artifactId>demo-notification-api</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.demonotification</groupId>
            <artifactId>demo-notification-domain</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.demonotification</groupId>
            <artifactId>demo-notification-infrastructure</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.demonotification</groupId>
            <artifactId>demo-notification-service</artifactId>
        </dependency>
        <dependency>
            <groupId>com.homebase.ecom.demonotification</groupId>
            <artifactId>demo-notification-kafka</artifactId>
        </dependency>

        <!-- Security API -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>chenile-security-api</artifactId>
        </dependency>

        <!-- Spring Boot and Chenile Infrastructure -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>chenile-http</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- Database -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- Service Registry -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>service-registry-service</artifactId>
        </dependency>
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>service-registry-delegate</artifactId>
        </dependency>

        <!-- Kafka -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>chenile-kafka</artifactId>
        </dependency>

        <!-- Service Registry -->
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>service-registry-service</artifactId>
        </dependency>
        <dependency>
            <groupId>org.chenile</groupId>
            <artifactId>service-registry-delegate</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <mainClass>com.homebase.ecom.demonotification.DemoNotificationApp</mainClass>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
